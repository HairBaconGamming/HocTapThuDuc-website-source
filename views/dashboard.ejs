<%- include('partials/header') %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="/css/styleDashboard.css">

<%
    const toNumber = (value, fallback = 0) => {
        const parsed = Number(value);
        return Number.isFinite(parsed) ? parsed : fallback;
    };
    const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
    const encodeAvatarName = (value) => encodeURIComponent(String(value || 'Hoc vien'));

    const safeUser = user || {};
    const safeUsername = String(safeUser.username || 'Hoc vien').trim() || 'Hoc vien';
    const safeAvatar = safeUser.avatar || `https://ui-avatars.com/api/?name=${encodeAvatarName(safeUsername)}&background=eff6ff&color=1d4ed8`;
    <% 
        const safeLevel = levelInfo ? levelInfo.level : Math.max(1, toNumber(safeUser.level, 1));
        const safeXP = levelInfo ? levelInfo.currentXP : Math.max(0, toNumber(safeUser.xp, 0));
        const nextLevelXP = levelInfo ? levelInfo.requiredXP : Math.max(0, safeLevel * 1000);
        const safePercent = levelInfo ? levelInfo.progress : (nextLevelXP > 0 ? Math.min(100, Math.round((safeXP / nextLevelXP) * 100)) : 0);
    %>
    const safePoints = Math.max(0, toNumber(safeUser.points, 0));
    const safeStreak = Math.max(0, toNumber(safeUser.currentStreak, 0));
    const safeCompletedLessons = Math.max(0, toNumber(completedLessonsCount, 0)); 

    const safeRecentCourse = recentCourse && typeof recentCourse === 'object'
        ? {
            _id: recentCourse._id || '',
            href: recentCourse._id ? `/course/${recentCourse._id}` : '/courses',
            title: String(recentCourse.title || 'Khoa hoc gan day'),
            image: String(recentCourse.image || ''),
            progress: clamp(toNumber(recentCourse.progress, 0), 0, 100),
            completedLessons: Math.max(0, toNumber(recentCourse.completedLessons, 0)),
            totalLessons: Math.max(0, toNumber(recentCourse.totalLessons, 0))
        }
        : null;

    const safeEnrolledCourses = Array.isArray(enrolledCourses)
        ? enrolledCourses.map((course) => ({
            _id: course?._id || '',
            href: course?._id ? `/course/${course._id}` : '/courses',
            title: String(course?.title || 'Khoa hoc'),
            image: String(course?.image || ''),
            progress: clamp(toNumber(course?.progress, 0), 0, 100),
            completedLessons: Math.max(0, toNumber(course?.completedLessons, 0)),
            totalLessons: Math.max(0, toNumber(course?.totalLessons, 0))
        }))
        : [];

    const safeAchievements = Array.isArray(userAchievements)
        ? userAchievements.map((item) => {
            const achievement = item?.achievementId || {};
            return {
                id: item?._id || achievement?._id || '',
                name: String(achievement?.name || 'Thanh tich moi'),
                icon: String(achievement?.icon || '🏆'),
                unlockedAt: item?.unlockedAt ? new Date(item.unlockedAt) : null
            };
        })
        : [];

    const hasGardenData = !!gardenData;
    const safeGardenData = {
        water: Math.max(0, toNumber(gardenData?.water, 0)),
        gold: Math.max(0, toNumber(gardenData?.gold, 0))
    };

    const safeWeeklyActivity = (() => {
        try {
            const raw = typeof weeklyActivity === 'string' ? JSON.parse(weeklyActivity) : weeklyActivity;
            if (!Array.isArray(raw)) {
                return [0, 0, 0, 0, 0, 0, 0];
            }
            return Array.from({ length: 7 }, (_, index) => {
                const value = Math.max(0, toNumber(raw[index], 0));
                return Number(value.toFixed(1));
            });
        } catch (error) {
            return [0, 0, 0, 0, 0, 0, 0];
        }
    })();

    const totalWeeklyHours = safeWeeklyActivity.reduce((sum, value) => sum + toNumber(value, 0), 0).toFixed(1);
%>

<script>
    window.WEEKLY_ACTIVITY = <%- JSON.stringify(safeWeeklyActivity) %>;
</script>

<div class="dashboard-shell">
    <div class="dashboard-container">
        <section class="dashboard-hero">
            <div class="dashboard-hero__main">
                <div class="dashboard-hero__identity">
                    <div class="dashboard-avatar">
                        <img src="<%= safeAvatar %>" alt="Avatar cua <%= safeUsername %>" onerror="this.src='https://ui-avatars.com/api/?name=<%= encodeAvatarName(safeUsername) %>&background=eff6ff&color=1d4ed8';">
                        <span class="dashboard-avatar__badge">LV. <%= safeLevel %></span>
                    </div>

                    <div class="dashboard-hero__copy">
                        <p class="dashboard-eyebrow">Bang dieu khien hoc tap</p>
                        <h1 class="dashboard-title dashboard-truncate-single" title="<%= safeUsername %>">Chao, <%= safeUsername %>!</h1>
                        <p class="dashboard-subtitle">Theo doi tien do hoc tap, vuon cua ban va quay lai nhung khoa hoc dang hoc ma khong bi roi boi giao dien.</p>

                        <div class="dashboard-xp">
                            <div class="dashboard-xp__header">
                                <span class="dashboard-xp__label">Tien do cap do</span>
                                <span class="dashboard-xp__meta"><%= safeXP %> / <%= nextLevelXP %> XP</span>
                            </div>
                            <div class="xp-bar-container" title="<%= safeXP %> / <%= nextLevelXP %> XP ( synced with garden )">
                                <div class="xp-bar-fill" style="width: <%= safePercent %>%;"></div>
                            </div>
                            <div class="dashboard-xp__footer">
                                <span>Da dat <strong><%= safePercent %>%</strong> cap do hien tai</span>
                                <span>Con <strong><%= Math.max(0, nextLevelXP - safeXP) %> XP</strong> de len cap</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="dashboard-hero__stats" aria-label="Thong ke tong quan">
                <div class="hero-stat-pill">
                    <span class="hero-stat-pill__icon">⚡</span>
                    <div>
                        <span class="hero-stat-pill__value"><%= safePoints %></span>
                        <span class="hero-stat-pill__label">Diem</span>
                    </div>
                </div>
                <div class="hero-stat-pill">
                    <span class="hero-stat-pill__icon">🔥</span>
                    <div>
                        <span class="hero-stat-pill__value"><%= safeStreak %></span>
                        <span class="hero-stat-pill__label">Streak</span>
                    </div>
                </div>
                <div class="hero-stat-pill">
                    <span class="hero-stat-pill__icon">🎓</span>
                    <div>
                        <span class="hero-stat-pill__value"><%= safeLevel %></span>
                        <span class="hero-stat-pill__label">Cap do</span>
                    </div>
                </div>
                <div class="hero-stat-pill">
                    <span class="hero-stat-pill__icon">📘</span>
                    <div>
                        <span class="hero-stat-pill__value"><%= safeCompletedLessons %></span>
                        <span class="hero-stat-pill__label">Bai da hoc</span>
                    </div>
                </div>
            </div>
        </section>

        <div class="dash-bento">
            <section class="dashboard-card dashboard-card--feature">
                <div class="dashboard-card__head">
                    <div>
                        <p class="dashboard-card__eyebrow">Resume Course</p>
                        <h2 class="dashboard-card__title">Tiep tuc hoc</h2>
                    </div>
                    <% if (safeRecentCourse) { %>
                        <span class="dashboard-chip"><%= safeRecentCourse.progress %>% hoan thanh</span>
                    <% } %>
                </div>

                <% if (safeRecentCourse) { %>
                    <div class="feature-course">
                        <div class="media-frame feature-course__media <%= safeRecentCourse.image ? '' : 'is-fallback' %>">
                            <% if (safeRecentCourse.image) { %>
                                <img src="<%= safeRecentCourse.image %>" alt="<%= safeRecentCourse.title %>" onerror="this.parentElement.classList.add('is-fallback'); this.remove();">
                            <% } %>
                            <div class="media-placeholder">
                                <span class="media-placeholder__icon">▶</span>
                                <span class="media-placeholder__text">San sang tiep tuc</span>
                            </div>
                        </div>

                        <div class="feature-course__body">
                            <h3 class="dashboard-truncate-multiline" title="<%= safeRecentCourse.title %>"><%= safeRecentCourse.title %></h3>
                            <p class="feature-course__copy">Quay lai bai hoc ban dang theo doi va tiep tuc duy tri nhiep hoc tap ma khong can tim lai tu dau.</p>

                            <div class="feature-course__progress">
                                <div class="feature-course__progress-head">
                                    <span>Da hoc <strong><%= safeRecentCourse.completedLessons %>/<%= safeRecentCourse.totalLessons %></strong> bai</span>
                                    <span><%= safeRecentCourse.progress %>%</span>
                                </div>
                                <div class="progress-track">
                                    <div class="progress-track__fill" style="width: <%= safeRecentCourse.progress %>%;"></div>
                                </div>
                            </div>

                            <div class="feature-course__actions">
                                <a href="<%= safeRecentCourse.href %>" class="dashboard-btn dashboard-btn--primary">Vao hoc ngay</a>
                                <a href="/courses" class="dashboard-btn dashboard-btn--ghost">Kham pha them</a>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="dashboard-empty">
                        <div class="dashboard-empty__icon">✨</div>
                        <h3>Chua co khoa hoc dang theo doi</h3>
                        <p>Hay bat dau mot khoa hoc moi de bang dieu khien nay hien thi tien do hoc tap cua ban.</p>
                        <a href="/courses" class="dashboard-btn dashboard-btn--primary">Kham pha khoa hoc</a>
                    </div>
                <% } %>
            </section>

            <section class="dashboard-card">
                <div class="dashboard-card__head">
                    <div>
                        <p class="dashboard-card__eyebrow">Weekly Learning</p>
                        <h2 class="dashboard-card__title">Gio hoc tuan nay</h2>
                    </div>
                    <span class="dashboard-chip"><%= totalWeeklyHours %> gio</span>
                </div>

                <div class="chart-container">
                    <canvas id="learningChart"></canvas>
                </div>
            </section>

            <section class="dashboard-card">
                <div class="dashboard-card__head">
                    <div>
                        <p class="dashboard-card__eyebrow">Garden Snapshot</p>
                        <h2 class="dashboard-card__title">Nong trai</h2>
                    </div>
                </div>

                <% if (hasGardenData) { %>
                    <div class="garden-panel">
                        <div class="garden-stat">
                            <span class="garden-stat__icon">💧</span>
                            <div>
                                <strong><%= safeGardenData.water %></strong>
                                <span>Nuoc</span>
                            </div>
                        </div>
                        <div class="garden-stat">
                            <span class="garden-stat__icon">🪙</span>
                            <div>
                                <strong><%= safeGardenData.gold %></strong>
                                <span>Vang</span>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="dashboard-empty dashboard-empty--compact">
                        <div class="dashboard-empty__icon">🌱</div>
                        <p>Vuon cua ban chua san sang. Vao cham soc de bat dau tich luy tai nguyen.</p>
                    </div>
                <% } %>

                <a href="/my-garden" class="dashboard-btn dashboard-btn--success">Vao cham soc vuon</a>
            </section>

            <section class="dashboard-card dashboard-card--wide">
                <div class="dashboard-card__head">
                    <div>
                        <p class="dashboard-card__eyebrow">My Library</p>
                        <h2 class="dashboard-card__title">Khoa hoc cua toi</h2>
                    </div>
                    <span class="dashboard-chip"><%= safeEnrolledCourses.length %> khoa hoc</span>
                </div>

                <% if (safeEnrolledCourses.length > 0) { %>
                    <div class="course-list">
                        <% safeEnrolledCourses.forEach((course) => { %>
                            <a href="<%= course.href %>" class="course-list__item">
                                <div class="media-frame course-list__media <%= course.image ? '' : 'is-fallback' %>">
                                    <% if (course.image) { %>
                                        <img src="<%= course.image %>" alt="<%= course.title %>" onerror="this.parentElement.classList.add('is-fallback'); this.remove();">
                                    <% } %>
                                    <div class="media-placeholder">
                                        <span class="media-placeholder__icon">📚</span>
                                    </div>
                                </div>

                                <div class="course-list__body">
                                    <h3 class="dashboard-truncate-multiline" title="<%= course.title %>"><%= course.title %></h3>
                                    <div class="course-list__meta">
                                        <span><%= course.completedLessons %>/<%= course.totalLessons %> bai</span>
                                        <span><%= course.progress %>%</span>
                                    </div>
                                    <div class="progress-track progress-track--small">
                                        <div class="progress-track__fill" style="width: <%= course.progress %>%;"></div>
                                    </div>
                                </div>

                                <span class="course-list__arrow">→</span>
                            </a>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="dashboard-empty dashboard-empty--compact">
                        <div class="dashboard-empty__icon">🧭</div>
                        <p>Ban chua tham gia khoa hoc nao. Thu bat dau voi mot mon hoc gan voi muc tieu cua ban.</p>
                        <a href="/courses" class="dashboard-btn dashboard-btn--primary">Kham pha ngay</a>
                    </div>
                <% } %>
            </section>

            <section class="dashboard-card">
                <div class="dashboard-card__head">
                    <div>
                        <p class="dashboard-card__eyebrow">Recent Achievements</p>
                        <h2 class="dashboard-card__title">Thanh tich</h2>
                    </div>
                </div>

                <% if (safeAchievements.length > 0) { %>
                    <div class="achievement-list">
                        <% safeAchievements.forEach((achievement) => { %>
                            <div class="achievement-item">
                                <div class="achievement-item__icon"><%= achievement.icon %></div>
                                <div class="achievement-item__body">
                                    <h3 class="dashboard-truncate-single" title="<%= achievement.name %>"><%= achievement.name %></h3>
                                    <span><%= achievement.unlockedAt ? achievement.unlockedAt.toLocaleDateString('vi-VN') : 'Moi mo khoa' %></span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="dashboard-empty dashboard-empty--compact">
                        <div class="dashboard-empty__icon">🏆</div>
                        <p>Chua co thanh tich nao. Hay hoan thanh bai hoc de mo khoa nhung cot moc dau tien.</p>
                    </div>
                <% } %>

                <a href="/achievements" class="dashboard-link">Xem tat ca thanh tich</a>
            </section>

            <section class="dashboard-card">
                <div class="dashboard-card__head">
                    <div>
                        <p class="dashboard-card__eyebrow">Quick Access</p>
                        <h2 class="dashboard-card__title">Loi tat</h2>
                    </div>
                </div>

                <div class="shortcut-grid">
                    <a href="/courses" class="shortcut-item">
                        <span class="shortcut-item__icon">🔎</span>
                        <span>Khoa hoc</span>
                    </a>
                    <a href="/leaderboard" class="shortcut-item">
                        <span class="shortcut-item__icon">📈</span>
                        <span>Bang xep hang</span>
                    </a>
                    <a href="/profile/edit" class="shortcut-item">
                        <span class="shortcut-item__icon">⚙️</span>
                        <span>Ho so</span>
                    </a>
                </div>
            </section>
        </div>
    </div>
</div>

<script src="/js/dashboard.js"></script>
<%- include('partials/footer') %>
