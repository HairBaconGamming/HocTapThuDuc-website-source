<%- include('partials/header') %>
<link rel="stylesheet" href="/css/styleNewsDetail.css">

<!-- READING PROGRESS BAR -->
<div class="nd-progress-bar" id="progressBar"></div>

<!-- HERO IMAGE -->
<% const heroImg = newsItem.image || 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1200&auto=format&fit=crop'; %>
<div class="nd-hero">
    <img src="<%= heroImg %>" class="nd-hero-img" alt="<%= newsItem.title %>">
    <div class="nd-hero-overlay"></div>
</div>

<article class="nd-article">
    <!-- ARTICLE HEADER -->
    <header class="nd-header">
        <div class="nd-top-bar">
            <span class="nd-cat"><%= newsItem.category || 'Tin tức' %></span>
            <%
                // Estimate read time (Vietnamese avg ~200 words/min)
                const wordCount = newsItem.content.split(/\s+/).length;
                const readTime = Math.max(1, Math.ceil(wordCount / 200));
            %>
            <span class="nd-read-time">
                <i class="far fa-clock"></i> <%= readTime %> phút đọc
            </span>
        </div>
        <h1 class="nd-title"><%= newsItem.title %></h1>

        <div class="nd-meta">
            <img src="<%= newsItem.postedBy && newsItem.postedBy.avatar ? newsItem.postedBy.avatar : 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>"
                 class="nd-author-avatar" alt="Author">
            <div class="nd-author-info">
                <span class="nd-author-name"><%= newsItem.postedBy ? newsItem.postedBy.username : 'Ban Biên Tập' %></span>
                <span class="nd-publish-date"><i class="far fa-calendar-alt"></i> <%= new Date(newsItem.createdAt).toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                <span class="nd-views" style="margin-left:10px;"><i class="fas fa-eye"></i> <%= newsItem.views || 0 %> lượt xem</span>
            </div>
        </div>
    </header>

    <!-- ARTICLE BODY -->
    <div class="nd-body">
        <div class="nd-content" id="articleContent">
            <%- marked.parse(newsItem.content) %>
        </div>
        
        <!-- REACTIONS -->
        <div class="nd-reactions" id="reactionsContainer">
            <% 
                const reactions = newsItem.reactions || { like: [], heart: [], haha: [], sad: [], angry: [] };
                const types = [
                    { id: 'like', icon: '👍', label: 'Thích' },
                    { id: 'heart', icon: '❤️', label: 'Yêu' },
                    { id: 'haha', icon: '😆', label: 'Haha' },
                    { id: 'sad', icon: '😢', label: 'Buồn' },
                    { id: 'angry', icon: '😡', label: 'Phẫn nộ' }
                ];
            %>
            <div class="nd-reactions-title">Bạn cảm thấy thế nào về bài viết này?</div>
            <div class="nd-reactions-list">
                <% types.forEach(t => { 
                    const hasReacted = user && reactions[t.id] && reactions[t.id].includes(user._id.toString());
                %>
                    <button class="nd-reaction-btn <%= hasReacted ? 'active' : '' %>" data-type="<%= t.id %>" onclick="toggleReaction('<%= t.id %>')" title="<%= t.label %>">
                        <span class="emoji"><%= t.icon %></span>
                        <span class="count" id="count-<%= t.id %>"><%= reactions[t.id] ? reactions[t.id].length : 0 %></span>
                    </button>
                <% }) %>
            </div>
        </div>
    </div>

    <!-- SHARE BUTTONS -->
    <div class="nd-share">
        <div class="nd-share-label">Chia sẻ bài viết</div>
        <div class="nd-share-btns">
            <button class="nd-share-btn" id="btnCopyLink" onclick="copyLink()">
                <i class="fas fa-link"></i> Sao chép link
            </button>
            <a class="nd-share-btn fb" href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent('https://hoctapthuduc.onrender.com/news/' + newsItem._id) %>" target="_blank" rel="noopener">
                <i class="fab fa-facebook-f"></i> Facebook
            </a>
        </div>
    </div>

    <!-- ARTICLE FOOTER -->
    <footer class="nd-footer">
        <div class="nd-actions">
            <a href="/news" class="nd-btn nd-btn-back">
                <i class="fas fa-arrow-left"></i> Quay lại
            </a>

            <% if (user && newsItem.postedBy && user._id.toString() === newsItem.postedBy._id.toString()) { %>
                <div style="display: flex; gap: 8px;">
                    <a href="/news/<%= newsItem._id %>/edit" class="nd-btn nd-btn-edit">
                        <i class="fas fa-pen"></i> Sửa bài
                    </a>
                    <form action="/news/<%= newsItem._id %>/delete" method="POST" style="margin:0;" onsubmit="return confirm('Xác nhận xóa bài viết này?');">
                        <button type="submit" class="nd-btn nd-btn-delete">
                            <i class="fas fa-trash"></i> Xóa
                        </button>
                    </form>
                </div>
            <% } %>
        </div>
    </footer>
</article>

<!-- RELATED POSTS -->
<% if (typeof relatedPosts !== 'undefined' && relatedPosts && relatedPosts.length > 0) { %>
<section class="nd-related">
    <h2 class="nd-related-header">📖 Bài viết liên quan</h2>
    <div class="nd-related-grid">
        <% relatedPosts.forEach(rp => { %>
            <a href="/news/<%= rp._id %>" class="nd-related-card">
                <img src="<%= rp.image || 'https://images.unsplash.com/photo-1503676260728-1c00da094a0b?q=80&w=600&auto=format&fit=crop' %>" class="nd-related-img" alt="<%= rp.title %>">
                <div class="nd-related-body">
                    <h3 class="nd-related-title"><%= rp.title %></h3>
                    <span class="nd-related-date"><%= new Date(rp.createdAt).toLocaleDateString('vi-VN') %></span>
                </div>
            </a>
        <% }) %>
    </div>
</section>
<% } %>

<!-- SCRIPTS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
    // Reading Progress Bar
    window.addEventListener('scroll', () => {
        const article = document.getElementById('articleContent');
        if (!article) return;
        const rect = article.getBoundingClientRect();
        const scrolled = Math.min(1, Math.max(0,
            (window.scrollY - article.offsetTop + window.innerHeight * 0.3) /
            (article.scrollHeight)
        ));
        document.getElementById('progressBar').style.width = (scrolled * 100) + '%';
    });

    // Copy Link
    function copyLink() {
        navigator.clipboard.writeText(window.location.href).then(() => {
            const btn = document.getElementById('btnCopyLink');
            btn.classList.add('copied');
            btn.innerHTML = '<i class="fas fa-check"></i> Đã sao chép!';
            setTimeout(() => {
                btn.classList.remove('copied');
                btn.innerHTML = '<i class="fas fa-link"></i> Sao chép link';
            }, 2000);
        });
    }

    // GSAP Animations
    document.addEventListener("DOMContentLoaded", () => {
        if (typeof gsap === 'undefined') return;
        gsap.from(".nd-hero-img", { scale: 1.1, duration: 1.5, ease: "power2.out" });
        gsap.from(".nd-header", { y: 40, opacity: 0, duration: 1, delay: 0.3, ease: "power3.out" });
        gsap.from(".nd-body", { y: 30, opacity: 0, duration: 0.8, delay: 0.5, ease: "power3.out" });

        // Related posts
        const relatedCards = document.querySelectorAll('.nd-related-card');
        if (relatedCards.length > 0) {
            gsap.from(relatedCards, {
                y: 30, opacity: 0, duration: 0.6, stagger: 0.1, delay: 0.7, ease: 'power3.out'
            });
        }

    });

    // Toggle Reaction
    async function toggleReaction(type) {
        <% if (!user) { %>
            alert('Vui lòng đăng nhập để thả cảm xúc!');
            return;
        <% } else { %>
            try {
                const btn = document.querySelector(`.nd-reaction-btn[data-type="${type}"]`);
                btn.style.opacity = '0.7';
                
                const response = await fetch(`/news/<%= newsItem._id %>/react`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ type })
                });
                
                const data = await response.json();
                if (data.success) {
                    // Update all counts
                    Object.keys(data.counts).forEach(t => {
                        const countEl = document.getElementById(`count-${t}`);
                        if(countEl) countEl.innerText = data.counts[t];
                        
                        const tBtn = document.querySelector(`.nd-reaction-btn[data-type="${t}"]`);
                        if(tBtn) {
                            if (t === type && data.reacted) {
                                tBtn.classList.add('active');
                            } else {
                                tBtn.classList.remove('active');
                            }
                        }
                    });
                } else {
                    alert(data.error || 'Có lỗi xảy ra!');
                }
            } catch(e) {
                console.error(e);
            } finally {
                const btn = document.querySelector(`.nd-reaction-btn[data-type="${type}"]`);
                btn.style.opacity = '1';
            }
        <% } %>
    }
</script>

<%- include('partials/footer') %>