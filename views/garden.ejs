<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Pixel Farm 🚜</title>
    <link rel="icon" type="image/png" href="https://i.ibb.co/QBLckWj/Gemini-Generated-Image-wt3dr4wt3dr4wt3d-removebg-preview.png">

    <link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/phaser@3.60.0/dist/phaser.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <link rel="stylesheet" href="/css/styleGarden.css">
    <link rel="stylesheet" href="/css/styleAiTutor.css">
</head>
<body class="garden-rustic-page">
    <% 
        let backLink = '/profile';
        if (!isOwner && garden.user) { backLink = '/profile/view/' + garden.user._id; }
        const resourceIcons = (assets.UI && assets.UI.resourceIcons) || {};
    %>

    <div id="rustic-loading">
        <div class="farm-loader-box">
            <div class="farm-icon-bounce">
                <img src="<%= (assets.UI && assets.UI.harvestIcons && assets.UI.harvestIcons.carrot) || (assets.PLANTS && assets.PLANTS.carrot && assets.PLANTS.carrot.harvestIcon) %>" alt="Loading Icon">
            </div>

            <div class="farm-title">Nông Trại Vui Vẻ</div>

            <div class="wood-progress-container">
                <div class="leaf-progress-bar" id="load-bar"></div>
            </div>

            <div class="loading-text" id="load-status-text">Đang mài cuốc...</div>

            <div class="paper-tip">
                <div class="paper-title">Mách nhỏ bà con:</div>
                <div class="paper-content" id="load-tip-text">...</div>
            </div>

            <div style="margin-top:10px; font-size:1rem; opacity:0.6;">(Đang tải: <span id="load-percent">0</span>%)</div>
        </div>
    </div>

    <div id="garden-game-container"></div>

    <div class="pixel-ui garden-shell">
        <div class="garden-shell-backdrop" id="gardenShellBackdrop"></div>

        <!-- FAB Menu Button (replaces garden-rail) -->
        <button id="gardenMenuToggle" class="pixel-btn fab-menu-btn" type="button" aria-controls="gardenSidebar" aria-expanded="false" title="Mở bảng điều hướng">
            <i class="fas fa-bars"></i>
        </button>

        <aside class="garden-shell-drawer" id="gardenSidebar" aria-hidden="true">
            <div class="drawer-header">
                <div>
                    <div class="drawer-kicker">Garden Workspace</div>
                    <h2>Khu điều hướng khu vườn</h2>
                </div>
                <button id="gardenMenuClose" class="drawer-close-btn" type="button" aria-label="Đóng bảng điều hướng">
                    <i class="fas fa-xmark"></i>
                </button>
            </div>

            <div class="drawer-quick-nav">
                <a href="<%= backLink %>" class="pixel-btn drawer-nav-btn">
                    <i class="fas fa-arrow-left"></i> Thoát
                </a>
                <% if (guildContext && guildContext.guild) { %>
                    <a href="/guilds/<%= guildContext.guild.slug %>" class="pixel-btn drawer-nav-btn">
                        <i class="fas fa-people-group"></i> Tông môn
                    </a>
                <% } else if (isOwner) { %>
                    <a href="/guilds" class="pixel-btn drawer-nav-btn">
                        <i class="fas fa-people-group"></i> Tông môn
                    </a>
                <% } %>
            </div>

            <div class="drawer-tabs">
                <button class="drawer-tab active" type="button" data-shell-target="quests">Nhiệm vụ</button>
                <button class="drawer-tab" type="button" data-shell-target="inventory">Vật phẩm</button>
                <button class="drawer-tab" type="button" data-shell-target="guide">Hướng dẫn</button>
                <button class="drawer-tab" type="button" data-shell-target="social">Kết nối</button>
            </div>

            <div class="drawer-body">
                <section class="drawer-panel active" data-sidebar-panel="quests">
                    <div class="drawer-panel-header">
                        <div>
                            <div class="drawer-kicker">Hôm nay</div>
                            <h3>Nhiệm vụ khu vườn</h3>
                        </div>
                        <span class="drawer-status" id="questSummaryStatus">Theo dõi tiến độ</span>
                    </div>

                    <% if (isOwner) { %>
                        <div class="drawer-empty-state">
                            <i class="fas fa-scroll"></i>
                            <p>Nhiệm vụ hằng ngày đã được chuyển sang bảng điều khiển mới.</p>
                            <button class="pixel-btn" type="button" data-shell-target="quest-modal" style="margin-top:12px;">Mở bảng nhiệm vụ</button>
                        </div>
                    <% } else { %>
                        <div class="drawer-empty-state">
                            <i class="fas fa-seedling"></i>
                            <p>Chỉ chủ vườn mới có thể nhận nhiệm vụ hằng ngày. Bạn vẫn có thể tham quan và xem nhịp sống khu vườn.</p>
                        </div>
                    <% } %>
                </section>

                <!-- Inventory has been moved to a modal (inventoryOverlay) -->

                <section class="drawer-panel" data-sidebar-panel="guide">
                    <div class="drawer-panel-header">
                        <div>
                            <div class="drawer-kicker">Điều phối</div>
                            <h3>Hướng dẫn nhanh</h3>
                        </div>
                        <span class="drawer-status">Mẹo canh tác</span>
                    </div>
                    <div class="guide-list" id="gardenGuideTips"></div>
                </section>

                <section class="drawer-panel" data-sidebar-panel="social">
                    <div class="drawer-panel-header">
                        <div>
                            <div class="drawer-kicker">Kết nối</div>
                            <h3>Khách & tông môn</h3>
                        </div>
                    </div>

                    <div class="social-links">
                        <% if (!isOwner) { %>
                            <div class="social-card">
                                <div class="social-card-title">Đang ghé thăm</div>
                                <div class="social-card-value"><%= garden.user ? garden.user.username : 'Hàng xóm' %></div>
                            </div>
                        <% } %>

                        <% if (guildContext && guildContext.guild) { %>
                            <a href="/guilds/<%= guildContext.guild.slug %>" class="social-card social-link-card">
                                <div class="social-card-title">Tông môn hiện tại</div>
                                <div class="social-card-value"><%= guildContext.guild.name %></div>
                            </a>
                        <% } else if (isOwner) { %>
                            <a href="/guilds" class="social-card social-link-card">
                                <div class="social-card-title">Cộng đồng</div>
                                <div class="social-card-value">Khám phá Tông Môn</div>
                            </a>
                        <% } %>

                        <a href="<%= backLink %>" class="social-card social-link-card">
                            <div class="social-card-title">Lối ra nhanh</div>
                            <div class="social-card-value">Quay về hồ sơ</div>
                        </a>
                    </div>
                </section>
            </div>
        </aside>

        <div class="hud-top garden-topbar">
            <!-- Đảo nổi bên trái -->
            <div class="topbar-island island-left">
                <div class="garden-scene-pill">
                    <span class="garden-scene-main"><%= isOwner ? 'My Garden' : (garden.user ? garden.user.username + "'s Garden" : 'Neighbor Garden') %></span>
                    <span class="garden-scene-sub">
                        <%= isOwner ? 'Khu vườn tri thức' : 'Đang ghé thăm' %> · <span id="gardenQuickRealm"><%= garden.levelName %></span>
                    </span>
                </div>

                <div class="pixel-panel player-stats-compact">
                    <div class="stat-level-box">
                        <span class="lbl">LV</span>
                        <span class="val" id="ui-level"><%= garden.userLevel %></span>
                    </div>

                    <div class="stat-info-col">
                        <div class="realm-badge" id="ui-realm"><%= garden.levelName %></div>
                        <div class="xp-progress-wrapper">
                            <% 
                                const curXP = garden.currentXP || 0;
                                const maxXP = garden.nextLevelXP || 100;
                                const xpPct = (maxXP > 0) ? Math.min(100, (curXP / maxXP) * 100) : 0;
                            %>
                            <div class="xp-fill" id="ui-xp-bar" style="width: <%= xpPct %>%;"></div>
                            <span class="xp-text" id="ui-xp-text"><%= curXP %>/<%= maxXP %></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Đảo nổi bên phải -->
            <div class="topbar-island island-right">
                <div class="pixel-panel resources garden-resource-bar">
                    <div class="res-item" title="Nước">
                        <img src="<%= resourceIcons.water %>" class="pixel-icon" alt="Nước">
                        <span id="ui-water"><%= garden.water %></span>
                    </div>
                    <div class="res-item" title="Phân bón">
                        <img src="<%= resourceIcons.fertilizer %>" class="pixel-icon" alt="Phân bón">
                        <span id="ui-fertilizer"><%= garden.fertilizer || 0 %></span>
                    </div>
                    <div class="res-item" title="Vàng">
                        <img src="<%= resourceIcons.gold %>" class="pixel-icon" alt="Vàng">
                        <span id="ui-gold"><%= garden.gold %></span>
                    </div>
                </div>

                <div class="garden-status-dropdown-container">
                    <button id="gardenStatusDropdownBtn" class="pixel-btn garden-compact-btn garden-dropdown-btn" type="button" title="Thông tin khu vườn" aria-haspopup="true" aria-expanded="false">
                        <i class="fas fa-circle-info"></i>
                    </button>
                    <div id="gardenStatusDropdownMenu" class="garden-dropdown-menu pixel-panel" aria-hidden="true" role="menu">
                        <div class="dropdown-section">
                            <div class="dropdown-item-header">Khu vườn</div>
                            <div class="dropdown-item-main">
                                <span id="dropdownGardenName" class="dropdown-garden-name"><%= isOwner ? 'My Garden' : (garden.user ? garden.user.username + "'s Garden" : 'Neighbor Garden') %></span>
                            </div>
                        </div>
                        <div class="dropdown-divider"></div>
                        <div class="dropdown-section">
                            <div class="dropdown-item-header">Trạng thái</div>
                            <% if (!isOwner) { %>
                                <div class="dropdown-item">
                                    <span class="dropdown-label">👤 Chủ vườn:</span>
                                    <span id="dropdownOwnerName" class="dropdown-value"><%= garden.user ? garden.user.username : 'Hàng xóm' %></span>
                                </div>
                            <% } else { %>
                                <div class="dropdown-item">
                                    <span class="dropdown-label">👥 Khách:</span>
                                    <span id="dropdownVisitorCount" class="dropdown-value">0</span>
                                </div>
                            <% } %>
                        </div>
                        <% if (guildContext && guildContext.guild) { %>
                            <div class="dropdown-divider"></div>
                            <div class="dropdown-section">
                                <div class="dropdown-item-header">Tông môn</div>
                                <div class="dropdown-item">
                                    <span id="dropdownGuildName" class="dropdown-value"><%= guildContext.guild.name %></span>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>

                <div class="garden-quick-actions" aria-label="Lối tắt">
                    <button class="garden-quick-btn quest-fab-btn" type="button" id="openQuestModalBtn" data-shell-target="quest-modal" title="Nhiệm vụ hằng ngày">
                        <i class="fas fa-scroll"></i>
                        <span class="quest-fab-badge" id="questFabBadge" style="display:none;">0</span>
                    </button>
                    <button class="garden-quick-btn" type="button" data-shell-target="inventory" title="Mở túi vật phẩm">
                        <i class="fas fa-box-open"></i>
                    </button>
                </div>
            </div>
        </div>

        <div id="plantingModeUI" class="planting-ui" style="display: none;">
            <div class="planting-label">🌱 Đang trồng...</div>
            <div class="planting-item-name" id="plantingItemName">Hạt giống</div>
            <button id="cancelPlantingBtn" class="pixel-btn btn-cancel-plant">
                Hủy (X)
            </button>
        </div>

        <div id="mobileMoveBtn" class="mobile-action-btn" style="display: none;">
            <i class="fas fa-arrows-alt"></i>
        </div>

        <div id="ui-coords-bar" class="coords-badge">
            📍 <span id="ui-coords-x">0</span>, <span id="ui-coords-y">0</span>
        </div>

        <div class="pixel-panel plant-info-panel" id="plantStats">
            <div class="info-header">
                <div class="info-thumb">
                    <img id="statImg" src="" class="pixel-img">
                </div>
                <div class="info-text">
                    <div class="info-panel-kicker">Contextual inspector</div>
                    <h3 id="statName">...</h3>
                    <div id="statStageBadge" class="pixel-badge">...</div>
                </div>
                <button id="closePlantStatsBtn" class="pixel-btn-close">X</button>
            </div>

            <div class="info-body">
                <div class="stat-row">
                    <label><i class="fas fa-tint text-blue"></i> Độ ẩm</label>
                    <div class="pixel-progress-track">
                        <div id="statWitherBar" class="pixel-progress-fill fill-water"></div>
                    </div>
                    <span id="statWitherVal" class="stat-val">--%</span>
                </div>

                <div class="stat-row">
                    <label><i class="fas fa-seedling text-green"></i> Sinh trưởng</label>
                    <div class="pixel-progress-track">
                        <div id="statGrowthBar" class="pixel-progress-fill fill-growth"></div>
                    </div>
                    <span id="statTimeProgress" class="stat-val">--%</span>
                </div>

                <div class="info-grid">
                    <div class="info-cell">
                        <small>⏳ Lớn lên</small>
                        <strong id="statTotalTime">--</strong>
                    </div>
                    <div class="info-cell">
                        <small>💰 Giá trị</small>
                        <strong id="statPrice" class="text-gold">--</strong>
                    </div>
                    <div class="info-cell">
                        <small>💧 Độ ẩm</small>
                        <strong id="statWateringTime" style="color: #29b6f6;">--</strong>
                    </div>
                    <div class="info-cell">
                        <small>⭐ Giai đoạn</small>
                        <strong id="statStageTime" style="color: #66bb6a;">--</strong>
                    </div>
                </div>

                <div class="info-footer">
                    <small id="statSoilStatus">---</small>
                </div>
                <% if (isOwner) { %>
                    <div class="plant-action-row" id="plantActionRow">
                        <button id="statFertilizeBtn" class="plant-action-btn" type="button">
                            BÓN PHÂN (+1 CẤP)
                        </button>
                        <div class="plant-action-meta">
                            Còn <span id="statFertilizerCount"><%= garden.fertilizer || 0 %></span> phân bón
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="garden-guide-widget" id="gardenGuideWidget">
            <button id="gardenGuideToggle" class="garden-guide-avatar" type="button" aria-expanded="false">
                <img src="/api/pro-images/1767353474437-ddk8r4.png" alt="NPC hướng dẫn">
            </button>
            <div class="garden-guide-panel">
                <div class="guide-panel-kicker">NPC điều phối</div>
                <p id="gardenGuideLine">Mở Nhiệm vụ hoặc Vật phẩm từ thanh bên để theo dõi tiến độ canh tác.</p>
                <button class="guide-panel-action" type="button" data-shell-target="guide">Xem hướng dẫn</button>
            </div>
        </div>

        <div class="hud-bottom" id="mainToolbar">
            <button id="toggleToolbeltBtn" class="toolbelt-toggle" type="button" aria-expanded="true">
                <i class="fas fa-chevron-down"></i>
            </button>

            <div class="pixel-panel toolbar">
                <div class="tool-slot" data-tool="move" title="Di chuyển">
                    <img src="<%= assets.FARMING.tools.move.icon %>">
                    <span class="key-hint">1</span>
                </div>

                <div class="tool-slot active" data-tool="cursor" title="Xem info">
                    <img src="<%= assets.FARMING.tools.cursor.icon %>">
                    <span class="key-hint">2</span>
                </div>

                <% if (isOwner) { %>
                    <div class="tool-slot" data-tool="hoe" title="Cuốc đất">
                        <img src="<%= assets.FARMING.tools.hoe.icon %>">
                        <span class="key-hint">3</span>
                    </div>

                    <div class="tool-slot" data-tool="water" title="Tưới nước">
                        <img src="<%= assets.FARMING.tools.water.icon %>">
                        <span class="key-hint">4</span>
                    </div>

                    <div class="tool-slot shop-slot" data-tool="shop" data-shop-tab="plant" title="Cửa hàng">
                        <img src="/api/pro-images/1767285084901-romnys.png">
                        <span class="key-hint">F</span>
                    </div>

                    <div class="tool-slot" data-tool="basket" title="Thu hoạch">
                        <img src="<%= assets.FARMING.tools.basket.icon %>">
                        <span class="key-hint">5</span>
                    </div>

                    <div class="tool-slot" data-tool="shovel" title="Xóa bỏ">
                        <img src="<%= assets.FARMING.tools.shovel.icon %>">
                        <span class="key-hint">6</span>
                    </div>
                <% } %>
            </div>
        </div>

        <nav class="garden-bottom-nav" aria-label="Điều hướng dưới cùng">
            <a href="/" class="bottom-nav-link">
                <i class="fas fa-house"></i>
                <span>Trang chủ</span>
            </a>
            <a href="/subjects" class="bottom-nav-link">
                <i class="fas fa-book"></i>
                <span>Kho bí kíp</span>
            </a>
            <a href="/dashboard" class="bottom-nav-link">
                <i class="fas fa-graduation-cap"></i>
                <span>Học tập</span>
            </a>
            <a href="/my-garden" class="bottom-nav-link active">
                <i class="fas fa-gamepad"></i>
                <span>Game</span>
            </a>
            <a href="/profile" class="bottom-nav-link">
                <i class="fas fa-user"></i>
                <span>Cá nhân</span>
            </a>
        </nav>
    </div>

    <div id="shopOverlay" class="pixel-modal-overlay pixel-modal-overlay--rustic" style="display:none;" aria-hidden="true"
        onwheel="event.stopPropagation()" onmousedown="event.stopPropagation()" ontouchstart="event.stopPropagation()">

        <div class="pixel-window shop-window shop-window--rustic" role="dialog" aria-modal="true" aria-labelledby="gardenShopTitle">
            <div class="window-header">
                <div class="win-title" id="gardenShopTitle">🛒 Tạp Hóa Thôn Quê</div>
                <button id="closeShopBtn" class="pixel-btn-close red">X</button>
            </div>

            <div class="window-body">
                <div class="shop-list-col">
                    <div class="shop-tabs">
                        <button class="pixel-tab active" data-shop-tab="plant" id="tab-plant">Hạt Giống</button>
                        <button class="pixel-tab" data-shop-tab="decor" id="tab-decor">Trang Trí</button>
                        <button class="pixel-tab" data-shop-tab="plot" id="tab-plot">Đất Đai</button>
                    </div>
                    <div class="shop-grid-container">
                        <div class="shop-grid" id="shopGrid"></div>
                    </div>
                </div>

                <div class="shop-detail-col">
                    <div id="shop-npc-state" class="npc-state">
                        <div class="npc-dialog">
                            "Chào mừng Đạo Hữu! <br> Hãy chọn hạt giống để xem chi tiết nhé."
                        </div>
                        <img src="/api/pro-images/1767353474437-ddk8r4.png" class="npc-img-lg">
                    </div>

                    <div id="shop-item-state" class="item-detail-state">
                        <div class="detail-header">
                            <img id="d-img" src="" class="detail-img">
                            <h3 id="d-name" class="detail-name">Tên Vật Phẩm</h3>
                            <span id="d-type" class="detail-type">LOẠI</span>
                        </div>

                        <div class="detail-body-wrapper">
                            <div class="detail-stats">
                                <div class="d-row">
                                    <span class="d-label">Yêu cầu:</span>
                                    <span class="d-val" id="d-level">Cấp 1</span>
                                </div>
                                <div class="d-row">
                                    <span class="d-label">Thời gian:</span>
                                    <span class="d-val time" id="d-time">--</span>
                                </div>
                                <div class="d-row">
                                    <span class="d-label">Phần thưởng:</span>
                                    <span class="d-val xp" id="d-xp">-- XP</span>
                                </div>
                                <div class="d-row">
                                    <span class="d-label">Giá:</span>
                                    <span class="d-val" id="d-price" style="color: #e65100; font-weight:900;">-- Xu</span>
                                </div>
                            </div>

                            <div class="detail-actions">
                                <button id="btn-confirm-buy" class="btn-buy-action">
                                    MUA & TRỒNG
                                </button>
                                <div class="user-balance">
                                    Ví của bạn: <b style="color:#e65100;"><span id="shop-user-gold">0</span> Xu</b>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="inventoryOverlay" class="pixel-modal-overlay pixel-modal-overlay--rustic" style="display:none;" aria-hidden="true"
        onwheel="event.stopPropagation()" onmousedown="event.stopPropagation()" ontouchstart="event.stopPropagation()">
        
        <div class="pixel-window shop-window shop-window--rustic inventory-modal-premium" role="dialog" aria-modal="true" aria-labelledby="gardenInventoryTitle">
            <div class="window-header">
                <div class="win-title" id="gardenInventoryTitle"><i class="fas fa-backpack"></i> Túi Đồ Của Tôi</div>
                <button id="closeInventoryBtn" class="pixel-btn-close red">X</button>
            </div>

            <div class="window-body inventory-premium-body">
                <div class="inventory-toolbar-premium">
                    <div class="inventory-search-premium">
                        <i class="fas fa-search"></i>
                        <input type="text" id="inventorySearchInput" placeholder="Tìm kiếm nông sản...">
                    </div>
                    <div class="inventory-tabs-premium">
                        <button class="pixel-tab active" data-inv-tab="all">Tất cả</button>
                        <button class="pixel-tab" data-inv-tab="seed">Hạt giống</button>
                        <button class="pixel-tab" data-inv-tab="harvest">Nông sản</button>
                        <button class="pixel-tab" data-inv-tab="decor">Trang trí</button>
                    </div>
                    <div class="inventory-sort-premium">
                        <select id="inventorySortSelect" class="pixel-select">
                            <option value="qty-desc">SL giảm dần</option>
                            <option value="qty-asc">SL tăng dần</option>
                            <option value="tier-desc">Độ hiếm giảm</option>
                        </select>
                    </div>
                </div>

                <div class="inventory-premium-content">
                    <div class="inventory-grid-wrapper">
                        <div class="inventory-grid-header">
                            <span class="grid-title"><i class="fas fa-th"></i> Lưới Lưu Trữ</span>
                            <span id="gardenInventorySummary" class="grid-summary">Đang đồng bộ...</span>
                        </div>
                        <div class="inventory-premium-grid" id="gardenInventoryList" role="listbox" aria-label="Túi vật phẩm">
                            <!-- Items injected by JS -->
                        </div>
                    </div>

                    <div class="inventory-detail-wrapper">
                        <aside class="inventory-detail-panel-premium" id="gardenInventoryDetail" aria-live="polite">
                            <!-- Injected by JS -->
                        </aside>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quest Modal Overlay -->
    <div id="questModalOverlay" class="pixel-modal-overlay pixel-modal-overlay--rustic quest-modal-overlay" style="display:none;" aria-hidden="true"
        onwheel="event.stopPropagation()" onmousedown="event.stopPropagation()" ontouchstart="event.stopPropagation()">
        
        <div class="pixel-window shop-window shop-window--rustic quest-modal-window" role="dialog" aria-modal="true" aria-labelledby="gardenQuestTitle">
            <div class="window-header quest-modal-header">
                <div class="win-title" id="gardenQuestTitle"><i class="fas fa-scroll"></i> Nhiệm Vụ Hằng Ngày</div>
                <button id="closeQuestModalBtn" class="pixel-btn-close red">X</button>
            </div>

            <div class="window-body quest-modal-body">
                <div class="quest-summary-bar">
                    <div class="quest-summary-text">
                        <span id="questModalSummaryStatus">Tiến độ: 0/5 nhiệm vụ hoàn thành</span>
                    </div>
                    <div class="quest-summary-timer">
                        <i class="fas fa-clock"></i> Làm mới sau: <b>24h</b>
                    </div>
                </div>

                <div class="quest-grid" id="questModalList">
                    <!-- Quests injected by JS -->
                </div>
            </div>
        </div>
    </div>

    <script type="application/json" id="gardenAssets"><%- JSON.stringify(assets) %></script>
    <script type="application/json" id="gardenData"><%- JSON.stringify(garden) %></script>
    <script>
        window.isOwner = <%= typeof isOwner !== "undefined" ? isOwner : true %>;
        window.gardenAssets = JSON.parse(document.getElementById('gardenAssets').textContent);
        window.gardenData = JSON.parse(document.getElementById('gardenData').textContent);
    </script>

    <script src="/js/gardenShared.js"></script>
    <script>
        if (window.GardenShared && window.GardenShared.applyGardenDefaults) {
            window.GardenShared.applyGardenDefaults(window.gardenData);
        }
    </script>
    <script src="/js/gardenSceneSetup.js"></script>
    <script src="/js/gardenSceneRendering.js"></script>
    <script src="/js/gardenSceneInteractions.js"></script>
    <script src="/js/gardenPhaser.js"></script>
    <script src="/js/gardenUI.js"></script>
    <script>
        if (window.initGardenPage) {
            window.initGardenPage();
        }
    </script>
    <link rel="stylesheet" href="/css/styleTutorial.css">
    <script src="/js/tutorial.js"></script>
    <%- include('partials/aiTutor', {
        user,
        aiTutorVariant: 'garden',
        aiTutorPage: 'garden',
        aiTutorTitle: 'Nông Trại AI',
        aiTutorSubtitle: 'Gợi ý nước đi tiếp theo trong vườn'
    }) %>
</body>
</html>
