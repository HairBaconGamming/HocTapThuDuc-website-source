<%- include('partials/header') %>
<link rel="stylesheet" href="/css/styleQA.css">

<%
// Xử lý dữ liệu an toàn
const safeSubjects = Array.isArray(subjects) ? subjects : [];
const safeGrades = Array.isArray(grades) ? grades : [];
%>

<div class="qa-main-container">
    
    <!-- THANH ĐIỀU HƯỚNG TRỞ VỀ -->
    <div class="qa-page-nav mb-4">
        <a href="/qa" class="qa-btn-back">
            <i class="fas fa-arrow-left"></i> Trở về Bảng Cầu Cứu
        </a>
    </div>

    <!-- LAYOUT: FORM BÊN TRÁI, TIPS BÊN PHẢI -->
    <div class="qa-editor-layout">
        
        <!-- MAIN FORM COLUMN -->
        <main class="qa-editor-main qa-glass-panel">
            <form id="qaQuestionForm" class="qa-super-form">
                
                <!-- 1. Tiêu đề kiểu Notion (Massive Input) -->
                <div class="qa-form-group mb-4">
                    <input type="text" name="title" class="qa-input-massive" maxlength="180" placeholder="Tiêu đề câu hỏi của bạn là gì?" required autocomplete="off">
                </div>

                <!-- 2. Phân loại Môn & Khối (Grid 2 cột) -->
                <div class="qa-input-grid mb-4">
                    <div class="qa-input-group">
                        <label class="qa-label">Môn học <span class="text-danger">*</span></label>
                        <div class="qa-select-wrapper">
                            <select name="subject" class="qa-select-pro" required>
                                <option value="" disabled selected>-- Chọn môn --</option>
                                <% safeSubjects.forEach((subject) => { %>
                                    <option value="<%= subject %>"><%= subject %></option>
                                <% }) %>
                            </select>
                            <i class="fas fa-chevron-down qa-select-icon"></i>
                        </div>
                    </div>

                    <div class="qa-input-group">
                        <label class="qa-label">Khối lớp <span class="text-danger">*</span></label>
                        <div class="qa-select-wrapper">
                            <select name="grade" class="qa-select-pro" required>
                                <option value="" disabled selected>-- Chọn khối --</option>
                                <% safeGrades.forEach((grade) => { %>
                                    <option value="<%= grade %>"><%= grade === 'Chung' ? 'Chung mọi khối' : ('Lớp ' + grade) %></option>
                                <% }) %>
                            </select>
                            <i class="fas fa-chevron-down qa-select-icon"></i>
                        </div>
                    </div>
                </div>

                <!-- 3. Khung soạn thảo Tiptap -->
                <div class="qa-input-group mb-4">
                    <label class="qa-label">Nội dung chi tiết <span class="text-danger">*</span></label>
                    
                    <div class="qa-tiptap-wrapper">
                        <!-- Toolbar -->
                        <div class="qa-tiptap-toolbar" id="tiptapToolbar">
                            <button type="button" class="qa-tt-btn" data-action="bold" title="In đậm (Ctrl+B)"><i class="fas fa-bold"></i></button>
                            <button type="button" class="qa-tt-btn" data-action="italic" title="In nghiêng (Ctrl+I)"><i class="fas fa-italic"></i></button>
                            <button type="button" class="qa-tt-btn" data-action="strike" title="Gạch ngang"><i class="fas fa-strikethrough"></i></button>
                            <button type="button" class="qa-tt-btn" data-action="code" title="Code Inline"><i class="fas fa-terminal"></i></button>
                            <div class="qa-tt-divider"></div>
                            <button type="button" class="qa-tt-btn" data-action="h2" title="Tiêu đề 2">H2</button>
                            <button type="button" class="qa-tt-btn" data-action="h3" title="Tiêu đề 3">H3</button>
                            <div class="qa-tt-divider"></div>
                            <button type="button" class="qa-tt-btn" data-action="bulletList" title="Danh sách chấm"><i class="fas fa-list-ul"></i></button>
                            <button type="button" class="qa-tt-btn" data-action="orderedList" title="Danh sách số"><i class="fas fa-list-ol"></i></button>
                            <button type="button" class="qa-tt-btn" data-action="blockquote" title="Trích dẫn"><i class="fas fa-quote-right"></i></button>
                            <button type="button" class="qa-tt-btn" data-action="codeBlock" title="Khối Code"><i class="fas fa-code"></i></button>
                            <div class="qa-tt-divider"></div>
                            <button type="button" class="qa-tt-btn text-primary" data-action="image" title="Chèn ảnh từ URL"><i class="fas fa-image"></i></button>
                        </div>
                        
                        <!-- Editor Body -->
                        <div class="qa-tiptap-body" id="tiptapEditor"></div>
                    </div>
                    
                    <!-- Hidden input to store HTML for form submission -->
                    <input type="hidden" name="content" id="qaHiddenContent">
                </div>

                <!-- 4. Footer Form (Bounty & Submit) -->
                <div class="qa-form-bottom-bar">
                    <div class="qa-bounty-input-wrap">
                        <div class="qa-bounty-icon"><i class="fas fa-coins text-warning"></i></div>
                        <input type="number" name="bountyAmount" class="qa-input-bounty" min="0" max="50000" step="10" placeholder="0" value="0">
                        <span class="qa-bounty-suffix">Vàng (Tùy chọn)</span>
                    </div>

                    <button type="submit" class="qa-btn-prime qa-btn-lg" id="submitBtn">
                        <i class="fas fa-paper-plane"></i> Treo Bảng Ngay
                    </button>
                </div>
            </form>
        </main>

        <!-- RIGHT SIDEBAR (TIPS CHECKLIST) -->
        <aside class="qa-editor-sidebar hidden-md-down">
            <div class="qa-sticky-card qa-glass-panel">
                <div class="qa-widget-header">
                    <h3 class="qa-widget-title"><i class="fas fa-lightbulb text-warning"></i> Bí kíp hỏi đáp</h3>
                </div>
                <ul class="qa-tips-list">
                    <li>
                        <i class="fas fa-check-circle text-success"></i>
                        <div>
                            <strong>Tiêu đề rõ ràng</strong>
                            <span>Tránh viết "Giúp em với", hãy viết "Làm sao để giải pt bậc 2 bằng Vi-ét?"</span>
                        </div>
                    </li>
                    <li>
                        <i class="fas fa-check-circle text-success"></i>
                        <div>
                            <strong>Gắn đúng Môn & Khối</strong>
                            <span>Giúp các cao thủ đúng chuyên môn tìm thấy bài của bạn nhanh hơn.</span>
                        </div>
                    </li>
                    <li>
                        <i class="fas fa-check-circle text-success"></i>
                        <div>
                            <strong>Toán học bằng KaTeX</strong>
                            <span>Bao bọc công thức bởi dấu `$`. Ví dụ: `$x^2 + y^2 = z^2$` sẽ hiển thị rất đẹp.</span>
                        </div>
                    </li>
                    <li>
                        <i class="fas fa-check-circle text-success"></i>
                        <div>
                            <strong>Treo thưởng xứng đáng</strong>
                            <span>Dùng số dư Vàng của bạn để lôi kéo các Thần Bài nhảy vào giải cứu tốc độ cao.</span>
                        </div>
                    </li>
                </ul>
            </div>
        </aside>

    </div>
</div>

<script src="/js/qa.js"></script>

<!-- TIPTAP EDITOR SCRIPT -->
<script type="module">
    import { Editor } from 'https://esm.sh/@tiptap/core@2.2.4';
    import StarterKit from 'https://esm.sh/@tiptap/starter-kit@2.2.4';
    import Image from 'https://esm.sh/@tiptap/extension-image@2.2.4';
    import Placeholder from 'https://esm.sh/@tiptap/extension-placeholder@2.2.4';

    document.addEventListener('DOMContentLoaded', () => {
        const hiddenInput = document.getElementById('qaHiddenContent');
        const form = document.getElementById('qaQuestionForm');
        
        // Khởi tạo Editor
        const editor = new Editor({
            element: document.getElementById('tiptapEditor'),
            extensions: [
                StarterKit,
                Image.configure({
                    inline: false,
                    allowBase64: true,
                }),
                Placeholder.configure({
                    placeholder: 'Trình bày đề bài hoặc chỗ bạn đang mắc kẹt. Bạn có thể kéo thả ảnh vào đây, hoặc gõ LaTeX để viết Toán...',
                }),
            ],
            content: '',
            onUpdate: ({ editor }) => {
                // Sync to hidden input
                hiddenInput.value = editor.isEmpty ? '' : editor.getHTML();
            },
            onSelectionUpdate: ({ editor }) => {
                updateToolbarActiveStates(editor);
            }
        });

        // Xử lý click thanh công cụ
        document.querySelectorAll('#tiptapToolbar .qa-tt-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                const action = btn.dataset.action;
                
                if (action === 'bold') editor.chain().focus().toggleBold().run();
                if (action === 'italic') editor.chain().focus().toggleItalic().run();
                if (action === 'strike') editor.chain().focus().toggleStrike().run();
                if (action === 'code') editor.chain().focus().toggleCode().run();
                if (action === 'h2') editor.chain().focus().toggleHeading({ level: 2 }).run();
                if (action === 'h3') editor.chain().focus().toggleHeading({ level: 3 }).run();
                if (action === 'bulletList') editor.chain().focus().toggleBulletList().run();
                if (action === 'orderedList') editor.chain().focus().toggleOrderedList().run();
                if (action === 'blockquote') editor.chain().focus().toggleBlockquote().run();
                if (action === 'codeBlock') editor.chain().focus().toggleCodeBlock().run();
                if (action === 'image') {
                    const url = window.prompt('Nhập URL ảnh (VD: https://imgur.com/...):');
                    if (url) {
                        editor.chain().focus().setImage({ src: url }).run();
                    }
                }
            });
        });

        // Cập nhật trạng thái (đổi màu nút) khi bôi đen chữ
        function updateToolbarActiveStates(editor) {
            const map = {
                bold: 'bold', italic: 'italic', strike: 'strike', code: 'code',
                h2: { heading: { level: 2 } }, h3: { heading: { level: 3 } },
                bulletList: 'bulletList', orderedList: 'orderedList',
                blockquote: 'blockquote', codeBlock: 'codeBlock'
            };
            
            document.querySelectorAll('#tiptapToolbar .qa-tt-btn').forEach(btn => {
                const action = btn.dataset.action;
                if(action === 'image') return;
                
                const isActive = typeof map[action] === 'string' 
                    ? editor.isActive(map[action]) 
                    : editor.isActive(Object.keys(map[action])[0], Object.values(map[action])[0]);
                    
                btn.classList.toggle('active', isActive);
            });
        }

        // Bắt lỗi rỗng khi submit
        form.addEventListener('submit', (e) => {
            if (!hiddenInput.value.trim() || hiddenInput.value === '<p></p>') {
                e.preventDefault();
                e.stopImmediatePropagation();
                
                // Hiển thị toast (Sử dụng hàm showToast từ qa.js nếu có)
                if(typeof showToast === 'function') {
                    showToast('Vui lòng nhập nội dung chi tiết cho câu hỏi!', true);
                } else {
                    alert('Vui lòng nhập nội dung chi tiết cho câu hỏi!');
                }
                editor.commands.focus();
            }
        });
    });
</script>

<%- include('partials/footer') %>