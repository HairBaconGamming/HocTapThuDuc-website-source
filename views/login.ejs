<%- include('partials/header') %>
<link rel="stylesheet" href="/css/styleLogin.css">

<section class="login-page-section">
    <div class="login-form-container">
        <div style="font-size: 3rem; margin-bottom: 10px;">👋</div>
        <h2 class="form-title">Vào lớp thôi!</h2>
        <p class="form-subtitle">Nhập tên và mật khẩu siêu bí mật của bạn.</p>

        <% if (locals.message && message.message) { %>
            <div style="background: #ffe0e6; color: #d81b60; padding: 10px; border-radius: 10px; margin-bottom: 20px; font-size: 0.9rem;">
                <%= message.message %>
            </div>
        <% } %>

        <form action="/login" method="POST" id="loginForm">
            <div class="input-field-group">
                <label class="form-label-v2">Tên đăng nhập</label>
                <input type="text" name="username" class="form-input-v2" placeholder="Ví dụ: nam123" required>
            </div>

            <div class="input-field-group">
                <label class="form-label-v2">Mật khẩu</label>
                <input type="password" name="password" class="form-input-v2" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn-submit-v2">🚀 Đăng nhập</button>
        </form>

        <% if (googleAuthEnabled) { %>
            <div class="auth-divider"><span>hoặc</span></div>
            <a href="/auth/google" class="btn-social-google">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.1.8 3.8 1.5l2.6-2.5C16.8 3.5 14.6 2.5 12 2.5 6.8 2.5 2.5 6.8 2.5 12S6.8 21.5 12 21.5c6.9 0 9.1-4.8 9.1-7.3 0-.5-.1-.9-.1-1.3H12z"/>
                </svg>
                <span>Tiếp tục với Google</span>
            </a>
        <% } %>

        <div class="switch-auth-link">
            Chưa có tài khoản? <a href="/register">Đăng ký nhập học ngay</a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
