<%- include('partials/header') %>
<link rel="stylesheet" href="/css/styleAuth.css">

<div class="auth-page-wrapper">
    <div class="auth-hero-panel">
        <div class="auth-hero-bg">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <circle cx="50" cy="50" r="50" fill="currentColor"/>
            </svg>
        </div>
        <div class="auth-hero-logo">
            <img src="/assets/images/logo.png" alt="HTTD Logo" onerror="this.src='https://placehold.co/40'">
            Học Tập Thủ Đức
        </div>
        <div class="auth-hero-content">
            <h1 class="auth-hero-title">Chào mừng trở lại!</h1>
            <p class="auth-hero-desc">Tiếp tục hành trình học tập của bạn, kết nối với bạn bè và chinh phục những đỉnh cao tri thức mới.</p>
        </div>
    </div>

    <div class="auth-form-panel">
        <div class="auth-form-container">
            <div class="auth-form-header">
                <div style="font-size: 3rem; margin-bottom: 10px;">👋</div>
                <h2>Vào lớp thôi!</h2>
                <p>Nhập tên và mật khẩu siêu bí mật của bạn.</p>
            </div>

            <% if (locals.message && message.message) { %>
                <div class="auth-alert <%= message.type === 'error' ? 'error' : 'success' %>">
                    <%= message.message %>
                </div>
            <% } %>

            <form action="/login" method="POST" id="loginForm">
                <% if (authRedirect) { %>
                    <input type="hidden" name="redirect" value="<%= authRedirect %>">
                <% } %>
                <div class="auth-input-group">
                    <label class="auth-label">Tên đăng nhập</label>
                    <input type="text" name="username" class="auth-input" placeholder="Ví dụ: nam123" required>
                </div>

                <div class="auth-input-group">
                    <label class="auth-label">Mật khẩu</label>
                    <input type="password" name="password" class="auth-input" placeholder="••••••••" required>
                </div>

                <button type="submit" class="auth-btn-primary">🚀 Đăng nhập</button>
            </form>

            <% if (googleAuthEnabled) { %>
                <div class="auth-divider"><span>hoặc</span></div>
                <a href="/auth/google<%= authRedirect ? ('?redirect=' + encodeURIComponent(authRedirect)) : '' %>" class="auth-btn-google">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.1.8 3.8 1.5l2.6-2.5C16.8 3.5 14.6 2.5 12 2.5 6.8 2.5 2.5 6.8 2.5 12S6.8 21.5 12 21.5c6.9 0 9.1-4.8 9.1-7.3 0-.5-.1-.9-.1-1.3H12z"/>
                    </svg>
                    <span>Tiếp tục với Google</span>
                </a>
            <% } %>

            <div class="auth-switch">
                Chưa có tài khoản? <a href="/register<%= authRedirect ? ('?redirect=' + encodeURIComponent(authRedirect)) : '' %>">Đăng ký nhập học ngay</a>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
