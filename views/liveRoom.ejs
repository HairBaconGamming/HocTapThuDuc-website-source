<%- include('partials/header', { disableHeaderOffset: true }) %>
<link rel="stylesheet" href="/css/styleLiveRoom.css">

<%
  const session = liveRoomData?.session || {};
  const role = session.permissions?.role || 'viewer';
  const canModerate = !!session.permissions?.canModerate;
%>

<script>
  window.LIVE_ROOM_BOOTSTRAP = <%- JSON.stringify({
    ...(liveRoomData || {}),
    currentUser: user
      ? {
          id: String(user._id || ''),
          username: user.displayName || user.username || 'Bạn học',
          avatar: user.avatar || '',
          role,
        }
      : null,
  }) %>;
</script>

<style>
  header, nav, footer, .footer, .site-header, .ai-tutor-shell, .ai-tutor-fab { display: none !important; }
  body { margin: 0 !important; overflow: hidden !important; background: #09090b; }
</style>

<section class="live-room-shell">
  <!-- LEFT: Media Area -->
  <div class="live-room-media-area">
    <div class="live-room-topbar">
      <div class="live-room-topbar__left">
        <a href="/live" class="live-room-btn-back" title="Quay về Hub">
          <i class="fas fa-chevron-left"></i>
        </a>
        <div class="live-room-info">
          <h1 id="liveSessionTitle"><%= session.title %></h1>
          <div class="live-room-badges">
            <span class="live-room-pill live-room-pill--<%= session.statusTone || 'scheduled' %>" id="liveStatusBadge">
              <%= session.statusLabel || 'Sắp diễn ra' %>
            </span>
            <span class="live-room-pill"><i class="fas fa-tag"></i> <%= session.category || 'Học tập' %></span>
            <span class="live-room-pill"><i class="far fa-clock"></i> <%= session.scheduledLabel || '' %></span>
            <span class="live-room-pill">Vai trò: <b id="liveRoleLabel"><%= role %></b></span>
          </div>
        </div>
      </div>

      <div class="live-room-topbar__right">
        <div class="live-room-stat" title="Đang xem">
          <i class="fas fa-eye"></i>
          <strong id="liveViewerCount"><%= session.viewerCount || 0 %></strong>
        </div>
        <div class="live-room-stat live-desktop-only" title="Peak Viewers">
          <i class="fas fa-fire"></i>
          <strong id="livePeakCount"><%= session.viewerPeak || 0 %></strong>
        </div>
        <div class="live-toggle-facecam-wrapper live-desktop-only" id="liveFacecamToggleWrapper">
          <button type="button" id="liveToggleFacecamButton" class="live-room-btn live-room-btn--secondary" title="Ẩn/Hiện Camera">
            <i class="fas fa-video"></i>
          </button>
        </div>
        <button type="button" id="liveToggleSidebarBtn" class="live-room-btn live-room-btn--secondary live-mobile-only" title="Thu gọn/Mở rộng Chat">
          <i class="fas fa-chevron-down"></i>
        </button>
        <% if (canModerate) { %>
          <!-- Desktop: inline buttons -->
          <button type="button" id="liveToggleMicButton" class="live-room-btn live-room-btn--secondary live-desktop-only" title="Bật/Tắt Micro">
            <i class="fas fa-microphone"></i>
          </button>
          <button type="button" id="liveDeviceSettingsButton" class="live-room-btn live-room-btn--secondary live-desktop-only" title="Cài đặt thiết bị">
            <i class="fas fa-cog"></i>
          </button>
          <button type="button" id="liveScreenShareButton" class="live-room-btn live-room-btn--secondary live-desktop-only" hidden>
            <i class="fas fa-desktop"></i> Chia sẻ màn hình
          </button>
          <button type="button" id="liveStartButton" class="live-room-btn live-room-btn--primary live-desktop-only" <%= session.permissions?.canStart ? '' : 'hidden' %>>
            Bắt đầu live
          </button>
          <button type="button" id="liveEndButton" class="live-room-btn live-room-btn--danger live-desktop-only" <%= session.permissions?.canEnd ? '' : 'hidden' %>>
            Kết thúc
          </button>
          <!-- Mobile: single button to open host controls -->
          <button type="button" id="liveHostControlsBtn" class="live-room-btn live-room-btn--secondary live-mobile-only" title="Điều khiển">
            <i class="fas fa-ellipsis-v"></i>
          </button>
        <% } %>
      </div>
    </div>

    <div class="live-stage-primary" id="liveStagePrimary">
      <div class="live-pip-controls" id="livePipControls">
        <button type="button" class="live-pip-btn" id="livePipHideBtn" title="Ẩn camera">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="live-stage-placeholder" id="liveStagePlaceholder">
        <i class="fas fa-broadcast-tower"></i>
        <strong id="liveStageHeadline">Phòng đang ở chế độ chờ</strong>
        <span id="liveStageSubtitle">Khi host lên sóng, video và audio sẽ xuất hiện ngay tại đây.</span>
      </div>
    </div>

    <div class="live-stage-grid" id="liveStageRemoteGrid"></div>
    <div class="live-screen-share-container" id="liveScreenShareContainer" hidden>
      <div class="live-screen-share-label"><i class="fas fa-desktop"></i> Màn hình đang được chia sẻ</div>
    </div>

    <% if (session.linkedMaterial) { %>
      <div class="live-linked-card">
        <div class="live-linked-card-icon">
          <i class="fas fa-book-open"></i>
        </div>
        <div class="live-linked-card-info">
          <strong><%= session.linkedMaterial.title %></strong>
          <% if (session.linkedMaterial.secondaryTitle) { %>
            <span><%= session.linkedMaterial.secondaryTitle %></span>
          <% } else { %>
            <span>Tài liệu tham khảo đính kèm</span>
          <% } %>
        </div>
        <a href="<%= session.linkedMaterial.href %>" target="_blank" class="live-room-btn live-room-btn--primary">
          Mở <i class="fas fa-external-link-alt" style="margin-left:6px; font-size:0.8em"></i>
        </a>
      </div>
    <% } %>
  </div>

  <!-- RIGHT: Sidebar Area -->
  <aside class="live-side-card">
    <div class="live-side-tabs">
      <button type="button" class="live-side-tab is-active" data-live-panel="chat">Chat</button>
      <button type="button" class="live-side-tab" data-live-panel="questions">Q&A</button>
      <button type="button" class="live-side-tab" data-live-panel="hands"><i class="fas fa-hand-paper"></i> Giơ tay</button>
      <button type="button" class="live-side-tab" data-live-panel="people"><i class="fas fa-users"></i></button>
    </div>

    <div class="live-side-panel is-active" data-live-panel-view="chat">
      <div class="live-feed" id="liveChatFeed">
        <% (liveRoomData.chatMessages || []).forEach((message) => { %>
          <div class="live-feed-item">
            <img src="<%= message.avatar %>" alt="<%= message.displayName || message.username %>" class="live-feed-item__avatar">
            <div class="live-feed-item-content">
              <strong><%= message.displayName || message.username %></strong>
              <p><%= message.content %></p>
            </div>
          </div>
        <% }) %>
      </div>
      <div class="live-panel-footer">
        <form id="liveChatForm" class="live-inline-form">
          <input type="text" id="liveChatInput" name="content" maxlength="1200" placeholder="Nhắn vào chat..." autocomplete="off">
          <button type="submit"><i class="fas fa-paper-plane"></i></button>
        </form>
      </div>
    </div>

    <div class="live-side-panel" data-live-panel-view="questions">
      <div class="live-feed" id="liveQuestionFeed">
        <% (liveRoomData.questions || []).forEach((question) => { %>
          <div class="live-feed-item" data-question-id="<%= question.id %>">
            <img src="<%= question.avatar %>" alt="<%= question.displayName || question.username %>" class="live-feed-item__avatar">
            <div class="live-feed-item-content">
              <strong><%= question.displayName || question.username %></strong>
              <p><%= question.content %></p>
              <div class="live-feed-item__actions">
                <span class="live-mini-btn" style="cursor:default; border:none;"><i class="fas fa-info-circle"></i> <%= question.status %></span>
                <% if (canModerate) { %>
                  <button type="button" class="live-mini-btn js-question-status" data-question-id="<%= question.id %>" data-status="pinned">Ghim</button>
                  <button type="button" class="live-mini-btn js-question-status" data-question-id="<%= question.id %>" data-status="answered">Xong</button>
                  <button type="button" class="live-mini-btn js-question-status" data-question-id="<%= question.id %>" data-status="dismissed">Ẩn</button>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <div class="live-panel-footer">
        <form id="liveQuestionForm" class="live-inline-form">
          <input type="text" id="liveQuestionInput" name="content" maxlength="1000" placeholder="Đặt câu hỏi cho host..." autocomplete="off">
          <button type="submit"><i class="fas fa-question"></i></button>
        </form>
      </div>
    </div>

    <div class="live-side-panel" data-live-panel-view="hands">
      <div class="live-hand-cta">
        <button type="button" id="liveRaiseHandButton" class="live-room-btn live-room-btn--primary">Giơ tay phát biểu</button>
      </div>
      <div class="live-feed" id="liveHandFeed">
        <% (liveRoomData.hands || []).forEach((hand) => { %>
          <div class="live-feed-item" data-hand-id="<%= hand.id %>">
            <img src="<%= hand.avatar %>" alt="<%= hand.displayName || hand.username %>" class="live-feed-item__avatar">
            <div class="live-feed-item-content">
              <strong><%= hand.displayName || hand.username %></strong>
              <p>Trạng thái: <%= hand.status %></p>
              <% if (canModerate) { %>
                <div class="live-feed-item__actions">
                  <button type="button" class="live-mini-btn js-hand-status" data-hand-id="<%= hand.id %>" data-status="accepted">Mời phát biểu</button>
                  <button type="button" class="live-mini-btn js-hand-status" data-hand-id="<%= hand.id %>" data-status="lowered">Hạ tay</button>
                </div>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="live-side-panel" data-live-panel-view="people">
      <div class="live-feed" id="livePeopleFeed">
        <div class="live-empty-inline">Danh sách người tham gia sẽ hiện theo thời gian thực.</div>
      </div>
    </div>
  </aside>

  <!-- Device Settings Modal -->
  <div id="liveDeviceModal" class="live-modal" hidden>
    <div class="live-modal-content">
      <div class="live-modal-header">
        <h3>Cài đặt thiết bị</h3>
        <button type="button" class="live-modal-close" id="liveCloseDeviceModal">&times;</button>
      </div>
      <div class="live-modal-body">
        <div class="live-setting-item">
          <label for="liveMicSelect"><i class="fas fa-microphone"></i> Microphone</label>
          <select id="liveMicSelect" class="live-room-select"></select>
        </div>
        <div class="live-setting-item">
          <label for="liveCamSelect"><i class="fas fa-video"></i> Camera</label>
          <select id="liveCamSelect" class="live-room-select"></select>
        </div>
        <div class="live-setting-item">
          <label class="live-setting-checkbox">
            <input type="checkbox" id="liveScreenAudioToggle">
            <span>Chia sẻ âm thanh hệ thống</span>
          </label>
        </div>
        <p class="live-setting-note">Lưu ý: Thay đổi sẽ có hiệu lực ngay lập tức.</p>
      </div>
    </div>
  </div>

  <!-- Mobile Context Menu -->
  <div id="liveMobileMenu" class="live-mobile-menu" hidden>
    <div class="live-mobile-menu__overlay"></div>
    <div class="live-mobile-menu__content">
      <div class="live-mobile-menu__item" data-action="focus">
        <i class="fas fa-expand"></i> <span>Chế độ Focus</span>
      </div>
      <div class="live-mobile-menu__item" data-action="report">
        <i class="fas fa-flag"></i> <span>Báo cáo vi phạm</span>
      </div>
      <div class="live-mobile-menu__item live-mobile-menu__item--danger" data-action="leave">
        <i class="fas fa-sign-out-alt"></i> <span>Rời phòng</span>
      </div>
      <div class="live-mobile-menu__close" id="liveCloseMobileMenu">
        Đóng
      </div>
    </div>
  </div>

  <% if (canModerate) { %>
  <!-- Mobile Host Controls Bottom Sheet -->
  <div id="liveHostControlsModal" class="live-host-controls" hidden>
    <div class="live-host-controls__overlay"></div>
    <div class="live-host-controls__sheet">
      <div class="live-host-controls__handle"></div>
      <h3 class="live-host-controls__title">Điều khiển phòng</h3>
      <div class="live-host-controls__grid">
        <button type="button" class="live-hc-btn" id="liveHcMicBtn">
          <div class="live-hc-btn__icon"><i class="fas fa-microphone"></i></div>
          <span>Micro</span>
        </button>
        <button type="button" class="live-hc-btn" id="liveHcCamBtn">
          <div class="live-hc-btn__icon"><i class="fas fa-video"></i></div>
          <span>Camera</span>
        </button>
        <button type="button" class="live-hc-btn" id="liveHcScreenBtn">
          <div class="live-hc-btn__icon"><i class="fas fa-desktop"></i></div>
          <span>Màn hình</span>
        </button>
        <button type="button" class="live-hc-btn" id="liveHcDeviceBtn">
          <div class="live-hc-btn__icon"><i class="fas fa-cog"></i></div>
          <span>Thiết bị</span>
        </button>
      </div>
      <div class="live-host-controls__actions">
        <button type="button" class="live-hc-action live-hc-action--start" id="liveHcStartBtn" <%= session.permissions?.canStart ? '' : 'hidden' %>>
          <i class="fas fa-play"></i> Bắt đầu Live
        </button>
        <button type="button" class="live-hc-action live-hc-action--end" id="liveHcEndBtn" <%= session.permissions?.canEnd ? '' : 'hidden' %>>
          <i class="fas fa-stop"></i> Kết thúc Live
        </button>
      </div>
      <button type="button" class="live-host-controls__close" id="liveHcCloseBtn">Đóng</button>
    </div>
  </div>
  <% } %>
</section>

<script src="/vendor/livekit/livekit-client.umd.js"></script>
<script src="/js/liveRoom.js"></script>
<%- include('partials/footer') %>
