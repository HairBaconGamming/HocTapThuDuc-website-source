<%- include('partials/header') %>
<link rel="stylesheet" href="/css/styleIndexPremium.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

<!-- HERO SECTION -->
<section class="idx-hero">
    <div class="idx-hero-bg"></div>
    <div class="idx-hero-blob blob-1"></div>
    <div class="idx-hero-blob blob-2"></div>
    
    <div class="idx-hero-wrapper gsap-hero-reveal">
        <div class="idx-hero-content">
            <div class="idx-badge">
                ✨ Nền tảng học tập cực xịn thế hệ mới
            </div>
            
            <% if (!user) { %>
                <h1 class="idx-title">
                    Đỉnh cao tri thức,<br>
                    <span class="idx-title-gradient">Cộng đồng dẫn đầu</span>
                </h1>
                <p class="idx-desc">
                    Tham gia mạng lưới học sinh Thủ Đức. Nơi chia sẻ tài liệu, bài giảng chất lượng cao và cùng nhau leo rank trên bảng xếp hạng thành tích.
                </p>
                <div class="idx-hero-actions">
                    <a href="/register" class="idx-btn idx-btn-primary">Bắt đầu ngay <i class="fas fa-arrow-right"></i></a>
                    <a href="#features" class="idx-btn idx-btn-secondary">Khám phá tính năng</a>
                </div>
            <% } else { %>
                <% 
                    const currentHour = new Date().getHours();
                    let greeting = "";
                    if (currentHour >= 5 && currentHour < 12) greeting = "Chào buổi sáng";
                    else if (currentHour >= 12 && currentHour < 18) greeting = "Chào buổi chiều";
                    else if (currentHour >= 18 && currentHour < 22) greeting = "Chào buổi tối";
                    else greeting = "Khuya rồi";
                %>
                <h1 class="idx-title">
                    <%= greeting %>,<br>
                    <span class="idx-title-gradient"><%= user.username %>!</span>
                </h1>
                <p class="idx-desc">
                    Sẵn sàng cho một phiên học mới chưa? Đừng quên kiểm tra khu vườn và các nhiệm vụ hôm nay của bạn.
                </p>
                <div class="idx-hero-actions">
                    <a href="/dashboard" class="idx-btn idx-btn-primary"><i class="fas fa-laptop-house"></i> Vào Dashboard</a>
                    <a href="/courses" class="idx-btn idx-btn-secondary"><i class="fas fa-book-open"></i> Thư viện</a>
                </div>
            <% } %>
        </div>

        <div class="idx-hero-3d">
            <script type="module" src="https://unpkg.com/@splinetool/viewer@1.9.5/build/spline-viewer.js"></script>
            <spline-viewer url="https://prod.spline.design/6t2j0Q2-BX0gIdqx/scene.splinecode"></spline-viewer>
        </div>
    </div>
</section>

<!-- BENTO GRID FEATURES -->
<section id="features" class="idx-section">
    <div class="idx-section-header gsap-fade-up">
        <h2 class="idx-section-title">Tính năng nổi bật</h2>
        <p class="idx-desc" style="margin-bottom:0;">Khám phá hệ sinh thái học tập toàn diện</p>
    </div>

    <div class="idx-bento-grid">
        <!-- Feature 1 -->
        <div class="idx-bento-card idx-bento-tall gsap-bento">
            <div class="idx-bento-icon"><i class="fas fa-tree"></i></div>
            <h3 class="idx-bento-title">Khu vườn tri thức</h3>
            <p class="idx-bento-desc">Trồng cây, thu hoạch tài nguyên và nâng cấp khu vườn ảo của bạn thông qua việc hoàn thành các bài học và bài tập hàng ngày.</p>
        </div>

        <!-- Feature 2 -->
        <div class="idx-bento-card idx-bento-square gsap-bento">
            <div class="idx-bento-icon"><i class="fas fa-crown"></i></div>
            <h3 class="idx-bento-title">Hệ thống Tu Tiên</h3>
            <p class="idx-bento-desc">Tích lũy kinh nghiệm (EXP) để đột phá cảnh giới. Từ Luyện Khí đến Đại La Kim Tiên, chứng tỏ bản lĩnh học tập của bạn.</p>
        </div>

        <!-- Feature 3 -->
        <div class="idx-bento-card idx-bento-square gsap-bento">
            <div class="idx-bento-icon"><i class="fas fa-users"></i></div>
            <h3 class="idx-bento-title">Bang hội & Giao lưu</h3>
            <p class="idx-bento-desc">Thành lập nhóm học tập, cùng nhau cày cuốc đóng góp quỹ chung và nhận buff đặc quyền cho thành viên.</p>
        </div>

        <!-- Feature 4 -->
        <div class="idx-bento-card idx-bento-wide gsap-bento" style="display: flex; flex-direction: row; align-items: center; gap: 2rem;">
            <div style="flex: 1;">
                <div class="idx-bento-icon"><i class="fas fa-laptop-code"></i></div>
                <h3 class="idx-bento-title">Thư viện Khóa học</h3>
                <p class="idx-bento-desc">Hàng trăm bài giảng và tài liệu được biên soạn kỹ lưỡng bởi đội ngũ giáo viên và những học sinh xuất sắc nhất.</p>
            </div>
            <div style="flex: 1; text-align: center;">
                <img src="https://cdni.iconscout.com/illustration/premium/thumb/online-learning-4488344-3738466.png" style="max-width: 100%; height: auto; transform: scale(1.1);">
            </div>
        </div>
    </div>
</section>

<!-- STATS SECTION -->
<section class="idx-section">
    <div class="idx-stats-container gsap-fade-up">
        <div class="idx-stat-item">
            <div class="idx-stat-value counter" data-target="<%= totalStudents || 0 %>">0</div>
            <div class="idx-stat-label">Học viên</div>
        </div>
        <div class="idx-stat-item">
            <div class="idx-stat-value counter" data-target="<%= totalCourses || 0 %>">0</div>
            <div class="idx-stat-label">Khóa học</div>
        </div>
        <div class="idx-stat-item">
            <div class="idx-stat-value counter" data-target="<%= totalLessons || 0 %>">0</div>
            <div class="idx-stat-label">Tài liệu</div>
        </div>
    </div>
</section>

<!-- LATEST COURSES SCROLL -->
<section class="idx-section" style="padding-bottom: 8rem;">
    <div class="idx-section-header gsap-fade-up">
        <h2 class="idx-section-title">Vừa ra lò</h2>
        <p class="idx-desc" style="margin-bottom:0;">Những khóa học mới nhất từ cộng đồng</p>
    </div>

    <% if (courses && courses.length > 0) { %>
        <div class="idx-horizontal-scroll gsap-scroll-x">
            <% courses.forEach((course) => { %>
                <a href="/course/<%= course._id %>" class="idx-course-card">
                    <img src="<%= course.thumbnail || 'https://i.ibb.co/BVnNtLhp/default-course.png' %>" class="idx-course-img" onerror="this.onerror=null;this.src='https://i.ibb.co/BVnNtLhp/default-course.png';">
                    <div class="idx-course-content">
                        <span class="idx-course-badge"><%= course.subjectId ? course.subjectId.name : 'Mới' %></span>
                        <h3 class="idx-course-title"><%= course.title %></h3>
                        <div class="idx-course-footer">
                            <div class="idx-course-author">
                                <% const author = course.author || {}; %>
                                <img src="<%= author.avatar || 'https://static.vecteezy.com/system/resources/previews/013/360/247/non_2x/default-avatar-photo-icon-social-media-profile-sign-symbol-vector.jpg' %>">
                                <span class="idx-course-author-name"><%= author.username || 'Ban Biên Tập' %></span>
                            </div>
                            <i class="fas fa-chevron-right" style="color: var(--idx-primary);"></i>
                        </div>
                    </div>
                </a>
            <% }) %>
        </div>
    <% } else { %>
        <div style="text-align: center; color: var(--idx-text-muted);">Đang cập nhật bài học...</div>
    <% } %>
</section>

<!-- GSAP Animations Script -->
<script>
    document.addEventListener("DOMContentLoaded", (event) => {
        gsap.registerPlugin(ScrollTrigger);

        // Hero Reveal
        gsap.from(".gsap-hero-reveal", {
            y: 50,
            opacity: 0,
            duration: 1.5,
            ease: "power4.out"
        });

        // Bento Grid Stagger
        gsap.from(".gsap-bento", {
            scrollTrigger: {
                trigger: ".idx-bento-grid",
                start: "top 80%"
            },
            y: 50,
            opacity: 0,
            duration: 1,
            stagger: 0.2,
            ease: "back.out(1.7)"
        });

        // General Fade Up
        gsap.utils.toArray('.gsap-fade-up').forEach(elem => {
            gsap.from(elem, {
                scrollTrigger: {
                    trigger: elem,
                    start: "top 85%"
                },
                y: 30,
                opacity: 0,
                duration: 1,
                ease: "power3.out"
            });
        });

        // Counter Animation
        const counters = document.querySelectorAll('.counter');
        counters.forEach(counter => {
            gsap.to(counter, {
                scrollTrigger: {
                    trigger: counter,
                    start: "top 90%",
                    once: true,
                    onEnter: () => {
                        const target = +counter.getAttribute('data-target');
                        gsap.to({ val: 0 }, {
                            val: target,
                            duration: 2,
                            ease: "power2.out",
                            onUpdate: function() {
                                counter.innerHTML = Math.ceil(this.targets()[0].val);
                            }
                        });
                    }
                }
            });
        });
    });
</script>

<%- include('partials/footer') %>
