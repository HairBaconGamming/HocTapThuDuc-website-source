<%- include('partials/header') %>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
<link rel="stylesheet" href="/css/styleQA.css">

<%
// Logic xử lý dữ liệu chi tiết
const detailQuestion = question || {};
const safeAnswers = Array.isArray(answers) ? answers : [];
const questionStatus = detailQuestion.status || 'open';
const canAnswer = !!user && questionStatus !== 'closed';
%>

<div class="qa-detail-shell">
    <a href="/qa" class="qa-btn qa-btn-secondary" style="margin-bottom: 24px; display: inline-flex; color: var(--qa-text); background: var(--qa-surface-glass);"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>

    <div class="qa-detail-layout">
        <section class="qa-thread">
            
            <article class="qa-panel qa-question-card" style="margin-bottom: 32px;">
                <div class="qa-card-top" style="margin-bottom: 16px;">
                    <span class="qa-badge qa-badge-subject"><%= detailQuestion.subject || 'Khác' %></span>
                    <span class="qa-badge qa-badge-grade">Lớp <%= detailQuestion.grade || 'Chung' %></span>
                    <span class="qa-badge qa-badge-status-<%= questionStatus %>">
                        <%= questionStatus === 'resolved' ? 'Đã giải quyết' : questionStatus === 'closed' ? 'Đã đóng' : 'Đang chờ giải' %>
                    </span>
                    <% if (Number(detailQuestion.bountyAmount || 0) > 0) { %>
                        <span class="qa-badge qa-badge-bounty" style="margin-left: auto;"><i class="fas fa-gem"></i> Treo thưởng <%= Number(detailQuestion.bountyAmount).toLocaleString('vi-VN') %></span>
                    <% } %>
                </div>

                <h1 class="qa-question-title" style="font-size: clamp(1.5rem, 4vw, 2.2rem); margin-bottom: 24px;"><%= detailQuestion.title || 'Chi tiết câu hỏi' %></h1>
                
                <div class="qa-author-row" style="margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--qa-border);">
                    <img class="qa-avatar" src="<%= detailQuestion.author?.avatar || '/default.png' %>" alt="Avatar">
                    <div class="qa-author-meta">
                        <div class="qa-author-name"><%= detailQuestion.author?.username || 'Ẩn danh' %></div>
                        <div class="qa-author-sub">
                            Đã hỏi lúc <time data-relative-time datetime="<%= detailQuestion.createdAt %>"><%= new Date(detailQuestion.createdAt).toLocaleString('vi-VN') %></time>
                        </div>
                    </div>
                </div>

                <div class="qa-richtext qa-math qa-question-summary" style="font-size: 1.05rem;">
                    <%- marked(detailQuestion.content || '') %>
                </div>

                <% if (Array.isArray(detailQuestion.images) && detailQuestion.images.length > 0) { %>
                    <div class="qa-image-grid" style="margin-top: 24px;">
                        <% detailQuestion.images.forEach((imageUrl) => { %>
                            <a href="<%= imageUrl %>" target="_blank" rel="noopener noreferrer">
                                <img src="<%= imageUrl %>" alt="Hình đính kèm" style="border-radius: var(--qa-radius-md);">
                            </a>
                        <% }) %>
                    </div>
                <% } %>
            </article>

            <section class="qa-answer-list">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
                    <h2 style="margin: 0; font-size: 1.4rem;"><%= safeAnswers.length %> Lời giải từ cộng đồng</h2>
                </div>

                <% if (safeAnswers.length > 0) { %>
                    <div style="display: grid; gap: 24px;">
                        <% safeAnswers.forEach((answer) => { %>
                            <article class="qa-panel qa-answer-card" id="answer-<%= answer._id %>" style="border-left: <%= answer.isAccepted ? '4px solid var(--qa-success)' : '1px solid var(--qa-border)' %>;">
                                
                                <% if (answer.isAccepted) { %>
                                    <div style="color: var(--qa-success); font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                                        <i class="fas fa-check-circle"></i> Đáp án đã được chốt
                                    </div>
                                <% } %>

                                <div class="qa-author-row" style="margin-bottom: 16px;">
                                    <img class="qa-avatar-sm" src="<%= answer.author?.avatar || '/default.png' %>" alt="Avatar">
                                    <div class="qa-author-meta">
                                        <div class="qa-author-name"><%= answer.author?.username || 'Thành viên' %></div>
                                        <div class="qa-author-sub"><time data-relative-time datetime="<%= answer.createdAt %>"><%= new Date(answer.createdAt).toLocaleString('vi-VN') %></time></div>
                                    </div>
                                </div>

                                <div class="qa-richtext qa-math qa-answer-content">
                                    <%- marked(answer.content || '') %>
                                </div>

                                <div class="qa-answer-toolbar" style="margin-top: 24px; padding-top: 16px; border-top: 1px dashed var(--qa-border); display: flex; gap: 12px; flex-wrap: wrap;">
                                    <% if (user) { %>
                                        <button class="qa-btn qa-btn-secondary qa-upvote-btn" style="color: var(--qa-text); padding: 8px 16px;" data-action-url="/qa/answers/<%= answer._id %>/upvote">
                                            <i class="fas fa-arrow-up"></i> <%= Number(answer.upvoteCount || 0) %> Upvote
                                        </button>
                                        <button class="qa-btn qa-btn-secondary" style="color: var(--qa-text); padding: 8px 16px;" data-toggle-comments="comments-<%= answer._id %>">
                                            <i class="fas fa-comment"></i> Thảo luận (<%= Array.isArray(answer.comments) ? answer.comments.length : 0 %>)
                                        </button>

                                        <% if (String(detailQuestion.author?._id || detailQuestion.author) === String(user._id) && !detailQuestion.acceptedAnswer && !answer.isAccepted) { %>
                                            <button class="qa-btn qa-btn-primary qa-accept-btn" style="padding: 8px 16px; margin-left: auto;" data-action-url="/qa/answers/<%= answer._id %>/accept">
                                                <i class="fas fa-award"></i> Chốt đúng
                                            </button>
                                        <% } %>
                                    <% } %>
                                </div>

                                <div class="qa-comments-wrap" id="comments-<%= answer._id %>" style="margin-top: 16px; background: var(--qa-bg); padding: 16px; border-radius: var(--qa-radius-md);" hidden>
                                    <p style="color: var(--qa-muted); font-size: 0.9rem; margin: 0;">Hiển thị bình luận tại đây...</p>
                                </div>
                            </article>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="qa-panel qa-empty">
                        <i class="far fa-paper-plane" style="font-size: 2.5rem; color: var(--qa-muted); margin-bottom: 16px; opacity: 0.5;"></i>
                        <strong>Chưa có ai giải bài này.</strong>
                        <p>Hãy là người hùng đầu tiên mở bát lấy trọn phần thưởng nhé!</p>
                    </div>
                <% } %>
            </section>

            <% if (canAnswer) { %>
                <section class="qa-panel" id="qaAnswerComposer" style="margin-top: 32px; border: 2px solid var(--qa-primary);">
                    <h3 style="margin-top: 0; margin-bottom: 16px;"><i class="fas fa-pen-nib"></i> Viết lời giải của bạn</h3>
                    <form id="qaAnswerForm" style="display: flex; flex-direction: column; gap: 16px;">
                        <input type="hidden" name="questionId" value="<%= detailQuestion._id %>">
                        <textarea name="content" rows="6" placeholder="Viết rõ ràng từng bước. Hỗ trợ Toán học LaTeX..." style="width: 100%; padding: 16px; border-radius: var(--qa-radius-md); border: 1px solid var(--qa-border);" required></textarea>
                        <div style="display: flex; justify-content: flex-end;">
                            <button type="submit" class="qa-btn qa-btn-primary"><i class="fas fa-paper-plane"></i> Gửi câu trả lời</button>
                        </div>
                    </form>
                </section>
            <% } %>
        </section>
    </div>
</div>

<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"></script>
<script src="/js/qa.js"></script>
<%- include('partials/footer') %>