<%
    const tutorVariant = typeof aiTutorVariant !== 'undefined' ? aiTutorVariant : 'default';
    const tutorPage = typeof aiTutorPage !== 'undefined' ? aiTutorPage : tutorVariant;
    const tutorTitle = typeof aiTutorTitle !== 'undefined'
        ? aiTutorTitle
        : (tutorVariant === 'garden'
            ? 'Nong Trai AI'
            : tutorVariant === 'lesson-studio'
                ? 'Studio AI'
                : tutorVariant === 'lesson-detail'
                    ? 'Gia su AI'
                    : 'AI Tutor');
    const tutorSubtitle = typeof aiTutorSubtitle !== 'undefined'
        ? aiTutorSubtitle
        : (tutorVariant === 'garden'
            ? 'Goi y nuoc di tiep theo trong vuon'
            : tutorVariant === 'lesson-studio'
                ? 'Bien tap, ra soat va len y tuong bai hoc'
                : tutorVariant === 'lesson-detail'
                    ? 'Giai thich ngan gon ngay luc dang hoc'
                    : 'Tom tat, giai thich va dan duong hoc tap');
    const tutorUser = user
        ? {
            id: String(user._id || ''),
            username: user.username || 'Ban',
            level: Number(user.level) || 0,
            isAdmin: !!user.isAdmin,
            isTeacher: !!user.isTeacher,
            isPro: !!user.isPro
        }
        : null;
%>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">

<div
    class="ai-tutor-shell ai-tutor-shell--<%= tutorVariant %>"
    id="aiTutorShell"
    data-ai-tutor-shell
    data-variant="<%= tutorVariant %>"
    data-page-type="<%= tutorPage %>"
>
    <button
        type="button"
        class="ai-tutor-fab"
        data-ai-tutor-toggle
        aria-expanded="false"
        aria-controls="aiTutorPanel"
    >
        <span class="ai-tutor-fab-orb">
            <i class="fas fa-robot"></i>
        </span>
        <span class="ai-tutor-fab-copy">
            <strong><%= tutorTitle %></strong>
            <small><%= tutorSubtitle %></small>
        </span>
    </button>

    <section
        class="ai-tutor-panel"
        id="aiTutorPanel"
        data-ai-tutor-panel
        hidden
        aria-live="polite"
    >
        <header class="ai-tutor-panel-head">
            <div>
                <span class="ai-tutor-kicker">AI huong dan</span>
                <h3><%= tutorTitle %></h3>
                <p><%= tutorSubtitle %></p>
            </div>
            <button type="button" class="ai-tutor-mini-btn" data-ai-tutor-close aria-label="Dong AI Tutor">
                <i class="fas fa-xmark"></i>
            </button>
        </header>

        <div class="ai-tutor-context" data-ai-tutor-context>
            <span class="ai-tutor-context-pill" data-ai-tutor-context-label>Dang doc ngu canh trang</span>
            <span class="ai-tutor-context-line" data-ai-tutor-selection-status>Chua co doan chon rieng.</span>
        </div>

        <div class="ai-tutor-quick-actions" data-ai-tutor-actions></div>

        <div class="ai-tutor-thread" data-ai-tutor-thread>
            <article class="ai-tutor-msg ai-tutor-msg--assistant">
                <div class="ai-tutor-msg-bubble ai-tutor-msg-bubble--rich" data-ai-tutor-welcome>
                    Minh dang bam theo noi dung trang nay. Ban cu hoi ngan gon, minh se giai thich bang Markdown va cong thuc LaTeX neu can.
                </div>
            </article>
        </div>

        <form class="ai-tutor-form" data-ai-tutor-form>
            <label class="ai-tutor-input-wrap" for="aiTutorInput">
                <textarea
                    id="aiTutorInput"
                    class="ai-tutor-input"
                    data-ai-tutor-input
                    rows="2"
                    placeholder="Hoi AI Tutor dieu ban dang can..."
                ></textarea>
            </label>
            <div class="ai-tutor-form-foot">
                <span class="ai-tutor-status" data-ai-tutor-status>San sang ho tro</span>
                <button type="submit" class="ai-tutor-send">
                    <i class="fas fa-paper-plane"></i>
                    <span>Gui</span>
                </button>
            </div>
        </form>
    </section>
</div>

<script>
    window.AI_TUTOR_BOOTSTRAP = Object.assign({}, window.AI_TUTOR_BOOTSTRAP || {}, {
        variant: <%- JSON.stringify(tutorVariant) %>,
        pageType: <%- JSON.stringify(tutorPage) %>,
        title: <%- JSON.stringify(tutorTitle) %>,
        subtitle: <%- JSON.stringify(tutorSubtitle) %>,
        user: <%- JSON.stringify(tutorUser) %>
    });
</script>
<script defer src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/dompurify@3.2.5/dist/purify.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"></script>
<script src="/js/aiTutor.js"></script>
