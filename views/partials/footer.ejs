</main> <footer style="margin-top: 60px; padding: 40px 20px; text-align: center; border-top: 2px dashed #eee; color: #888;">
    <div class="container">
        <h3 style="color: var(--primary); margin-bottom: 10px;">Học Tập Thủ Đức</h3>
        <p>Nơi kiến thức không bao giờ "ngủ gật" 😴</p>
        
        <div style="margin-top: 20px; font-size: 0.9rem;">
            <p>Code bằng 🍜 Mì tôm và ☕ Cafe bởi <b>NAM</b> và AI</p>
            <p>© <%= new Date().getFullYear() %> - Chạy ổn định trên máy của Nam (máy khác hên xui)</p>
        </div>
    </div>
</footer>

<% if (typeof user !== 'undefined' && user && activePage !== 'live') { %>
<%- include('aiTutor', {
    user,
    aiTutorVariant: typeof aiTutorVariant !== 'undefined' ? aiTutorVariant : undefined,
    aiTutorPage: typeof aiTutorPage !== 'undefined' ? aiTutorPage : undefined,
    aiTutorTitle: typeof aiTutorTitle !== 'undefined' ? aiTutorTitle : undefined,
    aiTutorSubtitle: typeof aiTutorSubtitle !== 'undefined' ? aiTutorSubtitle : undefined
}) %>
<% } %>

<% if (typeof user !== 'undefined' && user) { %>
<script>
    (function() {
        if (document.body.dataset.disableActivityHeartbeat === 'true') {
            return;
        }
        // Hàm gửi nhịp tim
        function sendHeartbeat() {
            // Chỉ gửi khi tab đang mở (tránh tính giờ treo máy)
            if (document.visibilityState === 'visible') {
                fetch('/api/activity/heartbeat', { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                }).catch(err => { /* Silent fail to not disturb user */ });
            }
        }

        // Gửi mỗi 60 giây (1 phút)
        setInterval(sendHeartbeat, 60000);
        
        // Gửi ngay 1 lần sau 5s vào trang để tính phút đầu tiên
        setTimeout(sendHeartbeat, 5000);
    })();
</script>
<% } %>

<script src="/js/alerts.js"></script>
<script>
    // --- KEEP ALIVE SYSTEM ---
    // Render.com Free Tier sẽ ngủ sau 15p không hoạt động.
    // Script này sẽ "chọc" server mỗi 10 phút (600.000ms) để giữ kết nối.
    
    const PING_INTERVAL = 10 * 60 * 1000; // 10 phút

    setInterval(() => {
        fetch('/api/ping')
            .then(res => {
                // console.log('Keep-alive ping:', res.status); // Bật nếu muốn debug
            })
            .catch(err => {
                console.warn('Keep-alive failed:', err);
            });
    }, PING_INTERVAL);
</script>
</body>
</html>
