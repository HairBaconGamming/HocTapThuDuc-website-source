<%- include('partials/header') %>
<link rel="stylesheet" href="/css/styleGuild.css">

<main class="guild-page-shell">
    <section class="guild-hero">
        <div class="guild-hero-copy">
            <span class="guild-kicker">Tông Môn / Bang Hội</span>
            <h1>Khai tông và hợp sức nuôi Linh Thụ.</h1>
            <p>
                Gia nhập một cộng đồng tự học, quyên góp tài nguyên cho Linh Thụ và nhận buff
                chung cho cả Tông Môn.
            </p>
            <div class="guild-hero-badges">
                <span class="guild-chip">Cần Level <%= minCreateLevel %> để lập Tông Môn</span>
                <span class="guild-chip"><%= realmInfo.fullName %></span>
                <span class="guild-chip">Buff XP + Bảo trợ Vườn</span>
            </div>
        </div>

        <div class="guild-create-card">
            <div class="guild-card-head">
                <span class="guild-mini-kicker">Bắt đầu</span>
                <h2>Lập Tông Môn mới</h2>
            </div>
            <form action="/guilds" method="POST" class="guild-form">
                <label>
                    <span>Tên Tông Môn</span>
                    <input type="text" name="name" maxlength="60" minlength="3" placeholder="Ví dụ: Thiên Mộc Tông" required>
                </label>
                <label>
                    <span>Mô tả ngắn</span>
                    <textarea name="description" rows="3" maxlength="260" placeholder="Tinh thần, mục tiêu, lời hứa của Tông Môn"></textarea>
                </label>
                <button type="submit" class="guild-primary-btn" <%= canCreateGuild ? '' : 'disabled' %>>Khai tông ngay</button>
                <% if (!canCreateGuild) { %>
                    <small class="guild-helper-note">Bạn cần đạt level <%= minCreateLevel %> để lập Tông Môn riêng.</small>
                <% } %>
            </form>
        </div>
    </section>

    <section class="guild-list-section">
        <div class="guild-section-head">
            <div>
                <span class="guild-kicker">Tông Môn đang mở</span>
                <h2>Chọn một nơi để cùng nhau thăng cấp.</h2>
            </div>
            <p><%= guilds.length %> Tông Môn đang sẵn sàng chào đón thành viên mới.</p>
        </div>

        <div class="guild-grid">
            <% guilds.forEach((entry) => { %>
                <article class="guild-list-card">
                    <div class="guild-list-top">
                        <div>
                            <span class="guild-stage-pill">Stage <%= entry.treeProgress.current.stage %></span>
                            <h3><%= entry.name %></h3>
                        </div>
                        <div class="guild-members-pill"><%= entry.memberCount %>/<%= entry.memberLimit %></div>
                    </div>

                    <p class="guild-list-description"><%= entry.description || 'Tông Môn này đang tìm kiếm những người học có tâm và có chí.' %></p>

                    <div class="guild-list-meta">
                        <span>Trưởng môn: <strong><%= entry.leader?.username || 'Ẩn danh' %></strong></span>
                        <span>Linh Thụ: <strong><%= entry.treeProgress.current.name %></strong></span>
                    </div>

                    <div class="guild-list-buffs">
                        <span>+<%= entry.buffSnapshot.lessonXpPct %>% XP học bài</span>
                        <span>+<%= entry.buffSnapshot.witherTimeBonusPct %>% độ bền cây</span>
                    </div>

                    <div class="guild-list-progress">
                        <div class="guild-progress-bar">
                            <span style="width: <%= entry.treeProgress.percent %>%"></span>
                        </div>
                        <% if (entry.treeProgress.next) { %>
                            <small>Còn <%= entry.treeProgress.xpForNextStage %> Linh Lực để đạt <%= entry.treeProgress.next.name %>.</small>
                        <% } else { %>
                            <small>Linh Thụ đã đạt cảnh giới tối thượng hiện tại.</small>
                        <% } %>
                    </div>

                    <div class="guild-list-actions">
                        <a href="/guilds/<%= entry.slug %>" class="guild-secondary-btn">Xem Tông Môn</a>
                        <form action="/guilds/<%= entry.slug %>/join" method="POST">
                            <button type="submit" class="guild-primary-btn" <%= (user.level || 0) >= (entry.levelRequirement || 0) ? '' : 'disabled' %>>Gia nhập</button>
                        </form>
                    </div>
                </article>
            <% }) %>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
