<%- include('partials/header') %>
<link rel="stylesheet" href="/css/styleQA.css">

<%
const safeSidebar = sidebar || {};
const weekly = Array.isArray(safeSidebar.contributors?.weekly) ? safeSidebar.contributors.weekly : [];
%>

<div class="qa-shell">
    <div class="qa-hero-banner hero-gold">
        <div class="hero-content">
            <h1>Bảng Phong Thần</h1>
            <p>Nơi vinh danh những trụ cột học thuật mang tri thức giải cứu toàn Server.</p>
        </div>
    </div>

    <!-- PODIUM CHO TOP 3 -->
    <% if (weekly.length >= 3) { %>
    <div class="qa-podium-container">
        <!-- TOP 2 -->
        <div class="qa-podium-spot spot-2">
            <div class="podium-avatar-wrap"><img src="<%= weekly[1].avatar %>" alt="Ava"><div class="podium-medal">2</div></div>
            <div class="podium-name"><%= weekly[1].username %></div>
            <div class="podium-score"><%= weekly[1].score %> pt</div>
            <div class="podium-base base-2"></div>
        </div>
        <!-- TOP 1 -->
        <div class="qa-podium-spot spot-1">
            <div class="podium-avatar-wrap"><img src="<%= weekly[0].avatar %>" alt="Ava"><div class="podium-medal"><i class="fas fa-crown"></i></div></div>
            <div class="podium-name"><%= weekly[0].username %></div>
            <div class="podium-score"><%= weekly[0].score %> pt</div>
            <div class="podium-base base-1"></div>
        </div>
        <!-- TOP 3 -->
        <div class="qa-podium-spot spot-3">
            <div class="podium-avatar-wrap"><img src="<%= weekly[2].avatar %>" alt="Ava"><div class="podium-medal">3</div></div>
            <div class="podium-name"><%= weekly[2].username %></div>
            <div class="podium-score"><%= weekly[2].score %> pt</div>
            <div class="podium-base base-3"></div>
        </div>
    </div>
    <% } %>

    <!-- LIST TOP 4 TRỞ XUỐNG -->
    <div class="qa-lb-table-container">
        <table class="qa-lb-table">
            <thead>
                <tr>
                    <th>Hạng</th>
                    <th>Cao thủ</th>
                    <th>Danh hiệu</th>
                    <th class="text-right">Công trạng (Điểm)</th>
                </tr>
            </thead>
            <tbody>
                <% weekly.slice(3).forEach((user) => { %>
                <tr>
                    <td><strong>#<%= user.rank %></strong></td>
                    <td>
                        <div class="qa-user-inline">
                            <img src="<%= user.avatar %>" class="qa-avatar-sm" alt="ava">
                            <span><%= user.username %></span>
                        </div>
                    </td>
                    <td><span class="qa-badge tier"><%= user.tier?.label || 'Tân Binh' %></span></td>
                    <td class="text-right"><strong class="qa-text-primary"><%= user.score %> pt</strong></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script src="/js/qa.js"></script>
<%- include('partials/footer') %>