<%- include('partials/header') %>

<%
    const safeProfileUser = profileUser || {};
    const safeLevelInfo = levelInfo || {};
    const safeStats = stats || {};
    const safeGuildProfile = guildProfile || null;
    const safeActivities = Array.isArray(activities) ? activities : [];
    const safeAchievements = Array.isArray(achievements) ? achievements : [];
    const safeUserRank = Number(userRank) || 0;
    const safeStreak = Number(streak) || 0;
    const safeTotalAchievements = Number(totalAchievements) || 0;
    const safeAvatar = safeProfileUser.avatar || `https://static.vecteezy.com/system/resources/previews/013/360/247/non_2x/default-avatar-photo-icon-social-media-profile-sign-symbol-vector.jpg`;
    const safeUsername = safeProfileUser.username || 'Đạo hữu bí ẩn';
    const safeBio = safeProfileUser.bio || 'Người chơi hệ bí ẩn, chưa để lại lời giới thiệu nào...';
    const safeSchool = safeProfileUser.school || 'THPT';
    const safeClass = safeProfileUser.class || 'Chưa cập nhật lớp';
    const safeLevel = Number(safeLevelInfo.level) || 0;
    const safeRealmProgress = Math.max(0, Math.min(100, Number(safeLevelInfo.progress) || 0));
    const safeCurrentXP = Number(safeLevelInfo.currentXP) || 0;
    const safeRequiredXP = Number(safeLevelInfo.requiredXP) || 0;
    const safeRealmName = safeLevelInfo.realmName || 'Phàm Nhân';
    const safeSubRealmName = safeLevelInfo.subRealmName || 'Cảnh giới chưa rõ';
    const safePoints = Number(safeStats.points) || 0;
    const safeLessons = Number(safeStats.lessons) || 0;
    const safeGold = Number(safeStats.gold) || 0;
    const safeAchievementPoints = Number(safeStats.achievementPoints) || 0;
    const safeRoleLabel = safeProfileUser.isAdmin ? 'Admin' : (safeProfileUser.isTeacher ? 'Giáo viên' : 'Học sinh');
    const safeRoleIcon = safeProfileUser.isAdmin ? 'fa-user-shield' : (safeProfileUser.isTeacher ? 'fa-chalkboard-teacher' : 'fa-user-graduate');
    const safeGardenLink = isOwner ? '/my-garden' : `/my-garden/visit/${safeProfileUser._id || ''}`;
%>

<style>
    :root {
        --prof-bg: #f8fafc;
        --prof-surface: #ffffff;
        --prof-border: #e2e8f0;
        --prof-primary: #4f46e5;
        --prof-text: #0f172a;
        --prof-muted: #64748b;
        --prof-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.08);
        --radius-xl: 28px;
        --radius-lg: 20px;
    }

    body {
        background-color: var(--prof-bg);
    }

    .profile-v2-wrapper {
        max-width: 1100px;
        margin: 40px auto 80px;
        padding: 0 20px;
        font-family: 'Quicksand', sans-serif;
    }

    .prof-hero {
        background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
        border-radius: var(--radius-xl);
        padding: 40px;
        display: flex;
        align-items: center;
        gap: 30px;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(49, 46, 129, 0.2);
        margin-bottom: 30px;
    }

    .prof-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(99, 102, 241, 0.4) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    .prof-avatar-box {
        position: relative;
        width: 130px;
        height: 130px;
        flex-shrink: 0;
    }

    .prof-avatar {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid rgba(255, 255, 255, 0.2);
        background: #fff;
        position: relative;
        z-index: 2;
    }

    .prof-level-badge {
        position: absolute;
        bottom: -5px;
        left: 50%;
        transform: translateX(-50%);
        background: #f59e0b;
        color: #fff;
        padding: 4px 16px;
        border-radius: 20px;
        font-weight: 800;
        font-size: 0.85rem;
        z-index: 3;
        border: 2px solid #fff;
        box-shadow: 0 4px 10px rgba(245, 158, 11, 0.4);
        white-space: nowrap;
    }

    .prof-info {
        flex: 1;
        z-index: 2;
        min-width: 0;
    }

    .prof-name {
        font-size: 2.2rem;
        font-weight: 900;
        margin: 0 0 5px;
        letter-spacing: -0.5px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .prof-tags {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
        flex-wrap: wrap;
    }

    .p-tag {
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 700;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
    }

    .p-tag.pro {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: #fff;
    }

    .p-tag.role {
        background: rgba(99, 102, 241, 0.3);
        color: #e0e7ff;
    }

    .prof-bio {
        font-size: 1rem;
        opacity: 0.85;
        line-height: 1.6;
        max-width: 600px;
        margin: 0;
    }

    .prof-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
        z-index: 2;
    }

    .btn-prof {
        padding: 10px 20px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.9rem;
        text-decoration: none;
        text-align: center;
        transition: 0.2s;
        cursor: pointer;
        border: none;
    }

    .btn-prof.edit {
        background: white;
        color: var(--prof-primary);
    }

    .btn-prof.edit:hover {
        background: #f1f5f9;
        transform: translateY(-2px);
    }

    .btn-prof.logout {
        background: rgba(239, 68, 68, 0.1);
        color: #fca5a5;
    }

    .btn-prof.logout:hover {
        background: #ef4444;
        color: white;
    }

    .prof-tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 30px;
        background: white;
        padding: 8px;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
        overflow-x: auto;
        scrollbar-width: none;
    }

    .prof-tabs::-webkit-scrollbar {
        display: none;
    }

    .p-tab {
        flex: 1;
        padding: 12px 20px;
        border-radius: 14px;
        border: none;
        background: transparent;
        font-weight: 700;
        color: var(--prof-muted);
        cursor: pointer;
        transition: 0.3s;
        white-space: nowrap;
        font-size: 1rem;
    }

    .p-tab.active {
        background: var(--prof-primary);
        color: white;
        box-shadow: 0 8px 20px rgba(79, 70, 229, 0.25);
    }

    .tab-content {
        display: none;
        animation: fadeIn 0.4s ease;
    }

    .tab-content.active {
        display: block;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .bento-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: minmax(140px, auto);
        gap: 20px;
    }

    .bento-card {
        background: var(--prof-surface);
        border-radius: var(--radius-lg);
        border: 1px solid var(--prof-border);
        padding: 24px;
        box-shadow: var(--prof-shadow);
        display: flex;
        flex-direction: column;
        justify-content: center;
        transition: 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .bento-card:hover {
        transform: translateY(-5px);
        border-color: #cbd5e1;
        box-shadow: 0 15px 35px -10px rgba(0, 0, 0, 0.1);
    }

    .span-2 {
        grid-column: span 2;
    }

    .span-4 {
        grid-column: span 4;
    }

    .realm-card {
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
        border-color: #86efac;
        color: #166534;
    }

    .realm-icon {
        font-size: 2.5rem;
        margin-bottom: 10px;
        opacity: 0.8;
    }

    .realm-name {
        font-size: 1.8rem;
        font-weight: 900;
        margin: 0 0 5px;
        line-height: 1.2;
    }

    .realm-sub {
        font-size: 0.9rem;
        font-weight: 700;
        opacity: 0.8;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .realm-progress-wrap {
        margin-top: 15px;
        width: 100%;
        background: rgba(255, 255, 255, 0.5);
        height: 8px;
        border-radius: 10px;
        overflow: hidden;
    }

    .realm-progress-fill {
        height: 100%;
        background: #16a34a;
        border-radius: 10px;
        transition: width 1s ease-out;
    }

    .realm-xp-text {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        font-size: 0.8rem;
        margin-top: 5px;
        font-weight: 700;
    }

    .stat-icon {
        font-size: 2rem;
        margin-bottom: 10px;
    }

    .stat-val {
        font-size: 2rem;
        font-weight: 900;
        color: var(--prof-text);
        line-height: 1;
        margin-bottom: 5px;
        font-family: 'Consolas', monospace;
    }

    .stat-lbl {
        font-size: 0.9rem;
        color: var(--prof-muted);
        font-weight: 600;
    }

    .link-card {
        text-decoration: none;
        color: inherit;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(135deg, #fffbeb, #fef3c7);
        border-color: #fde68a;
    }

    .link-card.guild {
        background: linear-gradient(135deg, #faf5ff, #f3e8ff);
        border-color: #e9d5ff;
    }

    .lc-content {
        min-width: 0;
    }

    .lc-content h3 {
        font-size: 1.2rem;
        font-weight: 800;
        margin: 0 0 5px;
        color: #1e293b;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .lc-content p {
        margin: 0;
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 600;
    }

    .lc-icon {
        width: 45px;
        height: 45px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        transition: 0.3s;
        flex-shrink: 0;
    }

    .link-card:hover .lc-icon {
        transform: scale(1.1) translateX(3px);
    }

    .empty-msg {
        text-align: center;
        padding: 40px;
        color: #94a3b8;
        font-weight: 600;
        background: white;
        border-radius: 20px;
        border: 1px dashed #cbd5e1;
    }

    .empty-msg i {
        font-size: 3rem;
        margin-bottom: 15px;
        opacity: 0.5;
        display: block;
    }

    .act-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .act-item {
        background: white;
        padding: 20px;
        border-radius: 20px;
        border: 1px solid var(--prof-border);
        display: flex;
        align-items: center;
        gap: 15px;
        transition: 0.2s;
    }

    .act-item:hover {
        border-color: var(--prof-primary);
        transform: translateX(5px);
    }

    .act-icon {
        width: 50px;
        height: 50px;
        background: #eff6ff;
        color: #3b82f6;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .act-info h4 {
        margin: 0 0 5px;
        font-size: 1.1rem;
        color: var(--prof-text);
        font-weight: 700;
    }

    .act-info p {
        margin: 0;
        font-size: 0.85rem;
        color: var(--prof-muted);
    }

    .ach-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 15px;
    }

    .ach-item {
        background: white;
        padding: 20px;
        border-radius: 20px;
        border: 1px solid var(--prof-border);
        text-align: center;
        transition: 0.3s;
    }

    .ach-item:hover {
        border-color: #f59e0b;
        box-shadow: 0 10px 20px rgba(245, 158, 11, 0.1);
        transform: translateY(-5px);
    }

    .ach-icon {
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .ach-name {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--prof-text);
        line-height: 1.3;
    }

    @media (max-width: 900px) {
        .bento-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .span-4 {
            grid-column: span 2;
        }
    }

    @media (max-width: 600px) {
        .prof-hero {
            flex-direction: column;
            text-align: center;
            padding: 30px 20px;
        }

        .prof-tags {
            justify-content: center;
        }

        .prof-actions {
            flex-direction: row;
            width: 100%;
        }

        .btn-prof {
            flex: 1;
        }

        .bento-grid {
            grid-template-columns: 1fr;
        }

        .span-2,
        .span-4 {
            grid-column: span 1;
        }

        .ach-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

<div class="profile-v2-wrapper">
    <div class="prof-hero">
        <div class="prof-avatar-box">
            <img src="<%= safeAvatar %>" class="prof-avatar" alt="Avatar">
            <div class="prof-level-badge">Lv.<%= safeLevel %></div>
        </div>

        <div class="prof-info">
            <h1 class="prof-name"><%= safeUsername %></h1>
            <div class="prof-tags">
                <% if (safeProfileUser.isPro) { %>
                    <span class="p-tag pro"><i class="fas fa-crown"></i> PRO Member</span>
                <% } %>
                <span class="p-tag role">
                    <i class="fas <%= safeRoleIcon %>"></i>
                    <%= safeRoleLabel %>
                </span>
                <span class="p-tag role" style="background: rgba(16, 185, 129, 0.3); color: #d1fae5;">
                    <%= safeClass %> • <%= safeSchool %>
                </span>
            </div>
            <p class="prof-bio"><%= safeBio %></p>
        </div>

        <% if (isOwner) { %>
            <div class="prof-actions">
                <a href="/profile/edit" class="btn-prof edit"><i class="fas fa-pen"></i> Chỉnh sửa</a>
                <a href="/logout" class="btn-prof logout"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
            </div>
        <% } %>
    </div>

    <div class="prof-tabs">
        <button class="p-tab active" type="button" onclick="switchTab(event, 'overview')"><i class="fas fa-th-large"></i> Tổng quan</button>
        <button class="p-tab" type="button" onclick="switchTab(event, 'activity')"><i class="fas fa-bolt"></i> Hoạt động</button>
        <button class="p-tab" type="button" onclick="switchTab(event, 'achievements')"><i class="fas fa-medal"></i> Thành tích</button>
    </div>

    <div id="tab-overview" class="tab-content active">
        <div class="bento-grid">
            <div class="bento-card realm-card span-2">
                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                    <div>
                        <div class="realm-sub"><%= safeSubRealmName %></div>
                        <h2 class="realm-name"><%= safeRealmName %></h2>
                    </div>
                    <div class="realm-icon">☯️</div>
                </div>
                <div class="realm-progress-wrap">
                    <div class="realm-progress-fill" style="width: <%= safeRealmProgress %>%;"></div>
                </div>
                <div class="realm-xp-text">
                    <span>Linh Khí</span>
                    <span><%= safeCurrentXP.toLocaleString('vi-VN') %> / <%= safeRequiredXP.toLocaleString('vi-VN') %></span>
                </div>
            </div>

            <div class="bento-card">
                <div class="stat-icon">🏆</div>
                <div class="stat-val">#<%= safeUserRank %></div>
                <div class="stat-lbl">Xếp hạng Server</div>
            </div>

            <div class="bento-card">
                <div class="stat-icon">🔥</div>
                <div class="stat-val"><%= safeStreak %></div>
                <div class="stat-lbl">Chuỗi ngày học</div>
            </div>

            <div class="bento-card">
                <div class="stat-icon">⚡</div>
                <div class="stat-val"><%= safePoints.toLocaleString('vi-VN') %></div>
                <div class="stat-lbl">Điểm cống hiến</div>
            </div>

            <div class="bento-card">
                <div class="stat-icon">📚</div>
                <div class="stat-val"><%= safeLessons %></div>
                <div class="stat-lbl">Bài đã hoàn thành</div>
            </div>

            <div class="bento-card">
                <div class="stat-icon">🪙</div>
                <div class="stat-val"><%= safeGold.toLocaleString('vi-VN') %></div>
                <div class="stat-lbl">Vàng nông trại</div>
            </div>

            <div class="bento-card">
                <div class="stat-icon">⭐</div>
                <div class="stat-val"><%= safeAchievementPoints.toLocaleString('vi-VN') %></div>
                <div class="stat-lbl">Điểm thành tích</div>
            </div>

            <a href="<%= safeGardenLink %>" class="bento-card link-card span-2">
                <div class="lc-content">
                    <h3><%= isOwner ? 'Về Nông Trại' : 'Ghé thăm Vườn' %> 🌱</h3>
                    <p>Trồng cây, thu thập tài nguyên và nhận buff học tập.</p>
                </div>
                <div class="lc-icon"><i class="fas fa-arrow-right" style="color: #d97706;"></i></div>
            </a>

            <% if (safeGuildProfile) { %>
                <a href="/guilds/<%= safeGuildProfile.slug %>" class="bento-card link-card guild span-2">
                    <div class="lc-content">
                        <h3>Tông Môn: <%= safeGuildProfile.name || 'Bang hội bí ẩn' %> 🏰</h3>
                        <p>Linh Thụ Giai Đoạn <%= safeGuildProfile.treeStage || 0 %> • Buff +<%= safeGuildProfile.buffSnapshot?.lessonXpPct || 0 %>% XP</p>
                    </div>
                    <div class="lc-icon"><i class="fas fa-arrow-right" style="color: #9333ea;"></i></div>
                </a>
            <% } else { %>
                <a href="/guilds" class="bento-card link-card guild span-2">
                    <div class="lc-content">
                        <h3>Tông Môn / Bang Hội 🏰</h3>
                        <p>Bạn chưa gia nhập. Tìm bang hội để nhận buff chung ngay!</p>
                    </div>
                    <div class="lc-icon"><i class="fas fa-search" style="color: #9333ea;"></i></div>
                </a>
            <% } %>
        </div>
    </div>

    <div id="tab-activity" class="tab-content">
        <div class="act-list">
            <% if (safeActivities.length > 0) { %>
                <% safeActivities.forEach((act) => { %>
                    <div class="act-item">
                        <div class="act-icon"><i class="fas fa-check"></i></div>
                        <div class="act-info">
                            <h4>Đã hoàn thành: <%= act.lessonId ? act.lessonId.title : 'Bài học đã bị xóa' %></h4>
                            <p><i class="far fa-clock"></i> <%= moment(act.completedAt).locale('vi').fromNow() %></p>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="empty-msg">
                    <i class="fas fa-history"></i>
                    Chưa có hoạt động học tập nào gần đây.
                </div>
            <% } %>
        </div>
    </div>

    <div id="tab-achievements" class="tab-content">
        <div class="ach-grid">
            <% if (safeAchievements.length > 0) { %>
                <% safeAchievements.forEach((ach) => { %>
                    <div class="ach-item" title="<%= ach.achievementId?.description || 'Thành tích' %>">
                        <div class="ach-icon"><%= ach.achievementId?.icon || '🏆' %></div>
                        <div class="ach-name"><%= ach.achievementId?.name || 'Thành tích bí ẩn' %></div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="empty-msg" style="grid-column: 1/-1;">
                    <i class="fas fa-medal"></i>
                    Bộ sưu tập thành tích đang trống. Hãy bắt đầu cày cuốc nào!
                </div>
            <% } %>
        </div>

        <div style="text-align: center; margin-top: 30px;">
            <a href="/achievements" class="btn-prof edit" style="display: inline-block; background: white; border: 2px solid var(--prof-border);">
                Xem toàn bộ kho thành tích
            </a>
        </div>
    </div>
</div>

<script>
    function switchTab(event, tabId) {
        document.querySelectorAll('.p-tab').forEach((tab) => tab.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach((content) => content.classList.remove('active'));

        if (event && event.currentTarget) {
            event.currentTarget.classList.add('active');
        }

        const target = document.getElementById('tab-' + tabId);
        if (target) {
            target.classList.add('active');
        }
    }
</script>

<%- include('partials/footer') %>
