<%- include('partials/header') %>

<%
    const safeProfileUser = profileUser || {};
    const safeLevelInfo = levelInfo || {};
    const safeStats = stats || {};
    const safeGuildProfile = guildProfile || null;
    const safeActivities = Array.isArray(activities) ? activities : [];
    const safeAchievements = Array.isArray(achievements) ? achievements : [];
    const safeUserRank = Number(userRank) || 0;
    const safeStreak = Number(streak) || 0;
    const safeTotalAchievements = Number(totalAchievements) || 0;
    const safeAvatar = safeProfileUser.avatar || `https://static.vecteezy.com/system/resources/previews/013/360/247/non_2x/default-avatar-photo-icon-social-media-profile-sign-symbol-vector.jpg`;
    const safeUsername = safeProfileUser.username || 'Đạo hữu bí ẩn';
    const safeBio = safeProfileUser.bio || 'Người chơi hệ bí ẩn, chưa để lại lời giới thiệu nào...';
    const safeSchool = safeProfileUser.school || 'THPT';
    const safeClass = safeProfileUser.class || 'Chưa cập nhật lớp';
    const safeLevel = Number(safeLevelInfo.level) || 0;
    const safeRealmProgress = Math.max(0, Math.min(100, Number(safeLevelInfo.progress) || 0));
    const safeCurrentXP = Number(safeLevelInfo.currentXP) || 0;
    const safeRequiredXP = Number(safeLevelInfo.requiredXP) || 0;
    const safeRealmName = safeLevelInfo.realmName || 'Phàm Nhân';
    const safeSubRealmName = safeLevelInfo.subRealmName || 'Cảnh giới chưa rõ';
    const safePoints = Number(safeStats.points) || 0;
    const safeLessons = Number(safeStats.lessons) || 0;
    const safeGold = Number(safeStats.gold) || 0;
    const safeAchievementPoints = Number(safeStats.achievementPoints) || 0;
    const safeRoleLabel = safeProfileUser.isAdmin ? 'Admin' : (safeProfileUser.isTeacher ? 'Giáo viên' : 'Học sinh');
    const safeRoleIcon = safeProfileUser.isAdmin ? 'fa-user-shield' : (safeProfileUser.isTeacher ? 'fa-chalkboard-teacher' : 'fa-user-graduate');
    const safeGardenLink = isOwner ? '/my-garden' : `/my-garden/visit/${safeProfileUser._id || ''}`;
%>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    :root {
        --cv-bg: #f3f4f6; /* Subtle light gray */
        --cv-surface: #ffffff;
        --cv-surface-alt: #f8fafc;
        --cv-border: #e2e8f0;
        --cv-primary: #3b82f6; /* Modern Blue */
        --cv-primary-dark: #2563eb;
        --cv-text-main: #0f172a;
        --cv-text-muted: #64748b;
        --cv-shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
        --cv-shadow-md: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
        --cv-shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.05), 0 4px 6px -2px rgba(0,0,0,0.02);
        --cv-radius: 16px;
        --cv-font: 'Inter', sans-serif;
    }

    body {
        background-color: var(--cv-bg);
        font-family: var(--cv-font);
    }

    .cv-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 30px;
        align-items: start;
    }

    /* SIDEBAR */
    .cv-sidebar {
        background: var(--cv-surface);
        border-radius: var(--cv-radius);
        padding: 30px;
        box-shadow: var(--cv-shadow-lg);
        position: sticky;
        top: 20px;
        border: 1px solid rgba(255, 255, 255, 0.5);
    }

    .cv-avatar-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-bottom: 25px;
        position: relative;
    }

    .cv-avatar-inner {
        position: relative;
        width: 140px;
        height: 140px;
        margin-bottom: 15px;
    }

    .cv-avatar {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid var(--cv-surface);
        box-shadow: var(--cv-shadow-md);
        background: var(--cv-surface-alt);
    }

    .cv-level-badge {
        position: absolute;
        bottom: 0;
        right: 0;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: white;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.9rem;
        border: 3px solid var(--cv-surface);
        box-shadow: var(--cv-shadow-sm);
    }

    .cv-name {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--cv-text-main);
        margin: 0 0 5px;
        line-height: 1.2;
    }

    .cv-role {
        font-size: 0.95rem;
        color: var(--cv-primary);
        font-weight: 600;
        margin: 0 0 15px;
    }

    .cv-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;
        margin-bottom: 20px;
    }

    .cv-tag {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
        background: var(--cv-surface-alt);
        color: var(--cv-text-muted);
        border: 1px solid var(--cv-border);
    }

    .cv-tag.pro {
        background: #fffbeb;
        color: #d97706;
        border-color: #fde68a;
    }

    .cv-bio {
        font-size: 0.9rem;
        color: var(--cv-text-muted);
        line-height: 1.6;
        text-align: center;
        margin: 0 0 25px;
        padding-bottom: 25px;
        border-bottom: 1px dashed var(--cv-border);
    }

    .cv-info-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-bottom: 25px;
    }

    .cv-info-item {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .cv-info-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: var(--cv-surface-alt);
        color: var(--cv-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
    }

    .cv-info-text {
        font-size: 0.9rem;
        color: var(--cv-text-main);
        font-weight: 500;
    }

    .cv-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .cv-btn {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.9rem;
        text-align: center;
        text-decoration: none;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .cv-btn-primary {
        background: var(--cv-primary);
        color: white;
        box-shadow: 0 4px 10px rgba(59, 130, 246, 0.3);
    }

    .cv-btn-primary:hover {
        background: var(--cv-primary-dark);
        transform: translateY(-2px);
    }

    .cv-btn-outline {
        background: white;
        color: #ef4444;
        border: 1px solid #fca5a5;
    }

    .cv-btn-outline:hover {
        background: #fef2f2;
    }

    /* MAIN CONTENT */
    .cv-main {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .cv-tabs-nav {
        display: flex;
        gap: 10px;
        background: var(--cv-surface);
        padding: 10px;
        border-radius: var(--cv-radius);
        box-shadow: var(--cv-shadow-sm);
        overflow-x: auto;
    }

    .cv-tab-btn {
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--cv-text-muted);
        background: transparent;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .cv-tab-btn:hover {
        color: var(--cv-text-main);
        background: var(--cv-surface-alt);
    }

    .cv-tab-btn.active {
        background: var(--cv-primary);
        color: white;
        box-shadow: 0 4px 10px rgba(59, 130, 246, 0.2);
    }

    .cv-tab-content {
        display: none;
        animation: fadeUp 0.4s ease;
    }

    .cv-tab-content.active {
        display: block;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .cv-section {
        background: var(--cv-surface);
        border-radius: var(--cv-radius);
        padding: 30px;
        box-shadow: var(--cv-shadow-md);
        margin-bottom: 20px;
    }

    .cv-section-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--cv-text-main);
        margin: 0 0 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .cv-section-title::before {
        content: '';
        display: block;
        width: 4px;
        height: 20px;
        background: var(--cv-primary);
        border-radius: 4px;
    }

    /* Overview Styles */
    .cv-realm-card {
        background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
        border: 1px solid #bbf7d0;
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .cv-realm-icon {
        width: 70px;
        height: 70px;
        background: white;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        box-shadow: var(--cv-shadow-sm);
        flex-shrink: 0;
    }

    .cv-realm-info {
        flex: 1;
    }

    .cv-realm-sub {
        font-size: 0.85rem;
        font-weight: 700;
        color: #166534;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 5px;
    }

    .cv-realm-name {
        font-size: 1.5rem;
        font-weight: 800;
        color: #14532d;
        margin: 0 0 15px;
    }

    .cv-progress-track {
        height: 8px;
        background: rgba(255,255,255,0.7);
        border-radius: 4px;
        overflow: hidden;
        margin-bottom: 8px;
    }

    .cv-progress-fill {
        height: 100%;
        background: #16a34a;
        border-radius: 4px;
        transition: width 1s ease-in-out;
    }

    .cv-progress-text {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        font-weight: 600;
        color: #166534;
    }

    .cv-stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin-bottom: 25px;
    }

    .cv-stat-box {
        background: var(--cv-surface-alt);
        border: 1px solid var(--cv-border);
        border-radius: 12px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        transition: transform 0.2s;
    }

    .cv-stat-box:hover {
        transform: translateY(-3px);
        border-color: #cbd5e1;
        box-shadow: var(--cv-shadow-sm);
    }

    .cv-stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 12px;
    }

    .cv-stat-val {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--cv-text-main);
        margin: 0 0 4px;
        font-family: 'Consolas', monospace;
    }

    .cv-stat-lbl {
        font-size: 0.85rem;
        color: var(--cv-text-muted);
        font-weight: 500;
    }

    /* Links / Experiences */
    .cv-experience-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .cv-exp-card {
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 20px;
        border-radius: 12px;
        border: 1px solid var(--cv-border);
        transition: all 0.2s;
    }

    .cv-exp-card.garden {
        background: linear-gradient(to right, #fffbeb, #fef3c7);
        border-color: #fde68a;
    }

    .cv-exp-card.guild {
        background: linear-gradient(to right, #faf5ff, #f3e8ff);
        border-color: #e9d5ff;
    }

    .cv-exp-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--cv-shadow-md);
    }

    .cv-exp-icon {
        width: 50px;
        height: 50px;
        background: white;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .cv-exp-info h4 {
        font-size: 1rem;
        font-weight: 700;
        color: var(--cv-text-main);
        margin: 0 0 5px;
    }

    .cv-exp-info p {
        font-size: 0.8rem;
        color: var(--cv-text-muted);
        margin: 0;
        font-weight: 500;
        line-height: 1.4;
    }

    /* Timeline (Activity) */
    .cv-timeline {
        position: relative;
        padding-left: 30px;
    }

    .cv-timeline::before {
        content: '';
        position: absolute;
        left: 7px;
        top: 5px;
        bottom: 0;
        width: 2px;
        background: var(--cv-border);
    }

    .cv-tl-item {
        position: relative;
        margin-bottom: 25px;
    }

    .cv-tl-item:last-child {
        margin-bottom: 0;
    }

    .cv-tl-dot {
        position: absolute;
        left: -30px;
        top: 5px;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: white;
        border: 3px solid var(--cv-primary);
        z-index: 1;
    }

    .cv-tl-content {
        background: var(--cv-surface-alt);
        border: 1px solid var(--cv-border);
        border-radius: 12px;
        padding: 15px 20px;
    }

    .cv-tl-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--cv-text-main);
        margin: 0 0 5px;
    }

    .cv-tl-time {
        font-size: 0.8rem;
        color: var(--cv-text-muted);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    /* Achievements Grid */
    .cv-achieve-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 15px;
    }

    .cv-achieve-item {
        background: var(--cv-surface-alt);
        border: 1px solid var(--cv-border);
        border-radius: 12px;
        padding: 20px 15px;
        text-align: center;
        transition: transform 0.2s;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .cv-achieve-item:hover {
        transform: translateY(-5px);
        border-color: #f59e0b;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.15);
    }

    .cv-achieve-icon {
        font-size: 2.2rem;
    }

    .cv-achieve-name {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--cv-text-main);
        line-height: 1.3;
    }

    /* Responsive */
    @media (max-width: 992px) {
        .cv-container {
            grid-template-columns: 1fr;
        }
        
        .cv-sidebar {
            position: relative;
            top: 0;
        }
    }

    @media (max-width: 768px) {
        .cv-stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .cv-experience-grid {
            grid-template-columns: 1fr;
        }

        .cv-realm-card {
            flex-direction: column;
            text-align: center;
            gap: 15px;
        }

        .cv-progress-track {
            width: 100%;
        }
    }

    @media (max-width: 480px) {
        .cv-stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="cv-container">
    <!-- SIDEBAR (Personal Info) -->
    <div class="cv-sidebar">
        <div class="cv-avatar-wrap">
            <div class="cv-avatar-inner">
                <img src="<%= safeAvatar %>" class="cv-avatar" alt="Avatar">
                <div class="cv-level-badge"><%= safeLevel %></div>
            </div>
            <h1 class="cv-name"><%= safeUsername %></h1>
            <div class="cv-role"><%= safeRoleLabel %></div>
            <div class="cv-tags">
                <% if (safeProfileUser.isPro) { %>
                    <span class="cv-tag pro"><i class="fas fa-crown"></i> PRO</span>
                <% } %>
                <span class="cv-tag"><%= safeClass %></span>
                <span class="cv-tag"><%= safeSchool %></span>
            </div>
            <p class="cv-bio"><%= safeBio %></p>
        </div>

        <div class="cv-info-list">
            <div class="cv-info-item">
                <div class="cv-info-icon" style="background: #eff6ff; color: #3b82f6;"><i class="fas fa-trophy"></i></div>
                <div class="cv-info-text">Rank: #<%= safeUserRank %></div>
            </div>
            <div class="cv-info-item">
                <div class="cv-info-icon" style="background: #fef2f2; color: #ef4444;"><i class="fas fa-fire"></i></div>
                <div class="cv-info-text">Chuỗi: <%= safeStreak %> ngày</div>
            </div>
            <div class="cv-info-item">
                <div class="cv-info-icon" style="background: #fffbeb; color: #f59e0b;"><i class="fas fa-coins"></i></div>
                <div class="cv-info-text">Vàng: <%= safeGold.toLocaleString('vi-VN') %></div>
            </div>
        </div>

        <% if (isOwner) { %>
            <div class="cv-actions">
                <a href="/profile/edit" class="cv-btn cv-btn-primary"><i class="fas fa-user-edit"></i> Chỉnh sửa hồ sơ</a>
                <a href="/logout" class="cv-btn cv-btn-outline"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
            </div>
        <% } %>
    </div>

    <!-- MAIN CONTENT -->
    <div class="cv-main">
        <nav class="cv-tabs-nav">
            <button class="cv-tab-btn active" type="button" onclick="switchCvTab(event, 'overview')">
                <i class="fas fa-id-card"></i> Hồ sơ chuyên môn
            </button>
            <button class="cv-tab-btn" type="button" onclick="switchCvTab(event, 'activity')">
                <i class="fas fa-history"></i> Lịch sử hoạt động
            </button>
            <button class="cv-tab-btn" type="button" onclick="switchCvTab(event, 'achievements')">
                <i class="fas fa-award"></i> Chứng nhận & Giải thưởng
            </button>
        </nav>

        <!-- Overview Tab -->
        <div id="cv-tab-overview" class="cv-tab-content active">
            
            <div class="cv-section">
                <h2 class="cv-section-title">Trạng thái Cảnh Giới</h2>
                <div class="cv-realm-card">
                    <div class="cv-realm-icon">☯️</div>
                    <div class="cv-realm-info">
                        <div class="cv-realm-sub"><%= safeSubRealmName %></div>
                        <h3 class="cv-realm-name"><%= safeRealmName %></h3>
                        <div class="cv-progress-track">
                            <div class="cv-progress-fill" style="width: <%= safeRealmProgress %>%;"></div>
                        </div>
                        <div class="cv-progress-text">
                            <span>Tiến độ tu luyện</span>
                            <span><%= safeCurrentXP.toLocaleString('vi-VN') %> / <%= safeRequiredXP.toLocaleString('vi-VN') %> XP</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="cv-section">
                <h2 class="cv-section-title">Chỉ số thành tích</h2>
                <div class="cv-stats-grid">
                    <div class="cv-stat-box">
                        <div class="cv-stat-icon" style="background: #f0fdf4; color: #16a34a;"><i class="fas fa-bolt"></i></div>
                        <div class="cv-stat-val"><%= safePoints.toLocaleString('vi-VN') %></div>
                        <div class="cv-stat-lbl">Điểm cống hiến</div>
                    </div>
                    <div class="cv-stat-box">
                        <div class="cv-stat-icon" style="background: #eff6ff; color: #3b82f6;"><i class="fas fa-book-reader"></i></div>
                        <div class="cv-stat-val"><%= safeLessons %></div>
                        <div class="cv-stat-lbl">Bài đã học</div>
                    </div>
                    <div class="cv-stat-box">
                        <div class="cv-stat-icon" style="background: #fdf2f8; color: #db2777;"><i class="fas fa-star"></i></div>
                        <div class="cv-stat-val"><%= safeAchievementPoints.toLocaleString('vi-VN') %></div>
                        <div class="cv-stat-lbl">Điểm danh hiệu</div>
                    </div>
                </div>
            </div>

            <div class="cv-section">
                <h2 class="cv-section-title">Tổ chức & Hoạt động ngoại khóa</h2>
                <div class="cv-experience-grid">
                    <a href="<%= safeGardenLink %>" class="cv-exp-card garden">
                        <div class="cv-exp-icon">🌱</div>
                        <div class="cv-exp-info">
                            <h4><%= isOwner ? 'Nông Trại Cá Nhân' : 'Vườn Của Đạo Hữu' %></h4>
                            <p>Khu vực trồng cây và thu thập tài nguyên phụ trợ.</p>
                        </div>
                    </a>

                    <% if (safeGuildProfile) { %>
                        <a href="/guilds/<%= safeGuildProfile.slug %>" class="cv-exp-card guild">
                            <div class="cv-exp-icon">🏰</div>
                            <div class="cv-exp-info">
                                <h4><%= safeGuildProfile.name || 'Bang hội' %></h4>
                                <p>Linh thụ cấp <%= safeGuildProfile.treeStage || 0 %> • +<%= safeGuildProfile.buffSnapshot?.lessonXpPct || 0 %>% XP</p>
                            </div>
                        </a>
                    <% } else { %>
                        <a href="/guilds" class="cv-exp-card guild">
                            <div class="cv-exp-icon">🔍</div>
                            <div class="cv-exp-info">
                                <h4>Chưa gia nhập Bang hội</h4>
                                <p>Tìm kiếm một tập thể để cùng nhau phát triển.</p>
                            </div>
                        </a>
                    <% } %>
                </div>
            </div>

        </div>

        <!-- Activity Tab -->
        <div id="cv-tab-activity" class="cv-tab-content">
            <div class="cv-section">
                <h2 class="cv-section-title">Lịch trình gần đây</h2>
                
                <% if (safeActivities.length > 0) { %>
                    <div class="cv-timeline">
                        <% safeActivities.forEach((act) => { %>
                            <div class="cv-tl-item">
                                <div class="cv-tl-dot"></div>
                                <div class="cv-tl-content">
                                    <h3 class="cv-tl-title">Đã hoàn thành: <%= act.lessonId ? act.lessonId.title : 'Bài học đã bị xóa' %></h3>
                                    <div class="cv-tl-time"><i class="far fa-clock"></i> <%= moment(act.completedAt).locale('vi').fromNow() %></div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div style="text-align: center; padding: 40px 0; color: var(--cv-text-muted);">
                        <i class="fas fa-history" style="font-size: 3rem; opacity: 0.2; margin-bottom: 15px; display: block;"></i>
                        <p>Chưa có dữ liệu hoạt động.</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Achievements Tab -->
        <div id="cv-tab-achievements" class="cv-tab-content">
            <div class="cv-section">
                <h2 class="cv-section-title">Bộ sưu tập Danh Hiệu</h2>
                
                <% if (safeAchievements.length > 0) { %>
                    <div class="cv-achieve-grid">
                        <% safeAchievements.forEach((ach) => { %>
                            <div class="cv-achieve-item" title="<%= ach.achievementId?.description || 'Thành tích' %>">
                                <div class="cv-achieve-icon"><%= ach.achievementId?.icon || '🏆' %></div>
                                <div class="cv-achieve-name"><%= ach.achievementId?.name || 'Thành tích bí ẩn' %></div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div style="text-align: center; padding: 40px 0; color: var(--cv-text-muted);">
                        <i class="fas fa-medal" style="font-size: 3rem; opacity: 0.2; margin-bottom: 15px; display: block;"></i>
                        <p>Hồ sơ chứng nhận đang trống.</p>
                    </div>
                <% } %>
                
                <div style="margin-top: 30px; text-align: center;">
                    <a href="/achievements" class="cv-btn cv-btn-outline" style="display: inline-flex; width: auto; padding: 10px 20px;">
                        <i class="fas fa-external-link-alt"></i> Xem toàn bộ danh hiệu
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    function switchCvTab(event, tabId) {
        document.querySelectorAll('.cv-tab-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.cv-tab-content').forEach(content => content.classList.remove('active'));

        if (event && event.currentTarget) {
            event.currentTarget.classList.add('active');
        }

        const target = document.getElementById('cv-tab-' + tabId);
        if (target) {
            target.classList.add('active');
        }
    }
</script>

<%- include('partials/footer') %>
