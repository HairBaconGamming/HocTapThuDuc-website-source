<%- include('partials/header') %>

<link rel="stylesheet" href="/css/styleProfile-refactored.css">

<div class="profile-main">
    
    <!-- Hero Banner -->
    <section class="profile-hero">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="avatar-hero">
                <img src="<%= profileUser.avatar || 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>" alt="Avatar">
                <div class="realm-glow-ring"></div>
                <div class="level-badge-hero">Lv.<%= levelInfo.level %></div>
            </div>
            <div class="hero-info">
                <h1 class="user-name-hero"><%= profileUser.username %></h1>
                <% if (profileUser.bio) { %>
                    <p class="user-bio-hero"><%= profileUser.bio %></p>
                <% } %>
                <% if (isOwner) { %>
                    <div class="action-buttons-hero">
                        <a href="/profile/edit" class="btn-modern btn-primary">
                            <i class="fas fa-pen"></i> Edit Profile
                        </a>
                        <a href="/logout" class="btn-modern btn-secondary">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Sticky Tabs -->
    <nav class="profile-tabs">
        <button class="tab-btn active" data-tab="overview">📊 Overview</button>
        <button class="tab-btn" data-tab="achievements">🏆 Achievements</button>
        <button class="tab-btn" data-tab="activity">📈 Activity</button>
    </nav>

    <!-- Tab Contents -->
    <div class="tab-content active" id="overview">
        <div class="bento-grid">
            <!-- Realm Card - Tall -->
            <div class="bento-card realm-card learning-card" style="grid-row: span 2;">
                <%- include('partials/realmDisplay', { realmInfo: realmInfo, user: profileUser }) %>
            </div>

            <!-- Learning Stats -->
            <div class="bento-card learning-card">
                <div class="stat-card">
                    <div class="stat-emoji">📚</div>
                    <div class="stat-value"><%= stats.lessons.toLocaleString() %></div>
                    <div class="stat-title">Lessons</div>
                </div>
            </div>

            <div class="bento-card learning-card">
                <div class="stat-card">
                    <div class="stat-emoji">🥇</div>
                    <div class="stat-value">#<%= userRank %></div>
                    <div class="stat-title">Global Rank</div>
                </div>
            </div>

            <!-- Garden Stats -->
            <div class="bento-card garden-card">
                <div class="stat-card">
                    <div class="stat-emoji">💰</div>
                    <div class="stat-value"><%= stats.gold.toLocaleString() %></div>
                    <div class="stat-title">Gold</div>
                </div>
            </div>

            <div class="bento-card garden-card">
                <div class="stat-card">
                    <div class="stat-emoji">⭐</div>
                    <div class="stat-value"><%= streak %></div>
                    <div class="stat-title">Streak</div>
                </div>
            </div>

            <!-- Quick Links -->
            <div class="bento-card garden-card">
                <div style="text-align: center;">
                    <a href="<%= isOwner ? '/my-garden' : '/my-garden/visit/' + profileUser._id %>" 
                       style="display: block; padding: 20px; font-size: 1.1rem; font-weight: 700; color: var(--garden-text); text-decoration: none;">
                        🌱 <%= isOwner ? 'My Garden' : 'Visit Garden' %>
                    </a>
                </div>
            </div>

            <% if (guildProfile) { %>
            <div class="bento-card learning-card">
                <div style="text-align: center;">
                    <a href="/guilds/<%= guildProfile.slug %>" 
                       style="display: block; padding: 20px; font-size: 1.1rem; font-weight: 700; color: var(--learning-text); text-decoration: none;">
                        👥 <%= guildProfile.name %> (Stage <%= guildProfile.treeStage || 0 %>)
                    </a>
                </div>
            </div>
            <% } %>
        </div>
    </div>

    <!-- Achievements Tab -->
    <div class="tab-content" id="achievements">
        <div class="achievements-grid">
            <% if (achievements && achievements.length > 0) { %>
                <% achievements.forEach((achievement, index) => { %>
                    <div class="achievement-badge" style="animation-delay: <%= index * 0.1 %>s">
                        <div class="achievement-icon"><%= achievement.achievementId?.icon || '🎖️' %></div>
                        <div class="achievement-name">
                            <%= (achievement.achievementId?.name || 'Achievement').substring(0, 20) %>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 60px 20px; color: #94a3b8;">
                    <div style="font-size: 4rem; margin-bottom: 20px;">🏆</div>
                    <h3>No achievements yet</h3>
                    <p>Keep learning to unlock epic badges!</p>
                </div>
            <% } %>
            <% if (totalAchievements > 6) { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 20px;">
                    <a href="/achievements" class="btn-modern btn-primary" style="display: inline-block;">View All Achievements</a>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Activity Tab -->
    <div class="tab-content" id="activity">
        <div class="activity-list">
            <% if (activities && activities.length > 0) { %>
                <% activities.forEach(activity => { %>
                    <div class="activity-item">
                        <div class="activity-icon">📚</div>
                        <div class="activity-details">
                            <h4>Completed: <%= activity.lessonId?.title?.substring(0, 40) || 'Lesson' %>...</h4>
                            <div class="activity-time"><%= moment(activity.completedAt).fromNow() %></div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div style="text-align: center; padding: 80px 40px; color: #94a3b8;">
                    <div style="font-size: 3.5rem; margin-bottom: 20px;">📈</div>
                    <h3>No recent activity</h3>
                    <p>Your learning journey will appear here!</p>
                </div>
            <% } %>
        </div>
    </div>
        
        <div class="bento-card identity-card">
            <div class="avatar-wrapper">
                <img src="<%= profileUser.avatar || 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>" class="avatar-img" alt="Avatar">
                <div class="level-badge">Lv.<%= levelInfo.level %></div>
            </div>
            
            <h1 class="user-name"><%= profileUser.username %></h1>
            
            <span class="user-role">
                <%= isOwner ? 'Chủ nhân 🏠' : 'Khách ghé thăm 👋' %>
            </span>

            <div class="bio-box">
                <%= profileUser.bio || "Chưa có lời giới thiệu nào. Một người bí ẩn..." %>
            </div>

            <% if (isOwner) { %>
            <div class="action-buttons">
                <a href="/profile/edit" class="btn-chill btn-edit">
                    <i class="fas fa-pen"></i> Sửa
                </a>
                <a href="/logout" class="btn-chill btn-logout">
                    <i class="fas fa-sign-out-alt"></i> Thoát
                </a>
            </div>
            <% } %>
        </div>

        <div class="bento-card realm-card-wrapper" style="padding: 0; background: transparent; border: none; box-shadow: none; overflow: visible;">
            <%- include('partials/realmDisplay', { realmInfo: realmInfo, user: profileUser }) %>
        </div>

        <div class="stats-container">
            <div class="mini-stat gold">
                <div class="stat-emoji">💰</div>
                <div class="stat-num"><%= stats.gold.toLocaleString() %></div>
                <div class="stat-title">Vàng</div>
            </div>
            <div class="mini-stat points">
                <div class="stat-emoji">🍀</div>
                <div class="stat-num"><%= stats.points.toLocaleString() %></div>
                <div class="stat-title">Điểm</div>
            </div>
            <div class="mini-stat lessons">
                <div class="stat-emoji">📚</div>
                <div class="stat-num"><%= stats.lessons %></div>
                <div class="stat-title">Bài học</div>
            </div>
        </div>

        <a href="<%= isOwner ? '/my-garden' : '/my-garden/visit/' + profileUser._id %>" class="bento-card garden-link-card">
            <div class="garden-content">
                <div><%= isOwner ? 'Về Nông Trại' : 'Ghé thăm Vườn' %></div>
                <div style="font-size: 0.9rem; opacity: 0.8; margin-top: 5px;">Trồng cây, nuôi cá, chill... 🌱</div>
            </div>
            <div class="garden-arrow">➔</div>
        </a>

        <% if (guildProfile) { %>
        <a href="/guilds/<%= guildProfile.slug %>" class="bento-card garden-link-card" style="background: linear-gradient(135deg, #ede9fe, #eff6ff);">
            <div class="garden-content">
                <div>Tông Môn: <strong><%= guildProfile.name %></strong></div>
                <div style="font-size: 0.9rem; opacity: 0.8; margin-top: 5px;">Linh Thụ Stage <%= guildProfile.treeStage || 0 %> · +<%= guildProfile.buffSnapshot?.lessonXpPct || 0 %>% XP</div>
            </div>
            <div class="garden-arrow">✦</div>
        </a>
        <% } %>

        <div class="bento-card achievement-card">
            <div class="achievement-header">
                <span>🏆 Thành tích</span>
                <span class="achievement-count"><%= totalAchievements %> đã đạt</span>
            </div>
            
            <div class="achievement-grid">
                <% if (achievements && achievements.length > 0) { %>
                    <% achievements.forEach(achievement => { %>
                        <div class="achievement-item" title="<%= achievement.achievementId?.name || 'Thành tích' %>">
                            <div class="achievement-icon">
                                <%= achievement.achievementId?.icon || '🎖️' %>
                            </div>
                            <div class="achievement-name">
                                <%= (achievement.achievementId?.name || 'Thành tích').substring(0, 15) %>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div style="text-align:center; padding:20px; color:#94a3b8; font-style:italic; grid-column: 1/-1;">
                        "Chưa có thành tích nào. Hãy bắt đầu học tập!" 🌟
                    </div>
                <% } %>
            </div>
            
            <% if (totalAchievements > 6) { %>
                <div style="text-align: center; margin-top: 15px;">
                    <a href="/achievements" class="btn-sm btn-light">Xem tất cả</a>
                </div>
            <% } %>
        </div>

        <div class="stats-container-bottom">
            <div class="mini-stat-bottom rank">
                <div class="stat-emoji">🥇</div>
                <div class="stat-num">#<%= userRank %></div>
                <div class="stat-title">Xếp hạng</div>
            </div>
            <div class="mini-stat-bottom streak">
                <div class="stat-emoji">🔥</div>
                <div class="stat-num"><%= streak %></div>
                <div class="stat-title">Chuỗi học</div>
            </div>
            <div class="mini-stat-bottom total-points">
                <div class="stat-emoji">⭐</div>
                <div class="stat-num"><%= (stats.achievementPoints || 0).toLocaleString() %></div>
                <div class="stat-title">Điểm TT</div>
            </div>
        </div>

        <div class="bento-card activity-card">
            <div class="activity-header">
                <span>🔥 Hoạt động gần đây</span>
            </div>
            
            <div class="activity-list">
                <% if (activities && activities.length > 0) { %>
                    <% activities.forEach(activity => { %>
                        <div class="activity-item">
                            <div class="act-icon">📝</div>
                            <div class="act-info">
                                <div class="act-title">
                                    Đã học xong: <strong><%= activity.lessonId ? activity.lessonId.title : 'Bài học ẩn' %></strong>
                                </div>
                                <div class="act-time">
                                    <%= moment(activity.completedAt).fromNow() %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div style="text-align:center; padding:20px; color:#94a3b8; font-style:italic;">
                        "Im ắng quá... Chưa có hoạt động nào." 🍃
                    </div>
                <% } %>
            </div>
        </div>

    </div>
</div>

        <!-- Tab Toggle JS -->
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const tabs = document.querySelectorAll('.tab-btn');
                const contents = document.querySelectorAll('.tab-content');

                tabs.forEach(tab => {
                    tab.addEventListener('click', () => {
                        const targetTab = tab.dataset.tab;

                        // Update active tab
                        tabs.forEach(t => t.classList.remove('active'));
                        tab.classList.add('active');

                        // Show target content
                        contents.forEach(c => c.classList.remove('active'));
                        document.getElementById(targetTab).classList.add('active');
                    });
                });
            });
        </script>

<%- include('partials/footer') %>

