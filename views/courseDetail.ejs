<%- include('partials/header') %>

<link rel="stylesheet" href="/css/styleCourseDetail.css">

<%- include('partials/breadcrumb') %>

<%
    const authorName = course.author ? course.author.username : 'HTTD Team';
    const authorAvatar = course.author ? (course.author.avatar || '/img/default-avatar.png') : '/img/default-avatar.png';
    const authorBio = course.author && course.author.bio ? course.author.bio : 'Đồng hành biên soạn lộ trình học theo nhịp dễ theo dõi và dễ quay lại.';
    const heroDescription = course.description || 'Khóa học được biên soạn theo dạng hành trình có nhịp, giúp bạn vào đúng bài, biết mình đang ở đâu và học tiếp theo cách gọn hơn.';
    const totalLocked = units.reduce((sum, unit) => sum + (unit.summary?.lockedCount || 0), 0);
    const hasStarted = progress.completedCount > 0;
%>

<main class="course-detail-page">
    <section class="course-hero">
        <div class="course-hero-copy">
            <div class="course-hero-kicker-row">
                <span class="course-hero-kicker">Khóa học trực tuyến</span>
                <% if (course.subjectId?.name) { %>
                    <span class="course-hero-subject"><i class="fas fa-book-open"></i><%= course.subjectId.name %></span>
                <% } %>
                <% if (course.isPro) { %>
                    <span class="course-status-badge is-pro"><i class="fas fa-crown"></i> PRO</span>
                <% } %>
                <% if (!course.isPublished && canViewDraft) { %>
                    <span class="course-status-badge is-draft"><i class="fas fa-flask"></i> Nháp</span>
                <% } %>
            </div>

            <h1 class="course-hero-title"><%= course.title %></h1>
            <p class="course-hero-description"><%= heroDescription %></p>

            <div class="course-meta-row">
                <div class="course-meta-item">
                    <img src="<%= authorAvatar %>" alt="<%= authorName %>" class="course-author-avatar">
                    <div>
                        <span class="course-meta-label">Biên soạn bởi</span>
                        <strong><%= authorName %></strong>
                    </div>
                </div>
                <div class="course-meta-item">
                    <i class="far fa-clock"></i>
                    <div>
                        <span class="course-meta-label">Cập nhật</span>
                        <strong><%= new Date(course.updatedAt).toLocaleDateString('vi-VN') %></strong>
                    </div>
                </div>
                <div class="course-meta-item">
                    <i class="fas fa-user-graduate"></i>
                    <div>
                        <span class="course-meta-label">Người học</span>
                        <strong><%= stats.studentCount %></strong>
                    </div>
                </div>
            </div>

            <div class="course-insight-row">
                <% insightChips.forEach((chip) => { %>
                    <span class="course-insight-chip"><%= chip %></span>
                <% }) %>
                <% if (totalLocked > 0) { %>
                    <span class="course-insight-chip is-warm"><i class="fas fa-lock"></i><%= totalLocked %> bài nâng cao</span>
                <% } %>
            </div>

            <div class="course-hero-actions">
                <% if (cta.primary) { %>
                    <a href="<%= cta.primary.href %>" class="course-btn course-btn-primary">
                        <i class="fas fa-play-circle"></i>
                        <span><%= cta.primary.label %></span>
                    </a>
                <% } %>
                <% if (cta.secondary) { %>
                    <a href="<%= cta.secondary.href %>" class="course-btn course-btn-secondary">
                        <i class="fas fa-compass"></i>
                        <span><%= cta.secondary.label %></span>
                    </a>
                <% } %>
            </div>
        </div>

        <div class="course-hero-visual">
            <div class="course-cover-card">
                <div class="course-cover-frame">
                    <img src="<%= course.thumbnail || 'https://i.ibb.co/BVnNtLhp/default-course.png' %>" class="course-cover-image" alt="<%= course.title %>">
                    <div class="course-cover-glow"></div>
                </div>

                <div class="course-cover-panel">
                    <span class="course-cover-eyebrow"><%= cta.eyebrow %></span>
                    <h2><%= cta.title %></h2>
                    <p><%= cta.body %></p>

                    <div class="course-progress-card">
                        <div class="course-progress-head">
                            <span>Tiến độ đang mở</span>
                            <strong><%= progress.percent %>%</strong>
                        </div>
                        <div class="course-progress-bar">
                            <span style="width:<%= progress.percent %>%"></span>
                        </div>
                        <div class="course-progress-meta">
                            <span><%= progress.completedCount %>/<%= progress.accessibleCount %> bài đã hoàn thành</span>
                            <span><%= progress.remainingCount %> bài còn lại</span>
                        </div>
                    </div>

                    <div class="course-cover-stats">
                        <div>
                            <span>Chương</span>
                            <strong><%= stats.unitCount %></strong>
                        </div>
                        <div>
                            <span>Bài học</span>
                            <strong><%= stats.totalLessons %></strong>
                        </div>
                        <div>
                            <span>Thời lượng</span>
                            <strong><%= stats.totalDuration %> phút</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="course-detail-layout">
        <div class="course-main-column">
            <section class="course-section course-summary-section">
                <div class="course-section-heading">
                    <div>
                        <span class="course-section-kicker">Tổng quan</span>
                        <h2>Toàn cảnh lộ trình</h2>
                    </div>
                    <p>Khóa học giữ nhịp rõ ràng giữa lý thuyết, video và bài luyện tập để bạn biết mình đang ở đâu trong hành trình học.</p>
                </div>

                <div class="course-summary-grid">
                    <article class="course-summary-card">
                        <span>Lộ trình đang mở</span>
                        <strong><%= progress.accessibleCount %> bài</strong>
                        <p>Các bài đang có thể học ngay theo quyền truy cập hiện tại.</p>
                    </article>
                    <article class="course-summary-card">
                        <span>Nội dung video</span>
                        <strong><%= stats.totalVideos %> bài</strong>
                        <p>Những phần cần trực quan hóa và đi theo nhịp chậm hơn.</p>
                    </article>
                    <article class="course-summary-card">
                        <span>Luyện tập</span>
                        <strong><%= stats.totalQuiz %> bài</strong>
                        <p>Checkpoint để kiểm tra hiểu bài thay vì chỉ đọc liên tục.</p>
                    </article>
                    <article class="course-summary-card">
                        <span>Tài liệu</span>
                        <strong><%= stats.totalDocuments %> mục</strong>
                        <p>Tài nguyên đi kèm giúp bạn quay lại đúng chỗ khi cần ôn tập.</p>
                    </article>
                </div>
            </section>

            <section class="course-section course-curriculum-section">
                <div class="course-section-heading course-section-heading-split">
                    <div>
                        <span class="course-section-kicker">Navigator</span>
                        <h2>Nội dung khóa học</h2>
                    </div>
                    <div class="course-section-actions">
                        <button type="button" class="course-ghost-btn" data-course-action="expand-all">
                            <i class="fas fa-angle-double-down"></i>
                            <span>Mở hết</span>
                        </button>
                        <button type="button" class="course-ghost-btn" data-course-action="collapse-all">
                            <i class="fas fa-angle-double-up"></i>
                            <span>Thu gọn</span>
                        </button>
                    </div>
                </div>

                <div class="course-curriculum-toolbar">
                    <label class="course-search-field">
                        <i class="fas fa-search"></i>
                        <input type="search" id="courseLessonSearch" placeholder="Tìm nhanh chương hoặc bài học...">
                    </label>

                    <div class="course-filter-pills" id="courseFilterPills">
                        <button type="button" class="is-active" data-course-filter="all">Tất cả</button>
                        <button type="button" data-course-filter="video">Video</button>
                        <button type="button" data-course-filter="quiz">Luyện tập</button>
                        <button type="button" data-course-filter="locked">VIP</button>
                        <% if (user) { %>
                            <button type="button" data-course-filter="completed">Đã học</button>
                        <% } %>
                    </div>
                </div>

                <div class="course-results-meta" id="courseResultsMeta">
                    <span><strong id="courseVisibleLessonCount"><%= progress.accessibleCount %></strong> bài đang hiện</span>
                    <span><strong id="courseVisibleUnitCount"><%= units.length %></strong> chương còn khớp bộ lọc</span>
                </div>

                <div class="course-curriculum-stack" id="courseCurriculumStack">
                    <% if (units.length > 0) { %>
                        <% units.forEach((unit, unitIndex) => { %>
                            <article class="course-unit-card" data-unit-card data-unit-title="<%= (unit.title || '').toLowerCase() %>">
                                <button
                                    type="button"
                                    class="course-unit-toggle <%= unitIndex === 0 ? 'is-open' : '' %>"
                                    data-unit-toggle
                                    aria-expanded="<%= unitIndex === 0 ? 'true' : 'false' %>">
                                    <div class="course-unit-copy">
                                        <span class="course-unit-index">Chương <%= unit.index %></span>
                                        <h3><%= unit.title %></h3>
                                        <p>
                                            <span><%= unit.summary.totalCount %> bài</span>
                                            <span>•</span>
                                            <span><%= unit.summary.durationLabel %></span>
                                            <% if (unit.summary.lockedCount > 0) { %>
                                                <span>•</span>
                                                <span><%= unit.summary.lockedCount %> bài khóa</span>
                                            <% } %>
                                        </p>
                                    </div>

                                    <div class="course-unit-meta">
                                        <% if (unit.summary.completedCount > 0) { %>
                                            <span class="course-mini-progress"><%= unit.summary.completedCount %>/<%= unit.summary.accessibleCount %></span>
                                        <% } %>
                                        <i class="fas fa-chevron-down"></i>
                                    </div>
                                </button>

                                <div class="course-unit-body <%= unitIndex === 0 ? 'is-open' : '' %>" data-unit-body>
                                    <% if (unit.lessons.length > 0) { %>
                                        <% unit.lessons.forEach((lesson) => { %>
                                            <% const lessonClasses = [
                                                'course-lesson-row',
                                                lesson.isLocked ? 'is-locked' : 'is-open',
                                                lesson.isCompleted ? 'is-completed' : '',
                                                lesson._id.toString() === resumeLessonId ? 'is-resume-target' : ''
                                            ].filter(Boolean).join(' '); %>
                                            <a
                                                href="<%= lesson.link %>"
                                                class="<%= lessonClasses %>"
                                                data-lesson-row
                                                data-lesson-title="<%= (lesson.title || '').toLowerCase() %>"
                                                data-lesson-type="<%= lesson.type %>"
                                                data-lesson-locked="<%= lesson.isLocked ? 'true' : 'false' %>"
                                                data-lesson-completed="<%= lesson.isCompleted ? 'true' : 'false' %>">
                                                <div class="course-lesson-main">
                                                    <span class="course-lesson-icon"><i class="fas <%= lesson.typeIcon %>"></i></span>
                                                    <div class="course-lesson-copy">
                                                        <div class="course-lesson-title-row">
                                                            <strong><%= lesson.title %></strong>
                                                            <% if (!lesson.isPublished && canViewDraft) { %>
                                                                <span class="course-pill is-draft">Nháp</span>
                                                            <% } %>
                                                            <% if (lesson.isCompleted) { %>
                                                                <span class="course-pill is-success"><i class="fas fa-check"></i> Đã học</span>
                                                            <% } %>
                                                        </div>
                                                        <div class="course-lesson-meta">
                                                            <span><i class="far fa-clock"></i><%= lesson.durationLabel %></span>
                                                            <span><i class="fas <%= lesson.typeIcon %>"></i><%= lesson.typeLabel %></span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="course-lesson-side">
                                                    <% if (lesson.isLocked) { %>
                                                        <span class="course-pill is-warm"><i class="fas fa-lock"></i> VIP</span>
                                                    <% } else { %>
                                                        <span class="course-pill is-soft">Mở</span>
                                                    <% } %>
                                                    <i class="fas fa-arrow-right"></i>
                                                </div>
                                            </a>
                                        <% }) %>
                                    <% } else { %>
                                        <div class="course-empty-inline">
                                            <i class="fas fa-hourglass-half"></i>
                                            <span>Chương này đang được cập nhật nội dung.</span>
                                        </div>
                                    <% } %>
                                </div>
                            </article>
                        <% }) %>
                    <% } else { %>
                        <div class="course-empty-state">
                            <i class="fas fa-sparkles"></i>
                            <h3>Nội dung đang được biên soạn</h3>
                            <p>Khóa học chưa có cấu trúc bài học khả dụng ở thời điểm hiện tại.</p>
                        </div>
                    <% } %>
                </div>
            </section>

            <section class="course-section course-author-section">
                <div class="course-section-heading">
                    <div>
                        <span class="course-section-kicker">Tác giả & phong cách học</span>
                        <h2>Học theo nhịp dễ quay lại</h2>
                    </div>
                    <p>Bố cục khóa học được ưu tiên để bạn nhìn thấy lộ trình, biết bài nào đang mở, bài nào cần PRO và quay lại đúng điểm đang học.</p>
                </div>

                <div class="course-author-card">
                    <img src="<%= authorAvatar %>" alt="<%= authorName %>" class="course-author-card-avatar">
                    <div class="course-author-card-copy">
                        <h3><%= authorName %></h3>
                        <p><%= authorBio %></p>
                    </div>
                </div>
            </section>
        </div>

        <aside class="course-side-column">
            <div class="course-side-card course-action-card" data-tone="<%= cta.tone %>">
                <span class="course-side-kicker"><%= cta.eyebrow %></span>
                <h2><%= cta.title %></h2>
                <p><%= cta.body %></p>

                <div class="course-side-actions">
                    <% if (cta.primary) { %>
                        <a href="<%= cta.primary.href %>" class="course-btn course-btn-primary course-btn-block">
                            <i class="fas fa-play-circle"></i>
                            <span><%= cta.primary.label %></span>
                        </a>
                    <% } %>
                    <% if (cta.secondary) { %>
                        <a href="<%= cta.secondary.href %>" class="course-btn course-btn-secondary course-btn-block">
                            <i class="fas fa-compass"></i>
                            <span><%= cta.secondary.label %></span>
                        </a>
                    <% } %>
                </div>

                <div class="course-rail-progress">
                    <div>
                        <span>Tiến độ</span>
                        <strong><%= progress.percent %>%</strong>
                    </div>
                    <div>
                        <span>Còn lại</span>
                        <strong><%= progress.remainingCount %> bài</strong>
                    </div>
                </div>
            </div>

            <div class="course-side-card">
                <span class="course-side-kicker">Snapshot</span>
                <h3>Điểm neo nhanh</h3>
                <ul class="course-side-list">
                    <li><span>Khóa đang mở</span><strong><%= progress.accessibleCount %> bài</strong></li>
                    <li><span>Bài nâng cao</span><strong><%= stats.premiumLessons %></strong></li>
                    <li><span>Tài liệu đính kèm</span><strong><%= stats.totalDocuments %></strong></li>
                    <li><span>Người học</span><strong><%= stats.studentCount %></strong></li>
                </ul>
            </div>

            <div class="course-side-card">
                <span class="course-side-kicker">Nhịp học</span>
                <h3><%= hasStarted ? 'Bạn đã vào guồng' : 'Đề xuất bắt đầu gọn' %></h3>
                <p>
                    <% if (hasStarted) { %>
                        Tiếp tục từ bài chưa hoàn thành để hệ thống giữ đúng nhịp đang học thay vì bắt đầu lại từ đầu.
                    <% } else { %>
                        Mở từ bài đầu và đi lần lượt theo từng chương để nhận đủ phần lý thuyết, video và luyện tập.
                    <% } %>
                </p>
            </div>
        </aside>
    </div>
</main>

<script>
    window.COURSE_DETAIL_STATE = {
        courseId: "<%= course._id %>",
        resumeLessonId: <%- JSON.stringify(resumeLessonId || '') %>,
        firstLessonId: <%- JSON.stringify(firstLessonId || '') %>
    };
</script>
<script src="/js/courseDetail.js"></script>

<%- include('partials/footer') %>
