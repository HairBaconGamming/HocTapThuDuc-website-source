<%- include('partials/header') %>

<link rel="stylesheet" href="/css/styleCourseDetail.css">

<%- include('partials/breadcrumb') %>

<%
    const authorName = course.author ? course.author.username : 'HTTD Team';
    const authorAvatar = course.author ? (course.author.avatar || '/img/default-avatar.png') : '/img/default-avatar.png';
    const authorBio = course.author && course.author.bio ? course.author.bio : 'Đồng hành biên soạn lộ trình học theo nhịp dễ theo dõi và dễ quay lại.';
    const totalLocked = units.reduce((sum, unit) => sum + (unit.summary?.lockedCount || 0), 0);
    const stickyLesson = nextLessonCard || null;
    const stickyHref = stickyLesson ? stickyLesson.link : (cta.primary ? cta.primary.href : '#');
    const stickyTitle = stickyLesson ? stickyLesson.title : cta.title;
    const stickyMeta = stickyLesson
        ? `${stickyLesson.durationLabel} • ${stickyLesson.typeLabel}`
        : `${progress.completedCount}/${progress.accessibleCount} bài đã chạm`;
    const stickyState = stickyLesson
        ? (stickyLesson._id.toString() === resumeLessonId ? 'Bài nên học tiếp' : (stickyLesson.isCompleted ? 'Đã hoàn thành' : 'Sẵn sàng mở'))
        : cta.eyebrow;
    const stickyCtaLabel = stickyLesson
        ? (stickyLesson._id.toString() === resumeLessonId ? 'Học bài tiếp theo' : 'Mở bài này')
        : (cta.primary ? cta.primary.label : 'Vào học ngay');
    const canReviewFlashcards = !!(user && flashcardDeck && flashcardDeck.count > 0);
%>

<main class="course-detail-page">
    <section class="course-poster">
        <img
            src="<%= course.thumbnail || 'https://i.ibb.co/BVnNtLhp/default-course.png' %>"
            class="course-poster-backdrop"
            alt="<%= course.title %>">
        <div class="course-poster-shade"></div>

        <div class="course-poster-grid">
            <div class="course-poster-copy">
                <div class="course-poster-kicker-row">
                    <span class="course-hero-kicker">Lộ trình học</span>
                    <% if (course.subjectId?.name) { %>
                        <span class="course-hero-subject"><i class="fas fa-book-open"></i><%= course.subjectId.name %></span>
                    <% } %>
                    <% if (course.isPro) { %>
                        <span class="course-status-badge is-pro"><i class="fas fa-crown"></i> PRO</span>
                    <% } %>
                    <% if (!course.isPublished && canViewDraft) { %>
                        <span class="course-status-badge is-draft"><i class="fas fa-flask"></i> Nháp</span>
                    <% } %>
                </div>

                <div class="course-poster-text">
                    <h1 class="course-hero-title"><%= course.title %></h1>
                    <p class="course-hero-description"><%= heroDescription %></p>
                </div>

                <div class="course-hero-actions">
                    <% if (cta.primary) { %>
                        <a href="<%= cta.primary.href %>" class="course-btn course-btn-primary">
                            <i class="fas fa-play-circle"></i>
                            <span><%= cta.primary.label %></span>
                        </a>
                    <% } %>
                    <% if (cta.secondary) { %>
                        <a href="<%= cta.secondary.href %>" class="course-btn course-btn-secondary">
                            <i class="fas fa-compass"></i>
                            <span><%= cta.secondary.label %></span>
                        </a>
                    <% } %>
                </div>

                <div class="course-hero-loot">
                    <span class="course-hero-loot-kicker">Đi hết chặng đang mở sẽ mở ra</span>
                    <div class="course-loot-preview">
                        <span><i class="fas fa-trophy"></i><%= rewardPreview.badge %></span>
                        <span><i class="fas fa-droplet"></i>+<%= rewardPreview.water %> nước</span>
                        <span><i class="fas fa-bolt"></i>+<%= rewardPreview.xp %> XP</span>
                        <span><i class="fas fa-coins"></i>+<%= rewardPreview.gold %> vàng</span>
                    </div>
                </div>
            </div>

            <div class="course-poster-visual">
                <figure class="course-poster-cover">
                    <img src="<%= course.thumbnail || 'https://i.ibb.co/BVnNtLhp/default-course.png' %>" alt="<%= course.title %>">
                </figure>

                <div class="course-poster-caption">
                    <span class="course-cover-eyebrow"><%= cta.eyebrow %></span>
                    <strong><%= cta.title %></strong>
                    <p><%= cta.body %></p>
                </div>
            </div>
        </div>
    </section>

    <div class="course-detail-layout">
        <div class="course-main-column">
            <section class="course-section course-promise-section">
                <div class="course-section-heading">
                    <div>
                        <span class="course-section-kicker">Bạn sẽ học được gì?</span>
                        <h2>Đi vào khóa học bằng nhịp rõ ràng, không phải một đống con số</h2>
                    </div>
                    <p>Phần này gom lại những tín hiệu quan trọng nhất để bạn biết cách khóa học sẽ dẫn mình đi tiếp, thay vì ném mọi thống kê lên đầu trang.</p>
                </div>

                <div class="course-promise-grid">
                    <% learningPromise.forEach((item) => { %>
                        <article class="course-promise-card">
                            <span class="course-promise-icon"><i class="fas <%= item.icon %>"></i></span>
                            <span class="course-promise-label"><%= item.label %></span>
                            <strong><%= item.value %></strong>
                            <p><%= item.copy %></p>
                        </article>
                    <% }) %>
                </div>
            </section>

            <section class="course-section course-roadmap-section">
                <div class="course-section-heading">
                    <div>
                        <span class="course-section-kicker">Roadmap học tập</span>
                        <h2>Thấy rõ mình đang ở đâu trong cả hành trình</h2>
                    </div>
                    <p>Thay vì accordion cũ, mỗi chặng giờ đi theo một trục dọc liên tục. Bài đã học sáng lên, bài nên mở tiếp có nhịp pulse, bài khóa thì mềm lại để bạn nhìn được con đường phía trước.</p>
                </div>

                <div class="course-curriculum-toolbar">
                    <label class="course-search-field">
                        <i class="fas fa-search"></i>
                        <input type="search" id="courseLessonSearch" placeholder="Tìm nhanh chương hoặc bài học...">
                    </label>

                    <div class="course-filter-pills" id="courseFilterPills">
                        <button type="button" class="is-active" data-course-filter="all">Tất cả</button>
                        <button type="button" data-course-filter="video">Video</button>
                        <button type="button" data-course-filter="quiz">Luyện tập</button>
                        <button type="button" data-course-filter="locked">VIP</button>
                        <% if (user) { %>
                            <button type="button" data-course-filter="completed">Đã học</button>
                        <% } %>
                    </div>
                </div>

                <div class="course-results-meta" id="courseResultsMeta">
                    <span><strong id="courseVisibleLessonCount"><%= progress.accessibleCount %></strong> bài đang hiện</span>
                    <span><strong id="courseVisibleUnitCount"><%= units.length %></strong> chặng còn khớp bộ lọc</span>
                    <% if (totalLocked > 0) { %>
                        <span><strong><%= totalLocked %></strong> bài nâng cao đang chờ mở</span>
                    <% } %>
                </div>

                <div class="course-roadmap" id="courseRoadmap">
                    <% if (units.length > 0) { %>
                        <% units.forEach((unit) => { %>
                            <section class="course-roadmap-unit" data-unit-card data-unit-title="<%= (unit.title || '').toLowerCase() %>">
                                <div class="course-roadmap-unit-rail" aria-hidden="true">
                                    <span class="course-roadmap-unit-step"><%= unit.index %></span>
                                    <span class="course-roadmap-unit-line"></span>
                                </div>

                                <div class="course-roadmap-unit-body">
                                    <header class="course-roadmap-unit-head">
                                        <div>
                                            <span class="course-unit-index">Chặng <%= unit.index %></span>
                                            <h3><%= unit.title %></h3>
                                            <p>
                                                <span><%= unit.summary.totalCount %> bài</span>
                                                <span>•</span>
                                                <span><%= unit.summary.durationLabel %></span>
                                                <% if (unit.summary.lockedCount > 0) { %>
                                                    <span>•</span>
                                                    <span><%= unit.summary.lockedCount %> bài khóa</span>
                                                <% } %>
                                            </p>
                                        </div>

                                        <div class="course-roadmap-unit-progress">
                                            <span><%= unit.summary.completedCount %>/<%= unit.summary.accessibleCount %></span>
                                            <small>đã chạm</small>
                                        </div>
                                    </header>

                                    <% if (unit.lessons.length > 0) { %>
                                        <div class="course-roadmap-lesson-stack">
                                            <% unit.lessons.forEach((lesson) => { %>
                                                <%
                                                    const lessonStateClass = lesson.isLocked
                                                        ? 'is-locked'
                                                        : lesson.isCompleted
                                                            ? 'is-completed'
                                                            : (lesson._id.toString() === resumeLessonId ? 'is-current' : 'is-open');
                                                    const lessonStateLabel = lesson.isLocked
                                                        ? 'Cần mở khóa'
                                                        : lesson.isCompleted
                                                            ? 'Đã hoàn thành'
                                                            : (lesson._id.toString() === resumeLessonId ? 'Đang nên học tiếp' : 'Sẵn sàng mở');
                                                    const lessonCtaLabel = lesson.isLocked
                                                        ? 'Mở khóa'
                                                        : (lesson._id.toString() === resumeLessonId ? 'Tiếp tục học' : 'Vào bài');
                                                %>
                                                <a
                                                    href="<%= lesson.link %>"
                                                    class="course-roadmap-lesson <%= lessonStateClass %>"
                                                    data-lesson-row
                                                    data-lesson-title="<%= (lesson.title || '').toLowerCase() %>"
                                                    data-lesson-type="<%= lesson.type %>"
                                                    data-lesson-locked="<%= lesson.isLocked ? 'true' : 'false' %>"
                                                    data-lesson-completed="<%= lesson.isCompleted ? 'true' : 'false' %>"
                                                    data-preview-title="<%= lesson.title %>"
                                                    data-preview-meta="<%= `${lesson.durationLabel} • ${lesson.typeLabel}` %>"
                                                    data-preview-state="<%= lessonStateLabel %>"
                                                    data-preview-href="<%= lesson.link %>"
                                                    data-preview-cta="<%= lessonCtaLabel %>">
                                                    <span class="course-roadmap-lesson-node" aria-hidden="true"></span>

                                                    <div class="course-roadmap-lesson-main">
                                                        <div class="course-roadmap-lesson-copy">
                                                            <div class="course-roadmap-lesson-title-row">
                                                                <strong><%= lesson.title %></strong>
                                                                <% if (!lesson.isPublished && canViewDraft) { %>
                                                                    <span class="course-pill is-draft">Nháp</span>
                                                                <% } %>
                                                            </div>

                                                            <div class="course-roadmap-lesson-meta">
                                                                <span><i class="far fa-clock"></i><%= lesson.durationLabel %></span>
                                                                <span><i class="fas <%= lesson.typeIcon %>"></i><%= lesson.typeLabel %></span>
                                                            </div>
                                                        </div>

                                                        <div class="course-roadmap-lesson-side">
                                                            <span class="course-roadmap-state"><%= lessonStateLabel %></span>
                                                            <% if (lesson.isLocked) { %>
                                                                <i class="fas fa-lock"></i>
                                                            <% } else if (lesson.isCompleted) { %>
                                                                <i class="fas fa-check-circle"></i>
                                                            <% } else { %>
                                                                <i class="fas fa-arrow-right"></i>
                                                            <% } %>
                                                        </div>
                                                    </div>
                                                </a>
                                            <% }) %>
                                        </div>
                                    <% } else { %>
                                        <div class="course-empty-inline">
                                            <i class="fas fa-hourglass-half"></i>
                                            <span>Chặng này đang được biên soạn nội dung.</span>
                                        </div>
                                    <% } %>
                                </div>
                            </section>
                        <% }) %>
                    <% } else { %>
                        <div class="course-empty-state">
                            <i class="fas fa-sparkles"></i>
                            <h3>Nội dung đang được biên soạn</h3>
                            <p>Khóa học chưa có cấu trúc bài học khả dụng ở thời điểm hiện tại.</p>
                        </div>
                    <% } %>
                </div>
            </section>

            <section class="course-section course-ecosystem-section">
                <div class="course-section-heading">
                    <div>
                        <span class="course-section-kicker">Hệ sinh thái HTTD</span>
                        <h2>Không chỉ học xong rồi rời đi</h2>
                    </div>
                    <p>Khi khóa học nối được với khu vườn, flashcard và thành tích, mỗi lần quay lại đều có lý do rõ ràng hơn là chỉ “đọc tiếp cho xong”.</p>
                </div>

                <div class="course-ecosystem-grid">
                    <article class="course-ecosystem-card">
                        <span class="course-ecosystem-kicker">Loot preview</span>
                        <h3><%= rewardPreview.headline %></h3>
                        <p>Phần thưởng được gom theo đúng nhịp bài đang mở, để cảm giác tiến bộ luôn nhìn thấy được ngay từ trước khi bắt đầu.</p>
                        <div class="course-loot-preview is-grid">
                            <% rewardPreview.summary.forEach((item) => { %>
                                <span><%= item %></span>
                            <% }) %>
                        </div>
                    </article>

                    <article class="course-ecosystem-card">
                        <span class="course-ecosystem-kicker">Flashcard</span>
                        <h3><%= canReviewFlashcards ? 'Ôn lại đúng bộ thẻ gắn với khóa này' : 'Bộ thẻ sẽ mở ra khi bạn bắt đầu học' %></h3>
                        <p>
                            <% if (canReviewFlashcards) { %>
                                Bạn đang có <strong><%= flashcardDeck.count %></strong> thẻ gắn với khóa học này. Có thể vào ôn ngay thay vì phải lục lại từng bài.
                            <% } else { %>
                                Khi bạn tạo checkpoint flashcard ngay trong bài, bộ thẻ sẽ gom lại đúng theo khóa học để quay lại ôn tập liền mạch hơn.
                            <% } %>
                        </p>
                        <% if (canReviewFlashcards) { %>
                            <a href="<%= flashcardDeck.href %>" class="course-btn course-btn-secondary">
                                <i class="fas fa-layer-group"></i>
                                <span><%= flashcardDeck.label %></span>
                            </a>
                        <% } else if (resumeLessonId) { %>
                            <a href="/lesson/<%= resumeLessonId %>" class="course-btn course-btn-secondary">
                                <i class="fas fa-bolt"></i>
                                <span>Tạo thẻ ngay trong bài đang học</span>
                            </a>
                        <% } %>
                    </article>

                    <article class="course-ecosystem-card course-author-panel">
                        <span class="course-ecosystem-kicker">Biên soạn</span>
                        <div class="course-author-card">
                            <img src="<%= authorAvatar %>" alt="<%= authorName %>" class="course-author-card-avatar">
                            <div class="course-author-card-copy">
                                <h3><%= authorName %></h3>
                                <p><%= authorBio %></p>
                            </div>
                        </div>
                    </article>
                </div>
            </section>
        </div>

        <aside class="course-side-column">
            <div
                class="course-sticky-card"
                id="courseStickyCard"
                data-default-state="<%= stickyState %>"
                data-default-title="<%= stickyTitle %>"
                data-default-meta="<%= stickyMeta %>"
                data-default-href="<%= stickyHref %>"
                data-default-cta="<%= stickyCtaLabel %>">
                <div class="course-sticky-media">
                    <img src="<%= course.thumbnail || 'https://i.ibb.co/BVnNtLhp/default-course.png' %>" alt="<%= course.title %>">
                </div>

                <div class="course-sticky-copy">
                    <span class="course-side-kicker">Tiếp tục học</span>
                    <strong id="courseStickyState"><%= stickyState %></strong>
                    <h2 id="courseStickyTitle"><%= stickyTitle %></h2>
                    <p id="courseStickyMeta"><%= stickyMeta %></p>
                </div>

                <div class="course-sticky-progress">
                    <div class="course-progress-head">
                        <span>Tiến độ khóa</span>
                        <strong><%= progress.percent %>%</strong>
                    </div>
                    <div class="course-progress-bar">
                        <span style="width:<%= progress.percent %>%"></span>
                    </div>
                    <div class="course-progress-meta">
                        <span><%= progress.completedCount %>/<%= progress.accessibleCount %> bài đã hoàn thành</span>
                        <span><%= progress.remainingCount %> bài còn lại</span>
                    </div>
                </div>

                <div class="course-sticky-actions">
                    <a href="<%= stickyHref %>" class="course-btn course-btn-primary course-btn-block" id="courseStickyPrimary">
                        <i class="fas fa-play-circle"></i>
                        <span id="courseStickyPrimaryLabel"><%= stickyCtaLabel %></span>
                    </a>

                    <% if (canReviewFlashcards) { %>
                        <a href="<%= flashcardDeck.href %>" class="course-btn course-btn-secondary course-btn-block">
                            <i class="fas fa-layer-group"></i>
                            <span>Ôn <%= flashcardDeck.count %> flashcard</span>
                        </a>
                    <% } %>
                </div>

                <div class="course-sticky-loot">
                    <span class="course-sticky-loot-label">Khi đi hết chặng đang mở</span>
                    <div class="course-loot-preview is-grid compact">
                        <span>+<%= rewardPreview.water %> nước</span>
                        <span>+<%= rewardPreview.fertilizer %> phân bón</span>
                        <span>+<%= rewardPreview.xp %> XP</span>
                        <span>+<%= rewardPreview.gold %> vàng</span>
                    </div>
                </div>
            </div>
        </aside>
    </div>

    <div class="course-mobile-continue-bar" id="courseMobileBar">
        <div class="course-mobile-continue-copy">
            <span><%= stickyState %></span>
            <strong id="courseMobileTitle"><%= stickyTitle %></strong>
        </div>
        <a href="<%= stickyHref %>" class="course-btn course-btn-primary" id="courseMobilePrimary">
            <span id="courseMobilePrimaryLabel"><%= stickyCtaLabel %></span>
        </a>
    </div>
</main>

<script>
    window.COURSE_DETAIL_STATE = {
        courseId: "<%= course._id %>",
        resumeLessonId: <%- JSON.stringify(resumeLessonId || '') %>,
        firstLessonId: <%- JSON.stringify(firstLessonId || '') %>
    };
</script>
<script src="/js/courseDetail.js"></script>

<%- include('partials/footer') %>
