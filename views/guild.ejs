<%- include('partials/header') %>
<link rel="stylesheet" href="/css/styleGuild.css">
<%
const safeArray = (value) => (Array.isArray(value) ? value : []);
const safeNumber = (value, fallback = 0) => {
    const parsed = Number(value);
    return Number.isFinite(parsed) ? parsed : fallback;
};
const formatInt = (value) => Math.max(0, safeNumber(value, 0)).toLocaleString('vi-VN');
const formatDecimal = (value) => Math.max(0, safeNumber(value, 0)).toLocaleString('vi-VN', { maximumFractionDigits: 1 });
const formatDate = (value, fallback = 'No recent activity') => {
    if (!value) return fallback;
    const date = new Date(value);
    return Number.isNaN(date.getTime()) ? fallback : date.toLocaleString('vi-VN');
};
const clampPercent = (value) => Math.max(0, Math.min(100, safeNumber(value, 0)));
const ui = guildUi || {};
const guild = guildDetail?.guild || {};
const guildSlug = String(guild.slug || '');
const guildId = String(guild._id || '');
const safeGuildName = String(guild.name || 'Unnamed Guild');
const safeGuildDescription = String(
    guild.description
    || 'A shared sanctuary to study, donate resources, and grow the Spirit Tree together.'
);
const safeMemberCount = Math.max(0, Number(guild.memberCount || 0));
const safeMemberLimit = Math.max(safeMemberCount, Number(guild.memberLimit || 0));
const guildMemberCount = safeMemberCount;
const guildMemberLimit = safeMemberLimit;
const safeLeaderName = String(guild.leader?.username || 'Unknown leader');
const safeJoinMode = String(guild.settings?.joinMode || 'open');
const safeInviteCode = String(guild.settings?.inviteCode || '');
const showAdminTab = Boolean(ui.showAdminTab && viewerRole === 'leader');
const activeTab = showAdminTab ? String(ui.activeTab || 'overview') : (ui.activeTab === 'admin' ? 'overview' : String(ui.activeTab || 'overview'));
const tree = ui.tree || {};
const treeAsset = ui.treeAsset || {};
const treeCurrent = tree.current || {};
const treeNext = tree.next || null;
const treePercent = Math.max(0, Math.min(100, Number(tree.percent || 0)));
const treeCurrentExp = Math.max(0, Number(tree.xpIntoStage || 0));
const treeMaxExp = Math.max(treeCurrentExp, Number(tree.xpNeeded || 0));
const treeStage = Math.max(0, Number(treeCurrent.stage || 0));
const treeCurrentName = String(treeCurrent.name || 'Spirit Tree');
const treeCurrentMotto = String(treeCurrent.motto || 'A quiet sanctuary where the guild gathers its strength.');
const treeImageUrl = String(treeAsset.imageUrl || '');
const treeImageAlt = String(treeAsset.name || treeCurrentName);
const nextUnlockCopy = String(
    ui.nextUnlockCopy
    || (treeNext ? `Need ${Number(tree.xpForNextStage || 0).toLocaleString('vi-VN', { maximumFractionDigits: 1 })} more spirit power to unlock ${treeNext.name || 'the next stage'}.` : 'The Spirit Tree has reached its peak form.')
);
const competition = ui.competition || {};
const weeklyGoal = ui.weeklyGoal || null;
const weeklyGoalPercent = Math.max(0, Math.min(100, Number(ui.weeklyGoalPercent || 0)));
const goalModalSummary = ui.goalModalSummary || null;
const goalModalMetrics = Array.isArray(goalModalSummary?.metrics) ? goalModalSummary.metrics : [];
const goalBanner = ui.goalBanner || null;
const donationCatalog = Array.isArray(ui.donationCatalog) && ui.donationCatalog.length ? ui.donationCatalog : [];
const donationSeed = donationCatalog[0] || {
    key: 'water',
    label: 'Water',
    symbol: '💧',
    iconUrl: '',
    amount: 0
};
const currentBuffBadges = Array.isArray(ui.currentBuffBadges) ? ui.currentBuffBadges : [];
const heroMetaChips = Array.isArray(ui.heroMetaChips) ? ui.heroMetaChips : [
    { key: 'leader', text: `Leader: ${safeLeaderName}` },
    { key: 'members', text: `${safeMemberCount}/${safeMemberLimit} members` },
    { key: 'joinMode', text: safeJoinMode }
];
const rightRail = ui.rightRail || {};
const rightRailLeaderboard = Array.isArray(rightRail.leaderboard) ? rightRail.leaderboard : [];
const rightRailActivity = Array.isArray(rightRail.activity) ? rightRail.activity : [];
const defaultSegment = String(rightRail.defaultSegment || 'leaderboard');
const memberRows = Array.isArray(ui.memberRows) ? ui.memberRows : [];
const adminRows = Array.isArray(ui.adminRows) ? ui.adminRows : [];
const applications = Array.isArray(guildDetail?.applications) ? guildDetail.applications : [];
const auditLogs = Array.isArray(guildDetail?.auditLogs) ? guildDetail.auditLogs : [];
const roleLabelMap = ui.roleLabelMap || {};
const roleOptionsSafe = Array.isArray(roleOptions) ? roleOptions : [];
const topContributors = Array.isArray(ui.topContributors) ? ui.topContributors : [];
const topThreeContributors = Array.isArray(ui.topThreeContributors) ? ui.topThreeContributors : [];
const announcementCopy = String(ui.announcementCopy || '');
const goalTargetLabel = String(ui.weeklyGoalTarget || 'Spirit Power');
guild.name = safeGuildName;
guild.description = safeGuildDescription;
guild.slug = guildSlug;
guild._id = guildId;
guild.memberCount = guildMemberCount;
guild.memberLimit = guildMemberLimit;
tree.current = { ...treeCurrent, name: treeCurrentName, motto: treeCurrentMotto, stage: treeStage };
tree.next = treeNext
    ? { ...treeNext, name: treeNext.name || 'Next stage', unlockText: nextUnlockCopy }
    : { name: 'Peak stage reached', unlockText: nextUnlockCopy };
tree.percent = treePercent;
ui.heroMetaChips = heroMetaChips;
ui.rightRail = rightRail;
ui.adminRows = adminRows;
ui.weeklyGoalTarget = goalTargetLabel;
ui.goalBanner = goalBanner
    ? {
        ...goalBanner,
        title: String(goalBanner.title || 'Weekly Quest'),
        progressText: String(goalBanner.progressText || 'Keep donating to complete the quest.'),
        cta: String(goalBanner.cta || 'Open details'),
        percent: clampPercent(goalBanner.percent)
    }
    : null;
ui.goalModalSummary = goalModalSummary || {
    title: 'Weekly Quest',
    description: 'No campaign is active yet.',
    metrics: []
};
guildDetail.applications = applications;
guildDetail.auditLogs = auditLogs;
guildDetail.recentContributions = rightRailActivity;
%>
<main
    class="guild-page-shell guild-page-shell--detail guild-workspace guild-workspace-v2 guild-workspace-v3 guild-workspace-v4"
    data-guild-page
    data-guild-slug="<%= guildSlug %>"
    data-viewer-id="<%= viewerUserId %>"
    data-active-tab="<%= activeTab %>"
    data-default-segment="<%= defaultSegment %>"
>
    <section class="guild-v2-hero guild-v3-hero">
        <div class="guild-v2-hero__copy guild-v3-hero__copy">
            <span class="guild-kicker">Không gian Tông Môn</span>
            <h1 class="guild-v4-title guild-ellipsis" title="<%= safeGuildName %>"><%= safeGuildName %></h1>
            <p class="guild-v2-hero__lead guild-v4-copy">
                <%= guild.description || 'Một nơi cùng nhau học, vun trồng Linh Thụ và cộng hưởng buff cho cả môn phái.' %>
            </p>
            <div class="guild-v2-hero__chips guild-v3-hero__chips">
                <% ui.heroMetaChips.forEach((chip) => { %>
                    <span class="guild-chip"><%= chip.text %></span>
                <% }) %>
                <% if (!memberRows.length) { %>
                    <div class="guild-empty-copy guild-empty-copy--panel">No members yet. Invite the first learner to join this guild.</div>
                <% } %>
            </div>
        </div>

        <div class="guild-v2-hero__actions guild-v3-hero__actions">
            <div class="guild-v3-hero__status">
                <% if (isMember) { %>
                    <span class="guild-v2-status">Bạn đang đồng tu trong tông này</span>
                <% } else if (pendingApplication) { %>
                    <span class="guild-v2-status">Đơn gia nhập đang chờ duyệt</span>
                <% } else if (!viewerContext.guild && canJoin && guild.settings?.joinMode === 'open') { %>
                    <span class="guild-v2-status">Cổng tuyển sinh đang mở tự do</span>
                <% } else if (!viewerContext.guild && canJoin && guild.settings?.joinMode === 'approval') { %>
                    <span class="guild-v2-status">Gia nhập qua xét duyệt</span>
                <% } else if (!viewerContext.guild && canJoin && guild.settings?.joinMode === 'invite') { %>
                    <span class="guild-v2-status">Gia nhập qua mật lệnh chiêu mộ</span>
                <% } else if (!viewerContext.guild) { %>
                    <span class="guild-v2-status">Bạn chưa đủ điều kiện gia nhập</span>
                <% } else { %>
                    <span class="guild-v2-status">Bạn đang thuộc Tông Môn khác</span>
                <% } %>
            </div>

            <div class="guild-v3-hero__buttons">
                <% if (isMember) { %>
                    <form action="/guilds/<%= guildSlug %>/leave" method="POST">
                        <button type="submit" class="guild-secondary-btn">
                            <%= viewerRole === 'leader' ? 'Giải tán / Rời tông' : 'Rời Tông Môn' %>
                        </button>
                    </form>
                <% } else if (!viewerContext.guild && canJoin && guild.settings?.joinMode === 'open') { %>
                    <form action="/guilds/<%= guildSlug %>/join" method="POST">
                        <button type="submit" class="guild-primary-btn">Gia nhập Tông Môn</button>
                    </form>
                <% } else if (!viewerContext.guild && canJoin && guild.settings?.joinMode === 'approval') { %>
                    <button type="button" class="guild-primary-btn" data-guild-drawer-target="apply">Nộp đơn gia nhập</button>
                <% } else if (!viewerContext.guild && canJoin && guild.settings?.joinMode === 'invite') { %>
                    <button type="button" class="guild-primary-btn" data-guild-drawer-target="invite">Nhập mật lệnh</button>
                <% } %>

                <a href="/my-garden" class="guild-tertiary-link">Về khu vườn cá nhân</a>
            </div>
        </div>
    </section>

    <nav class="guild-v2-tabbar guild-v3-tabbar" aria-label="Điều hướng guild">
        <button type="button" class="guild-v2-tab <%= activeTab === 'overview' ? 'is-active' : '' %>" data-guild-tab="overview">🌳 Tổng Quan</button>
        <button type="button" class="guild-v2-tab <%= activeTab === 'goal' ? 'is-active' : '' %>" data-guild-tab="goal">🎯 Mục Tiêu Tuần</button>
        <button type="button" class="guild-v2-tab <%= activeTab === 'members' ? 'is-active' : '' %>" data-guild-tab="members">👥 Thành Viên</button>
        <% if (showAdminTab) { %>
            <button type="button" class="guild-v2-tab <%= activeTab === 'admin' ? 'is-active' : '' %>" data-guild-tab="admin">⚙️ Quản Trị</button>
        <% } %>
    </nav>

    <section class="guild-tab-panel <%= activeTab === 'overview' ? 'is-active' : '' %>" data-guild-panel="overview" <%= activeTab === 'overview' ? '' : 'hidden' %>>
        <div class="guild-v3-overview">
            <div class="guild-v3-main">
                <% if (announcementCopy) { %>
                    <section class="guild-v2-brief guild-v2-brief--announcement guild-v3-ribbon">
                        <span class="guild-mini-kicker">Tông Môn Lệnh</span>
                        <p><%= announcementCopy %></p>
                    </section>
                <% } %>

                <% if (ui.goalBanner) { %>
                    <button type="button" class="guild-v2-goal-banner guild-v3-goal-banner" data-guild-modal-open="goal">
                        <div class="guild-v2-goal-banner__copy">
                            <strong>🔥 <%= ui.goalBanner.title %></strong>
                            <span><%= ui.goalBanner.progressText %></span>
                        </div>
                        <span class="guild-v2-goal-banner__cta"><%= ui.goalBanner.cta %> →</span>
                        <span class="guild-v2-goal-banner__bar"><i style="width: <%= ui.goalBanner.percent %>%"></i></span>
                    </button>
                <% } else if (permissions.manageWeeklyGoal) { %>
                    <button type="button" class="guild-v2-goal-banner guild-v2-goal-banner--empty guild-v3-goal-banner" data-guild-drawer-target="goal-settings">
                        <div class="guild-v2-goal-banner__copy">
                            <strong>🔥 Chưa có chiến dịch tuần</strong>
                            <span>Tạo một campaign ngắn gọn để cả Tông Môn cùng kéo tiến độ.</span>
                        </div>
                        <span class="guild-v2-goal-banner__cta">+ Tạo chiến dịch</span>
                    </button>
                <% } %>

                <section class="guild-v2-altar guild-v3-altar">
                    <div class="guild-v2-altar__visual guild-v3-altar__visual" id="guildTreeSanctuary">
                        <div class="guild-v2-cosmos"></div>
                        <div class="guild-v2-cosmos guild-v2-cosmos--grid"></div>
                        <div class="guild-v2-altar__glow"></div>
                        <div class="guild-v2-altar__glow guild-v2-altar__glow--secondary"></div>
                        <div class="guild-v2-altar__halo"></div>
                        <div class="guild-v2-altar__spark guild-v2-altar__spark--one"></div>
                        <div class="guild-v2-altar__spark guild-v2-altar__spark--two"></div>
                        <div class="guild-v2-altar__spark guild-v2-altar__spark--three"></div>

                        <% if (treeImageUrl) { %>
                            <img
                                src="<%= treeImageUrl %>"
                                alt="<%= treeImageAlt %>"
                                class="guild-v2-tree guild-v3-tree"
                                loading="lazy"
                                decoding="async"
                            >
                        <% } %>

                        <div class="guild-v2-tree-card guild-v3-tree-card">
                            <span class="guild-mini-kicker">Bệ tế đàn Linh Thụ</span>
                            <h2 class="guild-ellipsis" title="<%= treeCurrentName %>"><%= treeCurrentName %></h2>
                            <p><%= treeCurrentMotto %></p>
                        </div>
                    </div>

                    <div class="guild-v2-altar__dock guild-v3-altar__dock">
                        <div class="guild-v2-progress guild-v3-progress">
                            <div class="guild-v2-progress__head">
                                <div>
                                    <span class="guild-mini-kicker">Cộng hưởng hiện tại</span>
                                    <h3><%= tree.percent %>% cộng hưởng</h3>
                                </div>
                                <span class="guild-v2-progress__pill">Giai đoạn <%= tree.current.stage %></span>
                            </div>

                            <div class="guild-progress-bar guild-progress-bar--hero">
                                <span style="width: <%= treePercent %>%"></span>
                            </div>

                            <div class="guild-v4-progress-meta">
                                <strong><%= formatDecimal(treeCurrentExp) %> / <%= formatDecimal(treeMaxExp) %> EXP</strong>
                                <span>Stage <%= treeStage %> · <%= treePercent %>% complete</span>
                            </div>

                            <div class="guild-v2-unlock guild-v3-unlock">
                                <span class="guild-v2-unlock__badge">🔓 Kế tiếp</span>
                                <div>
                                    <strong><%= tree.next ? tree.next.name : 'Đỉnh cảnh giới' %></strong>
                                    <p><%= tree.next ? tree.next.unlockText : ui.nextUnlockCopy %></p>
                                </div>
                            </div>

                            <div class="guild-v2-buffs guild-v3-buffs">
                                <% currentBuffBadges.forEach((badge) => { %>
                                    <span class="guild-v2-buff guild-v2-buff--<%= badge.tone %>">
                                        <small><%= badge.label %></small>
                                        <strong><%= badge.value %></strong>
                                    </span>
                                <% }) %>
                            </div>
                        </div>

                        <% if (isMember) { %>
                            <form class="guild-v2-donate guild-v3-donate" id="guildDonationForm" action="/guilds/<%= guildSlug %>/contribute" method="POST">
                                <input type="hidden" name="resourceType" value="<%= donationSeed.key %>">
                                <input type="hidden" name="amount" value="10">

                                <div class="guild-v2-donate__head guild-v3-donate__head">
                                    <div>
                                        <span class="guild-mini-kicker">Smart Dock</span>
                                        <h3>Hiến linh ngay</h3>
                                    </div>
                                    <strong id="guildDonateSummary"><%= donationSeed.symbol %> 10 <%= donationSeed.label %></strong>
                                </div>

                                <div class="guild-v2-resource-grid guild-v3-resource-grid" role="list">
                                    <% (donationCatalog.length ? donationCatalog : [donationSeed]).forEach((resource, index) => { %>
                                        <button
                                            type="button"
                                            class="guild-v2-resource <%= index === 0 ? 'is-active' : '' %>"
                                            data-resource-button
                                            data-resource-key="<%= resource.key %>"
                                            data-resource-label="<%= resource.label %>"
                                            data-resource-icon="<%= resource.symbol %>"
                                            data-resource-icon-url="<%= resource.iconUrl || '' %>"
                                            data-resource-amount="<%= resource.amount %>"
                                        >
                                            <span class="guild-v2-resource__orb guild-v3-resource__orb">
                                                <% if (resource.iconUrl) { %>
                                                    <img src="<%= resource.iconUrl %>" alt="<%= resource.label %>">
                                                <% } else { %>
                                                    <span><%= resource.symbol %></span>
                                                <% } %>
                                            </span>
                                            <span class="guild-v2-resource__label"><%= resource.label %></span>
                                            <small><%= resource.amount.toLocaleString('vi-VN') %></small>
                                        </button>
                                    <% }) %>
                                </div>

                                <div class="guild-v2-slider-card guild-v3-slider-card">
                                    <div class="guild-v2-slider-card__top">
                                        <span id="guildSelectedResourceLabel"><%= donationSeed.label %></span>
                                        <small>Tồn kho: <b id="guildSelectedResourceAmount"><%= formatInt(donationSeed.amount) %></b></small>
                                    </div>

                                    <input type="range" min="0" max="<%= Math.max(1, safeNumber(donationSeed.amount, 0)) %>" value="10" class="guild-donation-slider" id="guildDonationSlider">

                                    <div class="guild-v2-quick-grid">
                                        <button type="button" class="guild-quick-btn" data-quick-amount="10">+10</button>
                                        <button type="button" class="guild-quick-btn" data-quick-amount="100">+100</button>
                                        <button type="button" class="guild-quick-btn guild-quick-btn--allin" data-quick-amount="all">MAX</button>
                                    </div>

                                    <div class="guild-v2-slider-card__footer guild-v3-slider-card__footer">
                                        <label class="guild-custom-amount">
                                            <span>Số lượng</span>
                                            <input type="number" min="0" step="1" value="10" id="guildCustomAmount">
                                        </label>
                                        <button type="submit" class="guild-primary-btn guild-primary-btn--large" id="guildDonateSubmit">
                                            <span>Hiến Linh ngay</span>
                                            <strong id="guildDonateCta">Bơm thẳng vào Linh Thụ</strong>
                                        </button>
                                    </div>
                                </div>
                            </form>
                        <% } else if (!viewerContext.guild && guild.settings?.joinMode === 'approval' && !pendingApplication) { %>
                            <div class="guild-v2-callout guild-v3-callout">
                                <p>Gia nhập Tông Môn để mở nghi thức quyên góp, góp sức vào chiến dịch tuần và nhận buff cộng hưởng.</p>
                                <button type="button" class="guild-primary-btn" data-guild-drawer-target="apply">Nộp đơn gia nhập</button>
                            </div>
                        <% } else if (!viewerContext.guild && guild.settings?.joinMode === 'invite') { %>
                            <div class="guild-v2-callout guild-v3-callout">
                                <p>Tông Môn này chỉ nhận qua mật lệnh chiêu mộ. Nhập mã để đồng tu cùng môn phái.</p>
                                <button type="button" class="guild-primary-btn" data-guild-drawer-target="invite">Nhập mật lệnh</button>
                            </div>
                        <% } else if (!viewerContext.guild && guild.settings?.joinMode === 'open') { %>
                            <form action="/guilds/<%= guildSlug %>/join" method="POST" class="guild-v2-callout guild-v2-callout--form guild-v3-callout">
                                <p>Tông Môn đang mở cổng. Gia nhập ngay để bắt đầu hiến linh và nhận buff chung.</p>
                                <button type="submit" class="guild-primary-btn">Gia nhập ngay</button>
                            </form>
                        <% } else { %>
                            <div class="guild-v2-callout guild-v3-callout">
                                <p>Khóa đồng tu này hiện chưa khả dụng với trạng thái tài khoản hiện tại của bạn.</p>
                            </div>
                        <% } %>
                    </div>
                </section>
            </div>

            <aside class="guild-v3-side">
                <section class="guild-v2-sidecard guild-v3-sidecard">
                    <div class="guild-v2-sidecard__head guild-v3-sidecard__head">
                        <div>
                            <span class="guild-mini-kicker">Cột động</span>
                            <h3>Nhịp đập của Tông Môn</h3>
                        </div>
                        <div class="guild-v2-segmented">
                            <button type="button" class="guild-v2-segment is-active" data-guild-segment="leaderboard">🏆 Bảng Vàng</button>
                            <button type="button" class="guild-v2-segment" data-guild-segment="activity">⚡ Hoạt Động</button>
                        </div>
                    </div>

                    <div class="guild-v2-segment-panel is-active" data-guild-segment-panel="leaderboard">
                        <div class="guild-v2-leaderboard guild-v3-leaderboard">
                            <% rightRailLeaderboard.forEach((entry) => { %>
                                <article class="guild-v2-leaderboard-row guild-v2-leaderboard-row--rank-<%= entry.rank <= 3 ? entry.rank : 4 %>">
                                    <div class="guild-v2-leaderboard-row__identity">
                                        <span class="guild-v2-rank">#<%= entry.rank %></span>
                                        <img src="<%= entry.avatar || 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>" alt="<%= entry.username %>">
                                        <div>
                                            <strong><%= entry.username %></strong>
                                            <small><%= entry.totalAmount %> lượt cống hiến</small>
                                        </div>
                                    </div>
                                    <span class="guild-v2-leaderboard-row__value"><%= Number(entry.totalContributionValue || 0).toLocaleString('vi-VN', { maximumFractionDigits: 1 }) %></span>
                                </article>
                            <% }) %>
                            <% if (!rightRailLeaderboard.length) { %>
                                <p class="guild-empty-copy">Chưa có bảng vàng vì Tông Môn vẫn đang chờ những hiến lễ đầu tiên.</p>
                            <% } %>
                        </div>
                    </div>

                    <div class="guild-v2-segment-panel" data-guild-segment-panel="activity" hidden>
                        <div class="guild-v2-timeline guild-v3-timeline">
                            <% rightRailActivity.forEach((entry) => { %>
                                <% const userHasApplauded = Array.isArray(entry.applaudedBy) && entry.applaudedBy.some((memberId) => String(memberId) === String(viewerUserId)); %>
                                <article class="guild-v2-timeline-row guild-v2-timeline-row--<%= entry.dramaTone %>">
                                    <span class="guild-v2-timeline-row__dot guild-v2-timeline-row__dot--<%= entry.resourceTone %>"></span>
                                    <div class="guild-v2-timeline-row__copy">
                                        <p>
                                            <strong><%= entry.user?.username || 'Đồng môn ẩn danh' %></strong>
                                            vừa hiến <strong><%= entry.amount %> <%= entry.resourceLabel %></strong>
                                            <span>(+<%= Number(entry.contributionValue || 0).toLocaleString('vi-VN', { maximumFractionDigits: 1 }) %> Linh Lực)</span>
                                        </p>
                                        <small><%= new Date(entry.createdAt).toLocaleString('vi-VN') %></small>
                                    </div>
                                    <button type="button" class="guild-applause-btn guild-applause-btn--inline <%= userHasApplauded ? 'is-active' : '' %>" data-applause-url="/guilds/<%= guildSlug %>/contributions/<%= entry._id %>/applause">
                                        <span>👏</span>
                                        <strong data-applause-count><%= entry.applauseCount || 0 %></strong>
                                    </button>
                                </article>
                            <% }) %>
                            <% if (!rightRailActivity.length) { %>
                                <p class="guild-empty-copy">Dòng linh lực sẽ sáng lên khi các đồng môn bắt đầu hiến lễ.</p>
                            <% } %>
                        </div>
                    </div>
                </section>
            </aside>
        </div>
    </section>

    <section class="guild-tab-panel <%= activeTab === 'goal' ? 'is-active' : '' %>" data-guild-panel="goal" <%= activeTab === 'goal' ? '' : 'hidden' %>>
        <div class="guild-v3-goal-tab">
            <section class="guild-v2-sectioncard guild-v3-sectioncard">
                <div class="guild-v2-sectioncard__head">
                    <div>
                        <span class="guild-mini-kicker">Chiến dịch tuần này</span>
                        <h2><%= weeklyGoal?.title || 'Chưa mở chiến dịch tuần' %></h2>
                    </div>
                    <% if (weeklyGoal) { %>
                        <span class="guild-v2-pill guild-v2-pill--state <%= weeklyGoal.status === 'completed' ? 'is-complete' : '' %>">
                            <%= weeklyGoal.status === 'completed' ? 'Đã hoàn thành' : 'Đang mở' %>
                        </span>
                    <% } %>
                </div>

                <% if (weeklyGoal) { %>
                    <p class="guild-v2-copy">
                        Tông Môn đang dồn lực vào <strong><%= ui.weeklyGoalTarget %></strong>. Khi chiến dịch hoàn tất, cả đội sẽ nhận:
                        <strong><%= weeklyGoal.rewardPreview || 'thưởng cộng hưởng đặc biệt' %></strong>.
                    </p>
                    <div class="guild-progress-bar guild-progress-bar--hero">
                        <span style="width: <%= weeklyGoalPercent %>%"></span>
                    </div>
                    <div class="guild-v2-goal-metrics guild-v3-goal-metrics">
                        <% goalModalMetrics.forEach((metric) => { %>
                            <div class="guild-v2-metric">
                                <small><%= metric.label %></small>
                                <strong><%= metric.value %></strong>
                            </div>
                        <% }) %>
                        <% if (!rightRailActivity.length) { %>
                            <p class="guild-empty-copy">No activities yet. Be the first to donate!</p>
                        <% } %>
                    </div>
                <% } else if (permissions.manageWeeklyGoal) { %>
                    <div class="guild-v3-empty-state">
                        <p class="guild-v2-copy">Chưa có chiến dịch tuần nào đang chạy. Hãy tạo một chiến dịch ngắn, rõ và có phần thưởng đủ hấp dẫn để cả Tông Môn cùng bám mục tiêu.</p>
                        <button type="button" class="guild-primary-btn" data-guild-drawer-target="goal-settings">+ Tạo chiến dịch</button>
                    </div>
                <% } else { %>
                    <p class="guild-v2-copy">Trưởng môn chưa khởi tạo chiến dịch tuần. Khi chiến dịch được mở, tiến độ và bảng đóng góp sẽ hiện ở đây.</p>
                <% } %>
            </section>

            <div class="guild-v2-goal-grid guild-v3-goal-grid">
                <section class="guild-v2-sectioncard guild-v3-sectioncard">
                    <div class="guild-v2-sectioncard__head">
                        <div>
                            <span class="guild-mini-kicker">Người dẫn đầu</span>
                            <h3>Top đóng góp chiến dịch</h3>
                        </div>
                    </div>
                    <div class="guild-v2-leaderboard guild-v2-leaderboard--compact guild-v3-leaderboard">
                        <% topThreeContributors.forEach((entry) => { %>
                            <article class="guild-v2-leaderboard-row guild-v2-leaderboard-row--rank-<%= entry.rank %>">
                                <div class="guild-v2-leaderboard-row__identity">
                                    <span class="guild-v2-rank">#<%= entry.rank %></span>
                                    <img src="<%= entry.avatar || 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>" alt="<%= entry.username %>">
                                    <div>
                                        <strong><%= entry.username %></strong>
                                        <small><%= entry.totalAmount %> lượt cống hiến</small>
                                    </div>
                                </div>
                                <span class="guild-v2-leaderboard-row__value"><%= Number(entry.totalContributionValue || 0).toLocaleString('vi-VN', { maximumFractionDigits: 1 }) %></span>
                            </article>
                        <% }) %>
                        <% if (!topThreeContributors.length) { %>
                            <p class="guild-empty-copy">Chưa có ai bứt tốc cho chiến dịch tuần này.</p>
                        <% } %>
                    </div>
                </section>

                <section class="guild-v2-sectioncard guild-v3-sectioncard">
                    <div class="guild-v2-sectioncard__head">
                        <div>
                            <span class="guild-mini-kicker">Dòng linh lực</span>
                            <h3>Ai đang kéo tiến độ đi lên</h3>
                        </div>
                    </div>
                    <div class="guild-v2-timeline guild-v2-timeline--compact guild-v3-timeline">
                        <% rightRailActivity.slice(0, 8).forEach((entry) => { %>
                            <article class="guild-v2-timeline-row guild-v2-timeline-row--<%= entry.dramaTone %>">
                                <span class="guild-v2-timeline-row__dot guild-v2-timeline-row__dot--<%= entry.resourceTone %>"></span>
                                <div class="guild-v2-timeline-row__copy">
                                    <p><strong><%= entry.user?.username || 'Đồng môn ẩn danh' %></strong> đã góp <strong><%= entry.amount %> <%= entry.resourceLabel %></strong>.</p>
                                    <small>+<%= Number(entry.contributionValue || 0).toLocaleString('vi-VN', { maximumFractionDigits: 1 }) %> Linh Lực · <%= new Date(entry.createdAt).toLocaleString('vi-VN') %></small>
                                </div>
                            </article>
                        <% }) %>
                    </div>
                </section>
            </div>
        </div>
    </section>

    <section class="guild-tab-panel <%= activeTab === 'members' ? 'is-active' : '' %>" data-guild-panel="members" <%= activeTab === 'members' ? '' : 'hidden' %>>
        <section class="guild-v2-sectioncard guild-v3-sectioncard">
            <div class="guild-v2-sectioncard__head">
                <div>
                    <span class="guild-mini-kicker">Nhân sự Tông Môn</span>
                    <h2>Danh sách thành viên</h2>
                </div>
                <span class="guild-card-meta"><%= guild.memberCount %> người</span>
            </div>

            <div class="guild-v3-member-list">
                <% memberRows.forEach((member) => { %>
                    <article class="guild-v3-member-row">
                        <div class="guild-v3-member-row__identity">
                            <div class="guild-member-avatar-wrap">
                                <img src="<%= member.avatar || 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>" alt="<%= member.username || 'Member' %>">
                                <span class="guild-online-dot <%= member.isOnline ? 'is-online' : '' %>"></span>
                            </div>
                            <div class="guild-v3-member-copy">
                                <div class="guild-v3-member-copy__head">
                                    <strong class="guild-ellipsis" title="<%= member.username || 'Unknown member' %>"><%= member.username || 'Unknown member' %></strong>
                                    <span class="guild-v3-role-pill"><%= member.roleText %></span>
                                </div>
                                <small>Level <%= member.level || 0 %> · Hoạt động cuối: <%= member.lastActiveText %></small>
                            </div>
                        </div>

                        <div class="guild-v3-member-row__stats">
                            <span>Cống hiến tuần <strong><%= member.weeklyContributionText %></strong></span>
                            <span>Phút học tuần <strong><%= member.weeklyStudyMinutesText %></strong></span>
                        </div>

                        <% if (member.canEditRole || member.canKick) { %>
                            <details class="guild-v3-member-menu">
                                <summary class="guild-inline-btn guild-inline-btn--ghost">Quản trị</summary>
                                <div class="guild-v3-member-menu__panel">
                                    <% if (member.canEditRole) { %>
                                        <form action="/guilds/<%= guildSlug %>/members/<%= member._id %>/role" method="POST" class="guild-inline-form">
                                            <input type="hidden" name="guildId" value="<%= guildId %>">
                                            <select name="nextRole">
                                                <% roleOptionsSafe.forEach((role) => { %>
                                                    <option value="<%= role %>"><%= roleLabelMap[role] %></option>
                                                <% }) %>
                                            </select>
                                            <button type="submit" class="guild-inline-btn">Đổi chức</button>
                                        </form>
                                    <% } %>
                                    <% if (member.canKick) { %>
                                        <form action="/guilds/<%= guildSlug %>/members/<%= member._id %>/kick" method="POST" class="guild-inline-form">
                                            <input type="hidden" name="guildId" value="<%= guildId %>">
                                            <input type="hidden" name="reason" value="Kỷ luật nội bộ">
                                            <button type="submit" class="guild-inline-btn guild-inline-btn--danger">Kick</button>
                                        </form>
                                    <% } %>
                                </div>
                            </details>
                        <% } %>
                    </article>
                <% }) %>
            </div>
        </section>
    </section>

    <% if (showAdminTab) { %>
        <section class="guild-tab-panel <%= activeTab === 'admin' ? 'is-active' : '' %>" data-guild-panel="admin" <%= activeTab === 'admin' ? '' : 'hidden' %>>
            <div class="guild-v3-admin-shell">
                <section class="guild-v2-sectioncard guild-v2-sectioncard--admin guild-v3-sectioncard guild-v3-admin-card">
                    <div class="guild-v2-sectioncard__head">
                        <div>
                            <span class="guild-mini-kicker">Bảng điều phối nội bộ</span>
                            <h2>Quản trị Tông Môn</h2>
                        </div>
                    </div>

                    <div class="guild-v2-admin-rows guild-v3-admin-rows">
                        <% ui.adminRows.forEach((row) => { %>
                            <article class="guild-v2-admin-row guild-v3-admin-row">
                                <div>
                                    <strong><%= row.title %></strong>
                                    <p><%= row.description %></p>
                                </div>
                                <button type="button" class="guild-inline-btn" data-guild-drawer-target="<%= row.drawerTarget %>"><%= row.actionLabel %></button>
                            </article>
                        <% }) %>
                    </div>
                </section>

                <% if (permissions.approveApplications) { %>
                    <section class="guild-v2-sectioncard guild-v3-sectioncard">
                        <div class="guild-v2-sectioncard__head">
                            <div>
                                <span class="guild-mini-kicker">Cổng tuyển sinh</span>
                                <h3>Đơn chờ duyệt</h3>
                            </div>
                            <span class="guild-card-meta"><%= guildDetail.applications.length %> đơn</span>
                        </div>
                        <div class="guild-application-list guild-v3-application-list">
                            <% if (!guildDetail.applications.length) { %>
                                <p class="guild-empty-copy">Hiện chưa có đơn mới trong cổng tuyển sinh.</p>
                            <% } %>
                            <% guildDetail.applications.forEach((application) => { %>
                                <article class="guild-application-card">
                                    <div class="guild-application-head">
                                        <div>
                                            <strong><%= application.applicant?.username || 'Đệ tử ẩn danh' %></strong>
                                            <small>Level <%= application.applicant?.level || 0 %> · Streak <%= application.applicant?.currentStreak || 0 %> ngày</small>
                                        </div>
                                        <span class="guild-card-meta"><%= new Date(application.createdAt).toLocaleString('vi-VN') %></span>
                                    </div>
                                    <p><%= application.message || 'Không để lại lời nhắn.' %></p>
                                    <div class="guild-inline-actions">
                                        <form action="/guilds/<%= guild.slug %>/applications/<%= application._id %>/review" method="POST">
                                            <input type="hidden" name="decision" value="approved">
                                            <button type="submit" class="guild-inline-btn">Duyệt đơn</button>
                                        </form>
                                        <form action="/guilds/<%= guild.slug %>/applications/<%= application._id %>/review" method="POST">
                                            <input type="hidden" name="decision" value="rejected">
                                            <button type="submit" class="guild-inline-btn guild-inline-btn--danger">Từ chối</button>
                                        </form>
                                    </div>
                                </article>
                            <% }) %>
                        </div>
                    </section>
                <% } %>

                <section class="guild-v2-sectioncard guild-v3-sectioncard">
                    <div class="guild-v2-sectioncard__head">
                        <div>
                            <span class="guild-mini-kicker">Tàng Kinh Các</span>
                            <h3>Sổ kỷ lục quản trị</h3>
                        </div>
                    </div>
                    <div class="guild-audit-list guild-v3-audit-list">
                        <% guildDetail.auditLogs.forEach((entry) => { %>
                            <article class="guild-audit-item">
                                <strong><%= entry.message %></strong>
                                <small><%= new Date(entry.createdAt).toLocaleString('vi-VN') %></small>
                            </article>
                        <% }) %>
                        <% if (!guildDetail.auditLogs.length) { %>
                            <p class="guild-empty-copy">Nhật ký quản trị sẽ sáng lên khi Tông Môn bắt đầu vận hành sâu hơn.</p>
                        <% } %>
                    </div>
                </section>
            </div>
        </section>
    <% } %>

    <div class="guild-modal-backdrop" data-guild-modal-backdrop hidden></div>
    <section class="guild-modal guild-v2-modal guild-v3-modal" data-guild-modal="goal" hidden>
        <div class="guild-modal__card guild-v2-modal__card guild-v3-modal__card">
            <button type="button" class="guild-modal__close" data-guild-modal-close aria-label="Đóng">×</button>
            <span class="guild-mini-kicker">Chi tiết chiến dịch</span>
            <h3><%= ui.goalModalSummary?.title || 'Chiến dịch tuần' %></h3>
            <% if (ui.goalModalSummary) { %>
                <p class="guild-v2-copy"><%= ui.goalModalSummary.description %></p>
                <div class="guild-progress-bar guild-progress-bar--hero">
                    <span style="width: <%= weeklyGoalPercent %>%"></span>
                </div>
                <div class="guild-v2-goal-metrics guild-v2-goal-metrics--modal guild-v3-goal-metrics">
                    <% ui.goalModalSummary.metrics.forEach((metric) => { %>
                        <div class="guild-v2-metric">
                            <small><%= metric.label %></small>
                            <strong><%= metric.value %></strong>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="guild-v2-copy">Chiến dịch tuần chưa được mở. Hãy chờ Trưởng môn khởi tạo để toàn đội cùng lao vào cày mục tiêu.</p>
            <% } %>
        </div>
    </section>

    <div class="guild-drawer-backdrop" data-guild-drawer-backdrop hidden></div>
    <aside class="guild-drawer" data-guild-drawer="apply" hidden>
        <div class="guild-drawer__card guild-v3-drawer__card">
            <button type="button" class="guild-drawer__close" data-guild-drawer-close aria-label="Đóng">×</button>
            <span class="guild-mini-kicker">Nộp đơn</span>
            <h3>Gia nhập <%= guild.name %></h3>
            <form action="/guilds/<%= guild.slug %>/apply" method="POST" class="guild-governance-form">
                <input type="hidden" name="guildId" value="<%= guild._id %>">
                <label>
                    <span>Lời nhắn gia nhập</span>
                    <textarea name="message" rows="6" maxlength="500" placeholder="Hãy nói rõ vì sao bạn muốn đồng hành cùng Tông Môn này."></textarea>
                </label>
                <button type="submit" class="guild-primary-btn">Gửi đơn ngay</button>
            </form>
        </div>
    </aside>

    <aside class="guild-drawer" data-guild-drawer="invite" hidden>
        <div class="guild-drawer__card guild-v3-drawer__card">
            <button type="button" class="guild-drawer__close" data-guild-drawer-close aria-label="Đóng">×</button>
            <span class="guild-mini-kicker">Mật lệnh</span>
            <h3>Gia nhập qua lời mời</h3>
            <form action="/guilds/<%= guild.slug %>/join" method="POST" class="guild-governance-form">
                <label>
                    <span>Mật lệnh chiêu mộ</span>
                    <input type="text" name="inviteCode" maxlength="12" placeholder="Nhập mật lệnh">
                </label>
                <button type="submit" class="guild-primary-btn">Gia nhập bằng mật lệnh</button>
            </form>
        </div>
    </aside>

    <% if (showAdminTab) { %>
        <% if (permissions.editAnnouncement) { %>
            <aside class="guild-drawer" data-guild-drawer="announcement" hidden>
                <div class="guild-drawer__card guild-v3-drawer__card">
                    <button type="button" class="guild-drawer__close" data-guild-drawer-close aria-label="Đóng">×</button>
                    <span class="guild-mini-kicker">Tông Môn Lệnh</span>
                    <h3>Chỉnh sửa thông báo chung</h3>
                    <form action="/guilds/<%= guild.slug %>/announcement" method="POST" class="guild-governance-form">
                        <input type="hidden" name="guildId" value="<%= guild._id %>">
                        <label>
                            <span>Nội dung thông báo</span>
                            <textarea name="content" rows="8" maxlength="700" placeholder="Viết lời hiệu triệu, mục tiêu hay nhịp học cho toàn tông môn."><%= announcementCopy %></textarea>
                        </label>
                        <button type="submit" class="guild-primary-btn">Lưu thông báo</button>
                    </form>
                </div>
            </aside>
        <% } %>

        <% if (permissions.approveApplications) { %>
            <aside class="guild-drawer" data-guild-drawer="recruitment" hidden>
                <div class="guild-drawer__card guild-v3-drawer__card">
                    <button type="button" class="guild-drawer__close" data-guild-drawer-close aria-label="Đóng">×</button>
                    <span class="guild-mini-kicker">Tuyển sinh</span>
                    <h3>Điều chỉnh cổng tuyển sinh</h3>
                    <form action="/guilds/<%= guild.slug %>/join-settings" method="POST" class="guild-governance-form">
                        <input type="hidden" name="guildId" value="<%= guild._id %>">
                        <div class="guild-governance-grid">
                            <label>
                                <span>Chế độ tuyển sinh</span>
                                <select name="joinMode">
                                    <option value="open" <%= guild.settings?.joinMode === 'open' ? 'selected' : '' %>>Vào tự do</option>
                                    <option value="approval" <%= guild.settings?.joinMode === 'approval' ? 'selected' : '' %>>Cần phê duyệt</option>
                                    <option value="invite" <%= guild.settings?.joinMode === 'invite' ? 'selected' : '' %>>Chỉ qua mật lệnh</option>
                                </select>
                            </label>
                            <label>
                                <span>Level tối thiểu</span>
                                <input type="number" min="0" name="minLevel" value="<%= guild.settings?.joinThresholds?.minLevel || 0 %>">
                            </label>
                            <label>
                                <span>Streak tối thiểu</span>
                                <input type="number" min="0" name="minStreak" value="<%= guild.settings?.joinThresholds?.minStreak || 0 %>">
                            </label>
                            <label>
                                <span>Điểm học tập tối thiểu</span>
                                <input type="number" min="0" name="minTotalPoints" value="<%= guild.settings?.joinThresholds?.minTotalPoints || 0 %>">
                            </label>
                            <label>
                                <span>Phút học/tuần tối thiểu</span>
                                <input type="number" min="0" name="minWeeklyMinutes" value="<%= guild.settings?.joinThresholds?.minWeeklyMinutes || 0 %>">
                            </label>
                        </div>
                        <button type="submit" class="guild-primary-btn">Lưu cổng tuyển sinh</button>
                    </form>
                </div>
            </aside>
        <% } %>

        <% if (permissions.manageWeeklyGoal) { %>
            <aside class="guild-drawer" data-guild-drawer="goal-settings" hidden>
                <div class="guild-drawer__card guild-v3-drawer__card">
                    <button type="button" class="guild-drawer__close" data-guild-drawer-close aria-label="Đóng">×</button>
                    <span class="guild-mini-kicker">Chiến dịch tuần</span>
                    <h3>Tạo hoặc cập nhật mục tiêu</h3>
                    <form action="/guilds/<%= guild.slug %>/weekly-goal" method="POST" class="guild-governance-form">
                        <input type="hidden" name="guildId" value="<%= guild._id %>">
                        <div class="guild-governance-grid">
                            <label>
                                <span>Tiêu đề</span>
                                <input type="text" name="title" maxlength="120" value="<%= weeklyGoal?.title || 'Tích lũy linh lực cho tuần này' %>">
                            </label>
                            <label>
                                <span>Loại mục tiêu</span>
                                <select name="targetType">
                                    <option value="spirit_power" <%= !weeklyGoal || weeklyGoal.targetType === 'spirit_power' ? 'selected' : '' %>>Tổng Linh Lực</option>
                                    <option value="resource" <%= weeklyGoal?.targetType === 'resource' ? 'selected' : '' %>>Một tài nguyên cụ thể</option>
                                </select>
                            </label>
                            <label>
                                <span>Tài nguyên</span>
                                <select name="targetResource">
                                    <% donationCatalog.forEach((resource) => { %>
                                        <option value="<%= resource.key %>" <%= weeklyGoal?.targetResource === resource.key ? 'selected' : '' %>><%= resource.label %></option>
                                    <% }) %>
                                </select>
                            </label>
                            <label>
                                <span>Mục tiêu</span>
                                <input type="number" min="1" name="targetAmount" value="<%= weeklyGoal?.targetAmount || 1000 %>">
                            </label>
                            <label class="guild-governance-span-2">
                                <span>Phần thưởng hiển thị</span>
                                <input type="text" name="rewardPreview" maxlength="220" value="<%= weeklyGoal?.rewardPreview || 'Mở khóa rương tông môn và badge cộng hưởng cho cả tuần.' %>">
                            </label>
                        </div>
                        <button type="submit" class="guild-primary-btn">Lưu chiến dịch</button>
                    </form>
                </div>
            </aside>
        <% } %>

        <% if (permissions.setAutoKickRules) { %>
            <aside class="guild-drawer" data-guild-drawer="moderation" hidden>
                <div class="guild-drawer__card guild-v3-drawer__card">
                    <button type="button" class="guild-drawer__close" data-guild-drawer-close aria-label="Đóng">×</button>
                    <span class="guild-mini-kicker">Thiết quân luật</span>
                    <h3>Tự động dọn chỗ cho người nhiệt huyết</h3>
                    <form action="/guilds/<%= guild.slug %>/auto-moderation" method="POST" class="guild-governance-form">
                        <input type="hidden" name="guildId" value="<%= guild._id %>">
                        <div class="guild-governance-grid">
                            <label class="guild-toggle-row">
                                <input type="checkbox" name="enabled" value="true" <%= guild.settings?.autoModeration?.enabled ? 'checked' : '' %>>
                                <span>Bật auto-kick</span>
                            </label>
                            <label>
                                <span>Kick nếu offline quá (ngày)</span>
                                <input type="number" min="0" name="kickAfterInactiveDays" value="<%= guild.settings?.autoModeration?.kickAfterInactiveDays || 0 %>">
                            </label>
                            <label>
                                <span>Kick nếu cống hiến tuần ≤</span>
                                <input type="number" min="0" name="kickIfWeeklyContributionBelow" value="<%= guild.settings?.autoModeration?.kickIfWeeklyContributionBelow || 0 %>">
                            </label>
                        </div>
                        <button type="submit" class="guild-primary-btn">Lưu quân luật</button>
                    </form>
                </div>
            </aside>
        <% } %>

        <% if (permissions.refreshInviteCode) { %>
            <aside class="guild-drawer" data-guild-drawer="invite-tools" hidden>
                <div class="guild-drawer__card guild-v3-drawer__card">
                    <button type="button" class="guild-drawer__close" data-guild-drawer-close aria-label="Đóng">×</button>
                    <span class="guild-mini-kicker">Mật lệnh</span>
                    <h3>Quản lý mã chiêu mộ</h3>
                    <div class="guild-secret-code-panel">
                        <strong>Mật lệnh hiện tại</strong>
                        <button type="button" class="guild-secret-code" data-copy-text="<%= guild.settings?.inviteCode || '' %>">
                            <%= guild.settings?.inviteCode || 'Chưa có mật lệnh' %>
                        </button>
                    </div>
                    <form action="/guilds/<%= guild.slug %>/invite-code/refresh" method="POST" class="guild-governance-form">
                        <input type="hidden" name="guildId" value="<%= guild._id %>">
                        <button type="submit" class="guild-primary-btn">Làm mới mật lệnh</button>
                    </form>
                </div>
            </aside>
        <% } %>
    <% } %>
</main>
<script src="/js/guild.js"></script>
<%- include('partials/footer') %>
