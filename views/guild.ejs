<%- include('partials/header') %>
<link rel="stylesheet" href="/css/styleGuild.css">

<%
    const guild = guildDetail.guild;
    const tree = guildDetail.treeProgress;
    const buffSnapshot = guild.buffSnapshot || { lessonXpPct: 0, witherTimeBonusPct: 0 };
    const treeAsset = Array.isArray(guildTreeAssets)
        ? guildTreeAssets.find((entry) => entry.stage === tree.current.stage)
        : null;
%>

<main class="guild-page-shell">
    <section class="guild-detail-hero">
        <div class="guild-tree-showcase <%= 'guild-tree-stage-' + tree.current.stage %>">
            <div class="guild-tree-orbit"></div>
            <% if (treeAsset && treeAsset.imageUrl) { %>
                <img
                    src="<%= treeAsset.imageUrl %>"
                    alt="<%= treeAsset.name %>"
                    class="guild-tree-image"
                    loading="lazy"
                    decoding="async"
                >
            <% } %>
            <div class="guild-tree-core">
                <span class="guild-tree-stage-label">Stage <%= tree.current.stage %></span>
                <h2><%= tree.current.name %></h2>
                <p><%= tree.current.motto %></p>
            </div>
        </div>

        <div class="guild-detail-copy">
            <span class="guild-kicker">Tông Môn hiện tại</span>
            <h1><%= guild.name %></h1>
            <p><%= guild.description || 'Tông Môn này đang cùng nhau nuôi dưỡng Linh Thụ và truy cầu cảnh giới cao hơn.' %></p>

            <div class="guild-hero-badges">
                <span class="guild-chip">Trưởng môn: <%= guild.leader?.username || 'Ẩn danh' %></span>
                <span class="guild-chip"><%= guild.memberCount %> thành viên</span>
                <span class="guild-chip">Tổng Linh Lực: <%= guild.treeXp %></span>
            </div>

            <div class="guild-list-buffs">
                <span>+<%= buffSnapshot.lessonXpPct %>% XP học bài</span>
                <span>+<%= buffSnapshot.witherTimeBonusPct %>% độ bền cây</span>
            </div>

            <div class="guild-list-actions">
                <% if (!viewerContext.guild && canJoin) { %>
                    <form action="/guilds/<%= guild.slug %>/join" method="POST">
                        <button type="submit" class="guild-primary-btn">Gia nhập Tông Môn</button>
                    </form>
                <% } else if (!viewerContext.guild) { %>
                    <span class="guild-secondary-btn" style="opacity: 0.7; cursor: default;">Cần thêm level để gia nhập</span>
                <% } else if (isMember) { %>
                    <form action="/guilds/<%= guild.slug %>/leave" method="POST">
                        <button type="submit" class="guild-secondary-btn"><%= isLeader ? 'Giải tán / Rời Tông' : 'Rời Tông Môn' %></button>
                    </form>
                <% } else { %>
                    <span class="guild-secondary-btn" style="opacity: 0.7; cursor: default;">Bạn đang thuộc Tông Môn khác</span>
                <% } %>
                <a href="/my-garden" class="guild-secondary-btn">Về Vườn Cá Nhân</a>
            </div>
        </div>
    </section>

    <section class="guild-dashboard-grid">
        <article class="guild-panel">
            <div class="guild-panel-head">
                <div>
                    <span class="guild-kicker">Tiến độ Linh Thụ</span>
                    <h3><%= tree.current.name %></h3>
                </div>
                <div class="guild-members-pill"><%= tree.percent %>%</div>
            </div>
            <div class="guild-progress-bar large">
                <span style="width: <%= tree.percent %>%"></span>
            </div>
            <% if (tree.next) { %>
                <p class="guild-panel-copy">Cần thêm <strong><%= tree.xpForNextStage %> Linh Lực</strong> để đạt <strong><%= tree.next.name %></strong>.</p>
            <% } else { %>
                <p class="guild-panel-copy">Linh Thụ đã đạt đến cảnh giới cao nhất hiện tại.</p>
            <% } %>

            <div class="guild-vault-grid">
                <div><span>Nước</span><strong><%= guild.vault.water || 0 %></strong></div>
                <div><span>Phân bón</span><strong><%= guild.vault.fertilizer || 0 %></strong></div>
                <div><span>Vàng</span><strong><%= guild.vault.gold || 0 %></strong></div>
                <div><span>Cà chua</span><strong><%= guild.vault.tomato || 0 %></strong></div>
                <div><span>Lúa mì</span><strong><%= guild.vault.wheat || 0 %></strong></div>
                <div><span>Cà rốt</span><strong><%= guild.vault.carrot || 0 %></strong></div>
            </div>
        </article>

        <article class="guild-panel">
            <div class="guild-panel-head">
                <div>
                    <span class="guild-kicker">Quyên góp</span>
                    <h3>Nuôi dưỡng Linh Thụ</h3>
                </div>
                <div class="guild-members-pill">Kho của bạn</div>
            </div>

            <% if (isMember) { %>
                <form class="guild-donation-form" action="/guilds/<%= guild.slug %>/contribute" method="POST">
                    <label>
                        <span>Tài nguyên</span>
                        <select name="resourceType">
                            <option value="water">Nước (còn <%= viewerResources.water %>)</option>
                            <option value="fertilizer">Phân bón (còn <%= viewerResources.fertilizer %>)</option>
                            <option value="gold">Vàng (còn <%= viewerResources.gold %>)</option>
                            <option value="tomato">Cà chua (còn <%= viewerResources.inventory.tomato %>)</option>
                            <option value="wheat">Lúa mì (còn <%= viewerResources.inventory.wheat %>)</option>
                            <option value="carrot">Cà rốt (còn <%= viewerResources.inventory.carrot %>)</option>
                            <option value="sunflower">Hướng dương (còn <%= viewerResources.inventory.sunflower %>)</option>
                        </select>
                    </label>
                    <label>
                        <span>Số lượng</span>
                        <input type="number" name="amount" min="1" step="1" value="1" required>
                    </label>
                    <button type="submit" class="guild-primary-btn">Quyên góp ngay</button>
                </form>
            <% } else { %>
                <p class="guild-panel-copy">Gia nhập Tông Môn trước khi quyên góp tài nguyên cho Linh Thụ.</p>
            <% } %>
        </article>

        <article class="guild-panel">
            <div class="guild-panel-head">
                <div>
                    <span class="guild-kicker">Thành viên</span>
                    <h3>Nội lực Tông Môn</h3>
                </div>
            </div>
            <div class="guild-member-list">
                <% guildDetail.members.forEach((member) => { %>
                    <div class="guild-member-item">
                        <img src="<%= member.avatar || 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>" alt="<%= member.username %>">
                        <div>
                            <strong><%= member.username %></strong>
                            <small>Level <%= member.level || 0 %> · <%= member.guildRole || 'member' %></small>
                        </div>
                    </div>
                <% }) %>
            </div>
        </article>

        <article class="guild-panel">
            <div class="guild-panel-head">
                <div>
                    <span class="guild-kicker">Bảng vàng cống hiến</span>
                    <h3>Top Linh Lực</h3>
                </div>
            </div>
            <div class="guild-contribution-list">
                <% guildDetail.topContributors.forEach((entry) => { %>
                    <div class="guild-contribution-row">
                        <div>
                            <strong><%= entry.username %></strong>
                            <small><%= entry.totalAmount %> vật phẩm</small>
                        </div>
                        <span>+<%= entry.totalContributionValue %> lực</span>
                    </div>
                <% }) %>
            </div>
        </article>

        <article class="guild-panel guild-panel-wide">
            <div class="guild-panel-head">
                <div>
                    <span class="guild-kicker">Đóng góp gần đây</span>
                    <h3>Nhịp sống Tông Môn</h3>
                </div>
            </div>
            <div class="guild-feed-list">
                <% guildDetail.recentContributions.forEach((entry) => { %>
                    <div class="guild-feed-item">
                        <img src="<%= entry.user?.avatar || 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>" alt="<%= entry.user?.username || 'Thành viên' %>">
                        <div>
                            <strong><%= entry.user?.username || 'Thành viên' %></strong>
                            <p>đã quyên góp <%= entry.amount %> <%= entry.resourceType %> cho Linh Thụ.</p>
                        </div>
                        <span>+<%= entry.contributionValue %></span>
                    </div>
                <% }) %>
            </div>
        </article>
    </section>
</main>

<%- include('partials/footer') %>
