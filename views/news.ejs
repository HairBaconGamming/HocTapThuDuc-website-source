<%- include('partials/header', { activePage: 'news' }) %>
<link rel="stylesheet" href="/css/styleNewsFeed.css">

<div class="news-container">
    
    <div class="news-header gsap-fade-down">
        <h1 class="news-title-main">Tạp chí HTTD</h1>
        <p class="news-subtitle">Đọc để hiểu, học để vươn xa. Khám phá những câu chuyện và bí kíp từ cộng đồng học sinh ưu tú.</p>
        
        <% if(user && (user.isPro || user.isAdmin)) { %>
            <a href="/news/post" class="news-btn-write">
                <i class="fas fa-pen-nib"></i> Lên bài ngay
            </a>
        <% } %>
    </div>

    <% if(newsList && newsList.length > 0) { %>
        <!-- BÀI NỔI BẬT (FEATURED POST) -->
        <% const featured = newsList[0]; %>
        <a href="/news/<%= featured._id %>" class="featured-post gsap-fade-up">
            <img src="<%= featured.image || 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1000&auto=format&fit=crop' %>" class="fp-image" alt="Featured">
            <div class="fp-content">
                <span class="fp-cat"><%= featured.category || 'Tiêu Điểm' %></span>
                <h2 class="fp-title"><%= featured.title %></h2>
                <p class="fp-excerpt"><%= featured.content.replace(/[#*`>]/g, '').substring(0, 200) %>...</p>
                
                <div class="post-meta">
                    <div class="meta-author">
                        <img src="<%= featured.author && featured.author.avatar ? featured.author.avatar : 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>" alt="Author">
                        <div class="meta-author-info">
                            <span class="meta-name"><%= featured.author ? featured.author.username : 'Ban Biên Tập' %></span>
                            <span class="meta-date"><%= new Date(featured.createdAt).toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                        </div>
                    </div>
                    <!-- Fake Stats for aesthetic -->
                    <div class="meta-stats">
                        <span><i class="fas fa-eye"></i> <%= Math.floor(Math.random() * 500) + 100 %></span>
                        <span><i class="fas fa-heart"></i> <%= Math.floor(Math.random() * 100) + 10 %></span>
                    </div>
                </div>
            </div>
        </a>

        <!-- DANH SÁCH BÀI VIẾT (GRID) -->
        <div class="news-grid">
            <% for(let i = 1; i < newsList.length; i++) { %>
                <% const news = newsList[i]; %>
                <a href="/news/<%= news._id %>" class="grid-post gsap-stagger">
                    <div class="gp-image-wrapper">
                        <img src="<%= news.image || 'https://images.unsplash.com/photo-1503676260728-1c00da094a0b?q=80&w=1000&auto=format&fit=crop' %>" class="gp-image" alt="Thumbnail">
                        <span class="gp-cat"><%= news.category || 'Tin tức' %></span>
                    </div>
                    <div class="gp-content">
                        <h3 class="gp-title"><%= news.title %></h3>
                        <p class="gp-excerpt"><%= news.content.replace(/[#*`>]/g, '').substring(0, 120) %>...</p>
                        
                        <div class="post-meta">
                            <div class="meta-author">
                                <img src="<%= news.author && news.author.avatar ? news.author.avatar : 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>" alt="Author">
                                <div class="meta-author-info">
                                    <span class="meta-name"><%= news.author ? news.author.username : 'Ban Biên Tập' %></span>
                                    <span class="meta-date"><%= new Date(news.createdAt).toLocaleDateString('vi-VN') %></span>
                                </div>
                            </div>
                            <!-- Fake Stats for aesthetic -->
                            <div class="meta-stats">
                                <span><i class="fas fa-eye"></i> <%= Math.floor(Math.random() * 300) + 50 %></span>
                            </div>
                        </div>
                    </div>
                </a>
            <% } %>
        </div>

    <% } else { %>
        <div style="text-align: center; padding: 100px 20px; color: var(--nf-text-muted);">
            <i class="far fa-newspaper" style="font-size: 5rem; margin-bottom: 20px; opacity: 0.5;"></i>
            <h3 style="font-size: 1.5rem; font-weight: 600;">Chưa có bài viết nào</h3>
            <p>Tòa soạn hiện đang trống, hãy là người đầu tiên lên bài!</p>
        </div>
    <% } %>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        if (typeof gsap === 'undefined') {
            // Fallback: If GSAP fails to load, force everything visible
            document.querySelectorAll('.gsap-fade-down, .gsap-fade-up, .gsap-stagger').forEach(el => {
                el.style.opacity = '1';
                el.style.transform = 'none';
            });
            return;
        }

        gsap.registerPlugin(ScrollTrigger);

        gsap.fromTo(".gsap-fade-down", 
            { y: -30, opacity: 0 },
            { y: 0, opacity: 1, duration: 1, ease: 'power3.out', clearProps: 'all' }
        );

        gsap.fromTo(".gsap-fade-up", 
            { y: 50, opacity: 0 },
            { y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: 0.2, clearProps: 'all' }
        );

        const gridPosts = document.querySelectorAll('.gsap-stagger');
        if (gridPosts.length > 0) {
            gsap.fromTo(gridPosts, 
                { y: 50, opacity: 0 },
                {
                    scrollTrigger: {
                        trigger: ".news-grid",
                        start: "top 85%"
                    },
                    y: 0, 
                    opacity: 1, 
                    duration: 0.8, 
                    stagger: 0.15,
                    ease: 'power3.out',
                    clearProps: 'all'
                }
            );
        }
    });
</script>

<%- include('partials/footer') %>