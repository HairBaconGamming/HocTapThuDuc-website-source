<%- include('partials/header', { activePage: 'news' }) %>
<link rel="stylesheet" href="/css/styleNewsFeed.css">

<!-- ====== HERO SECTION ====== -->
<section class="nf-hero">
    <div class="nf-hero-blob b1"></div>
    <div class="nf-hero-blob b2"></div>
    <div class="nf-hero-blob b3"></div>
    <div class="nf-hero-content gsap-hero">
        <span class="nf-hero-badge">
            <i class="fas fa-fire"></i> Cập nhật liên tục
        </span>
        <h1 class="nf-hero-title">
            Tạp chí <span class="gradient-text">HTTD</span>
        </h1>
        <p class="nf-hero-desc">
            Đọc để hiểu, học để vươn xa. Khám phá những câu chuyện, bí kíp và sự kiện từ cộng đồng học sinh ưu tú.
        </p>
        <% if(user && (user.isPro || user.isAdmin)) { %>
            <a href="/news/post" class="nf-hero-btn">
                <i class="fas fa-pen-nib"></i> Viết bài mới
            </a>
        <% } %>
    </div>
</section>

<!-- ====== CATEGORY FILTER BAR ====== -->
<div class="nf-filter-bar" id="filterBar">
    <button class="nf-filter-tab active" data-cat="all" onclick="filterNews('all', this)">
        <i class="fas fa-globe"></i> Tất cả
    </button>
    <button class="nf-filter-tab" data-cat="Học tập" onclick="filterNews('Học tập', this)">
        <i class="fas fa-book"></i> Học tập
    </button>
    <button class="nf-filter-tab" data-cat="Hoạt động" onclick="filterNews('Hoạt động', this)">
        <i class="fas fa-running"></i> Hoạt động
    </button>
    <button class="nf-filter-tab" data-cat="Tuyển sinh" onclick="filterNews('Tuyển sinh', this)">
        <i class="fas fa-fire-alt"></i> Tuyển sinh
    </button>
    <button class="nf-filter-tab" data-cat="Khác" onclick="filterNews('Khác', this)">
        <i class="fas fa-hashtag"></i> Khác
    </button>
</div>

<!-- ====== CONTENT ====== -->
<div class="nf-content">

<% if(newsList && newsList.length > 0) { %>

    <!-- ====== FEATURED ARTICLE ====== -->
    <% const featured = newsList[0]; %>
    <a href="/news/<%= featured._id %>" class="nf-featured gsap-fade-up" data-category="<%= featured.category || 'Khác' %>">
        <img src="<%= featured.image || 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1200&auto=format&fit=crop' %>" class="nf-featured-img" alt="<%= featured.title %>">
        <div class="nf-featured-overlay">
            <div>
                <span class="nf-featured-badge"><i class="fas fa-bolt"></i> Tiêu Điểm</span>
                <span class="nf-featured-cat"><%= featured.category || 'Tin tức' %></span>
            </div>
            <h2 class="nf-featured-title"><%= featured.title %></h2>
            <p class="nf-featured-excerpt"><%= featured.content.replace(/[#*`>]/g, '').substring(0, 200) %>...</p>
            <div class="nf-featured-meta">
                <img src="<%= featured.author && featured.author.avatar ? featured.author.avatar : 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>" alt="Author">
                <div class="nf-featured-meta-info">
                    <span class="nf-featured-meta-name"><%= featured.author ? featured.author.username : 'Ban Biên Tập' %></span>
                    <span class="nf-featured-meta-date"><%= new Date(featured.createdAt).toLocaleDateString('vi-VN', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                </div>
                <div class="nf-featured-stats">
                    <span><i class="fas fa-eye"></i> <%= featured.views || 0 %></span>
                    <% 
                        let fReacts = [];
                        if (featured.reactions) {
                            const fCounts = [
                                { icon: '👍', count: featured.reactions.like ? featured.reactions.like.length : 0 },
                                { icon: '❤️', count: featured.reactions.heart ? featured.reactions.heart.length : 0 },
                                { icon: '😆', count: featured.reactions.haha ? featured.reactions.haha.length : 0 },
                                { icon: '😢', count: featured.reactions.sad ? featured.reactions.sad.length : 0 },
                                { icon: '😡', count: featured.reactions.angry ? featured.reactions.angry.length : 0 }
                            ];
                            fReacts = fCounts.filter(c => c.count > 0).sort((a,b) => b.count - a.count);
                        }
                        const fTotalReacts = fReacts.reduce((sum, r) => sum + r.count, 0);
                        const fTopIcons = fReacts.slice(0, 3).map(r => r.icon).join('');
                    %>
                    <% if(fTotalReacts > 0) { %>
                        <span style="margin-left: 8px;"><%= fTopIcons %> <%= fTotalReacts %></span>
                    <% } %>
                </div>
            </div>
        </div>
    </a>

    <!-- ====== BENTO GRID ====== -->
    <div class="nf-bento-grid">
        <% for(let i = 1; i < newsList.length; i++) { %>
            <% const news = newsList[i]; %>
            <%
                // Asymmetric pattern: wide(8col), square(4col), square(4col), wide(8col)...
                // Position in grid cycle (0-indexed from grid start)
                const pos = (i - 1) % 4;
                let cardClass = 'nf-card-std';
                if (pos === 0) cardClass = 'nf-card-wide';
                else if (pos === 1 || pos === 2) cardClass = 'nf-card-square';
                else cardClass = 'nf-card-wide';
            %>
            <a href="/news/<%= news._id %>" class="nf-card <%= cardClass %> gsap-stagger" data-category="<%= news.category || 'Khác' %>">
                <div class="nf-card-img-wrap">
                    <img src="<%= news.image || 'https://images.unsplash.com/photo-1503676260728-1c00da094a0b?q=80&w=800&auto=format&fit=crop' %>" class="nf-card-img" alt="<%= news.title %>">
                    <span class="nf-card-cat-badge"><%= news.category || 'Tin tức' %></span>
                </div>
                <div class="nf-card-body">
                    <h3 class="nf-card-title"><%= news.title %></h3>
                    <p class="nf-card-excerpt"><%= news.content.replace(/[#*`>]/g, '').substring(0, 140) %>...</p>
                    <div class="nf-card-meta">
                        <div class="nf-card-author">
                            <img src="<%= news.author && news.author.avatar ? news.author.avatar : 'https://cdn-icons-png.flaticon.com/512/847/847969.png' %>" alt="Author">
                            <div class="nf-card-author-info">
                                <span class="nf-card-author-name"><%= news.author ? news.author.username : 'Ban Biên Tập' %></span>
                                <span class="nf-card-author-date"><%= new Date(news.createdAt).toLocaleDateString('vi-VN') %></span>
                            </div>
                        </div>
                        <div class="nf-card-stats">
                            <span><i class="fas fa-eye"></i> <%= news.views || 0 %></span>
                            <% 
                                let nReacts = [];
                                if (news.reactions) {
                                    const nCounts = [
                                        { icon: '👍', count: news.reactions.like ? news.reactions.like.length : 0 },
                                        { icon: '❤️', count: news.reactions.heart ? news.reactions.heart.length : 0 },
                                        { icon: '😆', count: news.reactions.haha ? news.reactions.haha.length : 0 },
                                        { icon: '😢', count: news.reactions.sad ? news.reactions.sad.length : 0 },
                                        { icon: '😡', count: news.reactions.angry ? news.reactions.angry.length : 0 }
                                    ];
                                    nReacts = nCounts.filter(c => c.count > 0).sort((a,b) => b.count - a.count);
                                }
                                const nTotalReacts = nReacts.reduce((sum, r) => sum + r.count, 0);
                                const nTopIcons = nReacts.slice(0, 3).map(r => r.icon).join('');
                            %>
                            <% if(nTotalReacts > 0) { %>
                                <span style="margin-left: 8px;"><%= nTopIcons %> <%= nTotalReacts %></span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </a>
        <% } %>
    </div>

<% } else { %>
    <!-- ====== EMPTY STATE ====== -->
    <div class="nf-empty">
        <div class="nf-empty-icon"><i class="far fa-newspaper"></i></div>
        <h3>Tòa soạn đang trống</h3>
        <p>Chưa có bài viết nào. Hãy là người đầu tiên lên bài!</p>
        <% if(user && (user.isPro || user.isAdmin)) { %>
            <a href="/news/post" class="nf-empty-btn">
                <i class="fas fa-pen-nib"></i> Lên bài ngay
            </a>
        <% } %>
    </div>
<% } %>

</div>

<!-- ====== SCRIPTS ====== -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

<script>
    // ====== CATEGORY FILTER (Client-side) ======
    function filterNews(cat, btn) {
        // Update tabs
        document.querySelectorAll('.nf-filter-tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');

        // Filter cards
        const featured = document.querySelector('.nf-featured');
        const cards = document.querySelectorAll('.nf-card');

        if (cat === 'all') {
            if (featured) featured.style.display = '';
            cards.forEach(c => c.style.display = '');
        } else {
            if (featured) featured.style.display = featured.dataset.category === cat ? '' : 'none';
            cards.forEach(c => {
                c.style.display = c.dataset.category === cat ? '' : 'none';
            });
        }
    }

    // ====== GSAP ANIMATIONS ======
    document.addEventListener("DOMContentLoaded", () => {
        if (typeof gsap === 'undefined') {
            document.querySelectorAll('.gsap-hero, .gsap-fade-up, .gsap-stagger').forEach(el => {
                el.style.opacity = '1';
                el.style.transform = 'none';
            });
            return;
        }

        gsap.registerPlugin(ScrollTrigger);

        // Hero content
        gsap.fromTo(".gsap-hero",
            { y: 40, opacity: 0 },
            { y: 0, opacity: 1, duration: 1.2, ease: 'power3.out', clearProps: 'all' }
        );

        // Featured post
        gsap.fromTo(".gsap-fade-up",
            { y: 60, opacity: 0 },
            { y: 0, opacity: 1, duration: 1, ease: 'power3.out', delay: 0.3, clearProps: 'all' }
        );

        // Bento grid stagger
        const gridPosts = document.querySelectorAll('.gsap-stagger');
        if (gridPosts.length > 0) {
            gsap.fromTo(gridPosts,
                { y: 50, opacity: 0 },
                {
                    scrollTrigger: {
                        trigger: ".nf-bento-grid",
                        start: "top 85%"
                    },
                    y: 0,
                    opacity: 1,
                    duration: 0.8,
                    stagger: 0.12,
                    ease: 'power3.out',
                    clearProps: 'all'
                }
            );
        }
    });
</script>

<%- include('partials/footer') %>