<%- include('partials/header') %>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
<link rel="stylesheet" href="/css/styleQA.css">

<%
// Giữ nguyên logic xử lý dữ liệu an toàn
const safeQuestions = Array.isArray(questions) ? questions : [];
const safeSubjects = Array.isArray(subjects) ? subjects : [];
const safeGrades = Array.isArray(grades) ? grades : [];
const safeFilters = filters || {};
const safeSidebar = sidebar || {};
const safeContributorWeekly = Array.isArray(safeSidebar.contributors?.weekly) ? safeSidebar.contributors.weekly : [];
const safeHotTags = Array.isArray(safeSidebar.hotTags) ? safeSidebar.hotTags : [];
const sidebarStats = safeSidebar.stats || {};
const currentSort = ['newest', 'hot', 'unanswered', 'mine'].includes(safeFilters.sort) ? safeFilters.sort : 'newest';
const currentSubject = safeSubjects.includes(safeFilters.subject) ? safeFilters.subject : '';
const currentGrade = safeGrades.includes(safeFilters.grade) ? safeFilters.grade : '';
const currentQuery = String(safeFilters.q || '').trim();

// Hàm tạo query string
const queryFor = (overrides = {}) => {
    const params = new URLSearchParams();
    const next = { sort: currentSort, subject: currentSubject, grade: currentGrade, q: currentQuery, ...overrides };
    Object.entries(next).forEach(([key, value]) => { if (value) params.set(key, String(value)); });
    const queryString = params.toString();
    return queryString ? `?${queryString}` : '';
};
%>

<div class="qa-shell">
    <section class="qa-hero">
        <div class="qa-hero-content">
            <span class="qa-kicker"><i class="fas fa-life-ring"></i> Bảng Cầu Cứu HTTD</span>
            <h1 class="qa-hero-title">Giải bài khó, nhận thưởng vàng, khẳng định vị thế.</h1>
            <p class="qa-hero-desc">
                Nơi những thắc mắc hóc búa nhất được cộng đồng chung tay giải quyết. Thảo luận từng bước, treo thưởng để thu hút cao thủ và đóng góp điểm danh vọng cho Tông Môn của bạn.
            </p>

            <div class="qa-hero-actions">
                <% if (user) { %>
                    <a href="/qa/ask" class="qa-btn qa-btn-primary">
                        <i class="fas fa-plus"></i> Đăng câu hỏi ngay
                    </a>
                <% } else { %>
                    <a href="/login" class="qa-btn qa-btn-primary">
                        <i class="fas fa-sign-in-alt"></i> Đăng nhập để hỏi
                    </a>
                <% } %>
                <a href="/qa/community" class="qa-btn qa-btn-secondary">
                    <i class="fas fa-chart-line"></i> Bảng Phong Thần
                </a>
            </div>
        </div>

        <div class="qa-hero-stats">
            <div class="qa-hero-stat">
                <strong><%= safeQuestions.length %></strong>
                <span>Bài đang hiện</span>
            </div>
            <div class="qa-hero-stat">
                <strong><%= Number(sidebarStats.openCount || 0).toLocaleString('vi-VN') %></strong>
                <span>Đang chờ giải</span>
            </div>
            <div class="qa-hero-stat">
                <strong><%= Number(sidebarStats.resolvedCount || 0).toLocaleString('vi-VN') %></strong>
                <span>Đã giải cứu</span>
            </div>
        </div>
    </section>

    <div class="qa-mobile-filter-toggle" style="display: none; margin-bottom: 16px;">
        <button class="qa-btn qa-btn-secondary" style="width: 100%; color: var(--qa-text); background: var(--qa-surface-glass);" onclick="document.querySelector('.qa-layout').classList.toggle('show-sidebar')">
            <i class="fas fa-sliders-h"></i> Hiện / Ẩn bộ lọc
        </button>
    </div>

    <div class="qa-layout">
        <aside class="qa-rail">
            <section class="qa-rail-card">
                <h2 class="qa-panel-title">Phân loại</h2>
                <div class="qa-filter-list">
                    <a href="<%= queryFor({ sort: 'newest' }) %>" class="qa-filter-link <%= currentSort === 'newest' ? 'is-active' : '' %>">
                        <span>Mới nhất</span> <i class="fas fa-bolt"></i>
                    </a>
                    <a href="<%= queryFor({ sort: 'hot' }) %>" class="qa-filter-link <%= currentSort === 'hot' ? 'is-active' : '' %>">
                        <span>Đang hot</span> <i class="fas fa-fire" style="color: #ef4444;"></i>
                    </a>
                    <a href="<%= queryFor({ sort: 'unanswered' }) %>" class="qa-filter-link <%= currentSort === 'unanswered' ? 'is-active' : '' %>">
                        <span>Cần giải cứu</span> <i class="far fa-life-ring"></i>
                    </a>
                    <% if (user) { %>
                        <a href="<%= queryFor({ sort: 'mine' }) %>" class="qa-filter-link <%= currentSort === 'mine' ? 'is-active' : '' %>">
                            <span>Bài của tôi</span> <i class="fas fa-user-edit"></i>
                        </a>
                    <% } %>
                </div>
            </section>

            <section class="qa-rail-card">
                <h2 class="qa-panel-title">Môn học</h2>
                <div class="qa-filter-list">
                    <a href="<%= queryFor({ subject: '' }) %>" class="qa-chip-link <%= !currentSubject ? 'is-active' : '' %>">
                        Tất cả môn
                    </a>
                    <% safeSubjects.forEach((subject) => { %>
                        <a href="<%= queryFor({ subject }) %>" class="qa-chip-link <%= currentSubject === subject ? 'is-active' : '' %>">
                            <%= subject %>
                        </a>
                    <% }) %>
                </div>
            </section>
        </aside>

        <section class="qa-feed">
            <div class="qa-feed-head qa-panel">
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
                    <h2 style="margin: 0;">Feed Học Thuật</h2>
                    <div class="qa-metrics">
                        <% if (currentSubject) { %><span><i class="fas fa-book"></i> <%= currentSubject %></span><% } %>
                        <% if (currentGrade) { %><span><i class="fas fa-layer-group"></i> Khối <%= currentGrade %></span><% } %>
                    </div>
                </div>
            </div>

            <% if (safeQuestions.length > 0) { %>
                <div class="qa-feed-list" style="display: grid; gap: 20px;">
                    <% safeQuestions.forEach((question) => { %>
                        <a href="<%= question.href || ('/qa/questions/' + question._id) %>" class="qa-feed-card">
                            <div class="qa-card-top">
                                <span class="qa-badge qa-badge-subject"><%= question.subject || 'Khác' %></span>
                                <span class="qa-badge qa-badge-grade">Lớp <%= question.grade || 'Chung' %></span>
                                <% if (Number(question.bountyAmount || 0) > 0) { %>
                                    <span class="qa-badge qa-badge-bounty"><i class="fas fa-gem"></i> <%= Number(question.bountyAmount).toLocaleString('vi-VN') %></span>
                                <% } %>
                            </div>

                            <div class="qa-card-content">
                                <h3 class="qa-card-title"><%= question.title || 'Câu hỏi ẩn danh' %></h3>
                                <p class="qa-card-preview"><%= question.previewText || 'Không có mô tả tóm tắt.' %></p>
                            </div>

                            <div class="qa-card-meta">
                                <div class="qa-author-row">
                                    <img class="qa-avatar-sm" src="<%= question.author?.avatar || '/default.png' %>" alt="Avatar">
                                    <div class="qa-author-meta">
                                        <div class="qa-author-name"><%= question.author?.username || 'Ẩn danh' %></div>
                                        <div class="qa-author-sub"><time data-relative-time datetime="<%= question.createdAt %>"><%= new Date(question.createdAt).toLocaleString('vi-VN') %></time></div>
                                    </div>
                                </div>
                                <div class="qa-metrics">
                                    <span><i class="fas fa-comment"></i> <%= Number(question.answerCount || 0) %></span>
                                    <span><i class="fas fa-eye"></i> <%= Number(question.viewCount || 0) %></span>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="qa-panel qa-empty">
                    <i class="fas fa-wind" style="font-size: 3rem; color: var(--qa-muted); margin-bottom: 16px; opacity: 0.5;"></i>
                    <strong>Không tìm thấy câu hỏi nào.</strong>
                    <p>Hãy thử xóa bộ lọc hoặc trở thành người đầu tiên đặt câu hỏi trong nhóm này!</p>
                </div>
            <% } %>
        </section>

        <aside class="qa-sidebar">
            <section class="qa-sidebar-card">
                <h2 class="qa-panel-title">Top Giải Cứu Tuần</h2>
                <div class="qa-contributor-list">
                    <% if (safeContributorWeekly.length > 0) { %>
                        <% safeContributorWeekly.forEach((contributor) => { %>
                            <a href="/profile/view/<%= contributor.userId %>" class="qa-contributor-row" style="text-decoration:none; color:inherit;">
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <img class="qa-avatar-sm" src="<%= contributor.avatar || '/default.png' %>" alt="Avatar">
                                    <div>
                                        <div class="qa-author-name" style="font-size: 0.9rem;">#<%= contributor.rank %> <%= contributor.username %></div>
                                        <div class="qa-author-sub"><%= contributor.tier?.label || 'Tân Binh' %></div>
                                    </div>
                                </div>
                                <strong style="color: var(--qa-primary);"><%= Number(contributor.score || 0) %> pt</strong>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <div class="qa-empty" style="padding: 16px 0;">
                            <p style="margin: 0; font-size: 0.9rem;">Tuần này chưa có ai bùng nổ.</p>
                        </div>
                    <% } %>
                </div>
            </section>
        </aside>
    </div>
</div>

<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"></script>
<script src="/js/qa.js"></script>

<style>
    @media (max-width: 1024px) {
        .qa-mobile-filter-toggle { display: block !important; }
        .qa-rail, .qa-sidebar { display: none; }
        .show-sidebar .qa-rail, .show-sidebar .qa-sidebar { display: flex; flex-direction: column; }
    }
</style>

<%- include('partials/footer') %>