<section class="admin-card">
    <form method="GET" action="<%= path %>" class="filter-bar">
        <select name="status">
            <option value="">Tất cả trạng thái</option>
            <% ['revealed', 'claiming', 'claimed', 'ignored'].forEach((status) => { %>
                <option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>><%= status %></option>
            <% }) %>
        </select>
        <select name="sort">
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Cũ nhất</option>
        </select>
        <button class="admin-btn admin-btn-primary" type="submit">Lọc</button>
    </form>

    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Lesson reward</th>
                    <th>User / Lesson</th>
                    <th>Reward</th>
                    <th>Status</th>
                    <th>Chi tiết</th>
                </tr>
            </thead>
            <tbody>
                <% rewardEvents.forEach((event) => { %>
                    <tr>
                        <td><%= event.eventType %></td>
                        <td><%= event.user?.username || 'Ẩn danh' %> · <%= event.lesson?.title || 'Không rõ lesson' %></td>
                        <td><%= event.rewardType %> · <%= formatNumber(event.rewardAmount || event.rewardBundle?.gold || 0) %></td>
                        <td><span class="admin-badge info"><%= event.status %></span></td>
                        <td><a class="admin-btn admin-btn-ghost" href="<%= buildAdminUrl(path, filters, { detailId: event._id, page: pagination.page }) %>">Chi tiết</a></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <%- include('../pagination') %>
</section>
