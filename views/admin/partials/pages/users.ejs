<section class="admin-card">
    <form method="GET" action="<%= path %>" class="filter-bar">
        <input type="text" name="q" value="<%= filters.q %>" placeholder="Tìm username, email, lớp, trường">
        <select name="status">
            <option value="">Tất cả trạng thái</option>
            <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Đang hoạt động</option>
            <option value="banned" <%= filters.status === 'banned' ? 'selected' : '' %>>Đang bị khóa</option>
            <option value="admin" <%= filters.status === 'admin' ? 'selected' : '' %>>Admin</option>
            <option value="teacher" <%= filters.status === 'teacher' ? 'selected' : '' %>>Giáo viên</option>
            <option value="pro" <%= filters.status === 'pro' ? 'selected' : '' %>>PRO</option>
        </select>
        <select name="sort">
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Cũ nhất</option>
            <option value="username_asc" <%= filters.sort === 'username_asc' ? 'selected' : '' %>>Tên A-Z</option>
            <option value="points_desc" <%= filters.sort === 'points_desc' ? 'selected' : '' %>>Điểm cao trước</option>
        </select>
        <input type="date" name="dateFrom" value="<%= filters.dateFrom %>">
        <input type="date" name="dateTo" value="<%= filters.dateTo %>">
        <button class="admin-btn admin-btn-primary" type="submit">Lọc</button>
    </form>

    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Tài khoản</th>
                    <th>Vai trò</th>
                    <th>Điểm</th>
                    <th>Hoạt động</th>
                    <th>Login gần nhất</th>
                    <th>Tác vụ</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach((item) => { %>
                    <tr class="<%= selectedUser && String(selectedUser._id) === String(item._id) ? 'is-selected' : '' %>">
                        <td>
                            <div class="entity-stack">
                                <strong><%= item.username %></strong>
                                <span><%= item.email || 'Chưa có email' %></span>
                            </div>
                        </td>
                        <td>
                            <div class="badge-row">
                                <% if (item.isAdmin) { %><span class="admin-badge danger">Admin</span><% } %>
                                <% if (item.isTeacher) { %><span class="admin-badge info">Teacher</span><% } %>
                                <% if (item.isPro) { %><span class="admin-badge warning">PRO</span><% } %>
                                <% if (!item.isAdmin && !item.isTeacher && !item.isPro) { %><span class="admin-badge neutral">Member</span><% } %>
                                <% if (item.isBanned) { %><span class="admin-badge danger">Banned</span><% } %>
                            </div>
                        </td>
                        <td><%= formatNumber(item.points || 0) %></td>
                        <td><%= formatNumber(item.activity.minutes || 0) %> phút</td>
                        <td><%= item.lastLoginIP || 'Chưa ghi nhận' %></td>
                        <td>
                            <div class="table-actions">
                                <a class="admin-btn admin-btn-ghost" href="<%= buildAdminUrl(path, filters, { detailId: item._id, page: pagination.page }) %>">Chi tiết</a>
                                <% if (item.isBanned) { %>
                                    <form method="POST" action="/admin/users/<%= item._id %>/unban">
                                        <input type="hidden" name="_csrf" value="<%= adminCsrfToken %>">
                                        <input type="hidden" name="returnTo" value="<%= currentUrl %>">
                                        <button class="admin-btn admin-btn-success" type="submit">Mở khóa</button>
                                    </form>
                                <% } else { %>
                                    <form method="POST" action="/admin/users/<%= item._id %>/ban" data-confirm="Khóa tài khoản <%= item.username %>?">
                                        <input type="hidden" name="_csrf" value="<%= adminCsrfToken %>">
                                        <input type="hidden" name="returnTo" value="<%= currentUrl %>">
                                        <button class="admin-btn admin-btn-danger" type="submit">Khóa</button>
                                    </form>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <%- include('../pagination') %>
</section>
