<section class="admin-card">
    <form method="GET" action="<%= path %>" class="filter-bar">
        <select name="status">
            <option value="">Tất cả trạng thái</option>
            <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="approved" <%= filters.status === 'approved' ? 'selected' : '' %>>Approved</option>
            <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
            <option value="cancelled" <%= filters.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
        </select>
        <select name="sort">
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Cũ nhất</option>
        </select>
        <button class="admin-btn admin-btn-primary" type="submit">Lọc</button>
    </form>

    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Guild</th>
                    <th>Applicant</th>
                    <th>Message</th>
                    <th>Status</th>
                    <th>Tác vụ</th>
                </tr>
            </thead>
            <tbody>
                <% applications.forEach((application) => { %>
                    <tr class="<%= selectedApplication && String(selectedApplication._id) === String(application._id) ? 'is-selected' : '' %>">
                        <td><%= application.guild?.name || 'Guild không rõ' %></td>
                        <td><%= application.applicant?.username || 'Ẩn danh' %></td>
                        <td><%= String(application.message || '').slice(0, 80) || 'Không có lời nhắn' %></td>
                        <td><span class="admin-badge <%= application.status === 'pending' ? 'warning' : application.status === 'approved' ? 'success' : 'danger' %>"><%= application.status %></span></td>
                        <td><a class="admin-btn admin-btn-ghost" href="<%= buildAdminUrl(path, filters, { detailId: application._id, page: pagination.page }) %>">Chi tiết</a></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <%- include('../pagination') %>
</section>
