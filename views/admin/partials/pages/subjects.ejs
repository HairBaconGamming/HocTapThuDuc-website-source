<section class="admin-card">
    <form method="GET" action="<%= path %>" class="filter-bar">
        <input type="text" name="q" value="<%= filters.q %>" placeholder="Tìm môn học">
        <select name="sort">
            <option value="name_asc" <%= filters.sort === 'name_asc' ? 'selected' : '' %>>Tên A-Z</option>
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Cũ nhất</option>
        </select>
        <button class="admin-btn admin-btn-primary" type="submit">Lọc</button>
    </form>

    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Môn học</th>
                    <th>Coverage</th>
                    <th>Icon</th>
                    <th>Tác vụ</th>
                </tr>
            </thead>
            <tbody>
                <% subjects.forEach((subject) => { %>
                    <tr class="<%= selectedSubject && String(selectedSubject._id) === String(subject._id) ? 'is-selected' : '' %>">
                        <td>
                            <div class="entity-stack">
                                <strong><%= subject.name %></strong>
                                <span>ID: <%= subject._id %></span>
                            </div>
                        </td>
                        <td><%= subject.courseCount %> courses · <%= subject.lessonCount %> lessons</td>
                        <td><%= subject.image ? 'Có icon' : 'Chưa có icon' %></td>
                        <td>
                            <div class="table-actions">
                                <a class="admin-btn admin-btn-ghost" href="<%= buildAdminUrl(path, filters, { detailId: subject._id, page: pagination.page }) %>"><%= selectedSubject && String(selectedSubject._id) === String(subject._id) ? 'Đang sửa' : 'Sửa' %></a>
                                <form method="POST" action="/admin/content/subjects/<%= subject._id %>/delete" data-confirm="Xóa môn học <%= subject.name %>?">
                                    <input type="hidden" name="_csrf" value="<%= adminCsrfToken %>">
                                    <input type="hidden" name="returnTo" value="<%= currentUrl %>">
                                    <button class="admin-btn admin-btn-danger" type="submit">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <%- include('../pagination') %>
</section>
