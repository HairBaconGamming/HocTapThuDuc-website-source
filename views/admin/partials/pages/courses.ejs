<section class="admin-card">
    <form method="GET" action="<%= path %>" class="filter-bar filter-bar-extended">
        <input type="text" name="q" value="<%= filters.q %>" placeholder="Tìm khóa học hoặc mô tả">
        <select name="status">
            <option value="">Tất cả trạng thái</option>
            <option value="published" <%= filters.status === 'published' ? 'selected' : '' %>>Public</option>
            <option value="draft" <%= filters.status === 'draft' ? 'selected' : '' %>>Draft</option>
            <option value="pro" <%= filters.status === 'pro' ? 'selected' : '' %>>PRO</option>
        </select>
        <select name="subjectId">
            <option value="">Tất cả môn</option>
            <% subjectOptions.forEach((subject) => { %>
                <option value="<%= subject._id %>" <%= filters.subjectId === String(subject._id) ? 'selected' : '' %>><%= subject.name %></option>
            <% }) %>
        </select>
        <select name="authorId">
            <option value="">Tất cả tác giả</option>
            <% authorOptions.forEach((author) => { %>
                <option value="<%= author._id %>" <%= filters.authorId === String(author._id) ? 'selected' : '' %>><%= author.username %></option>
            <% }) %>
        </select>
        <select name="sort">
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Cũ nhất</option>
            <option value="title_asc" <%= filters.sort === 'title_asc' ? 'selected' : '' %>>Tên A-Z</option>
            <option value="published_first" <%= filters.sort === 'published_first' ? 'selected' : '' %>>Public trước</option>
        </select>
        <button class="admin-btn admin-btn-primary" type="submit">Lọc</button>
    </form>

    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Khóa học</th>
                    <th>Môn / Tác giả</th>
                    <th>Scope</th>
                    <th>Units / Lessons</th>
                    <th>Tác vụ</th>
                </tr>
            </thead>
            <tbody>
                <% courses.forEach((course) => { %>
                    <tr>
                        <td>
                            <div class="entity-stack">
                                <strong><%= course.title %></strong>
                                <span><%= course.description || 'Chưa có mô tả' %></span>
                            </div>
                        </td>
                        <td>
                            <div class="entity-stack">
                                <strong><%= course.subjectId?.name || 'Chưa gắn môn' %></strong>
                                <span><%= course.author?.username || 'Ẩn danh' %></span>
                            </div>
                        </td>
                        <td>
                            <div class="badge-row">
                                <span class="admin-badge <%= course.isPublished ? 'success' : 'warning' %>"><%= course.isPublished ? 'Public' : 'Draft' %></span>
                                <% if (course.isPro) { %><span class="admin-badge info">PRO</span><% } %>
                            </div>
                        </td>
                        <td><%= course.unitCount %> units · <%= course.lessonCount %> lessons</td>
                        <td>
                            <div class="table-actions">
                                <a class="admin-btn admin-btn-ghost" href="<%= buildAdminUrl(path, filters, { detailId: course._id, page: pagination.page }) %>">Chi tiết</a>
                                <form method="POST" action="/admin/content/courses/<%= course._id %>/publish">
                                    <input type="hidden" name="_csrf" value="<%= adminCsrfToken %>">
                                    <input type="hidden" name="returnTo" value="<%= currentUrl %>">
                                    <input type="hidden" name="isPublished" value="<%= course.isPublished ? '' : 'on' %>">
                                    <button class="admin-btn <%= course.isPublished ? 'admin-btn-warning' : 'admin-btn-success' %>" type="submit"><%= course.isPublished ? 'Ẩn' : 'Public' %></button>
                                </form>
                                <form method="POST" action="/admin/content/courses/<%= course._id %>/delete" data-confirm="Xóa khóa học <%= course.title %> và toàn bộ unit/lesson liên quan?">
                                    <input type="hidden" name="_csrf" value="<%= adminCsrfToken %>">
                                    <input type="hidden" name="returnTo" value="<%= currentUrl %>">
                                    <button class="admin-btn admin-btn-danger" type="submit">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <%- include('../pagination') %>
</section>
