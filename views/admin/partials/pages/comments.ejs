<section class="admin-card">
    <form method="GET" action="<%= path %>" class="filter-bar filter-bar-extended">
        <input type="text" name="q" value="<%= filters.q %>" placeholder="Tìm nội dung bình luận">
        <select name="status">
            <option value="">Tất cả trạng thái</option>
            <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
            <option value="deleted" <%= filters.status === 'deleted' ? 'selected' : '' %>>Deleted</option>
        </select>
        <select name="authorId">
            <option value="">Tất cả tác giả</option>
            <% authorOptions.forEach((author) => { %>
                <option value="<%= author._id %>" <%= filters.authorId === String(author._id) ? 'selected' : '' %>><%= author.username %></option>
            <% }) %>
        </select>
        <select name="sort">
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Cũ nhất</option>
            <option value="likes_desc" <%= filters.sort === 'likes_desc' ? 'selected' : '' %>>Likes cao</option>
        </select>
        <button class="admin-btn admin-btn-primary" type="submit">Lọc</button>
    </form>

    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Bình luận</th>
                    <th>Lesson</th>
                    <th>Tác giả</th>
                    <th>Tín hiệu</th>
                    <th>Tác vụ</th>
                </tr>
            </thead>
            <tbody>
                <% comments.forEach((comment) => { %>
                    <tr class="<%= selectedComment && String(selectedComment._id) === String(comment._id) ? 'is-selected' : '' %>">
                        <td>
                            <div class="entity-stack">
                                <strong><%= comment.isDeleted ? 'Đã ẩn' : 'Đang hiển thị' %></strong>
                                <span><%= String(comment.content || '').slice(0, 90) %></span>
                            </div>
                        </td>
                        <td><%= comment.lesson?.title || 'Không rõ bài học' %></td>
                        <td><%= comment.user?.username || 'Ẩn danh' %></td>
                        <td><%= formatNumber(comment.likes) %> likes · <%= comment.replyCount %> replies</td>
                        <td><a class="admin-btn admin-btn-ghost" href="<%= buildAdminUrl(path, filters, { detailId: comment._id, page: pagination.page }) %>">Chi tiết</a></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <%- include('../pagination') %>
</section>
