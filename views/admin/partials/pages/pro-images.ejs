<section class="admin-card">
    <form method="GET" action="<%= path %>" class="filter-bar filter-bar-extended">
        <input type="text" name="q" value="<%= filters.q %>" placeholder="Tìm display name, filename, URL">
        <select name="authorId">
            <option value="">Tất cả uploader</option>
            <% authorOptions.forEach((author) => { %>
                <option value="<%= author._id %>" <%= filters.authorId === String(author._id) ? 'selected' : '' %>><%= author.username %></option>
            <% }) %>
        </select>
        <select name="sort">
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Mới nhất</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Cũ nhất</option>
            <option value="largest" <%= filters.sort === 'largest' ? 'selected' : '' %>>Nặng nhất</option>
        </select>
        <button class="admin-btn admin-btn-primary" type="submit">Lọc</button>
    </form>

    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Asset</th>
                    <th>Uploader</th>
                    <th>Nguồn</th>
                    <th>Dung lượng</th>
                    <th>Tác vụ</th>
                </tr>
            </thead>
            <tbody>
                <% images.forEach((image) => { %>
                    <tr>
                        <td>
                            <div class="entity-stack">
                                <strong><%= image.displayName || image.filename || 'Asset không tên' %></strong>
                                <span><%= image.url %></span>
                            </div>
                        </td>
                        <td><%= image.user?.username || 'Ẩn danh' %></td>
                        <td><span class="admin-badge info"><%= image.source %></span></td>
                        <td><%= image.displaySize %></td>
                        <td><a class="admin-btn admin-btn-ghost" href="<%= buildAdminUrl(path, filters, { detailId: image._id, page: pagination.page }) %>">Chi tiết</a></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <%- include('../pagination') %>
</section>
