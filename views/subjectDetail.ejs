<%- include('partials/header') %>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="/css/styleSubjectDetail.css">

<!-- CINEMATIC HERO -->
<div class="subject-hero" style="background-image: url('<%= subject.image || 'https://i.ibb.co/BVnNtLhp/default-course.png' %>');">
    <div class="hero-overlay"></div>
    <div class="hero-container">
        <div class="hero-content">
            <span class="hero-kicker">Lộ trình môn học</span>
            <h1 class="hero-title"><%= subject.name %></h1>
            <p class="hero-desc"><%= subject.description || 'Khám phá các khóa học chất lượng cao thuộc bộ môn này, được thiết kế bài bản để giúp bạn làm chủ kiến thức từ cơ bản đến nâng cao.' %></p>
            
            <div class="hero-stats">
                <div class="stat-pill">
                    <i class="fas fa-layer-group"></i>
                    <span><strong><%= courses.length %></strong> Khóa học</span>
                </div>
                <div class="stat-pill">
                    <i class="fas fa-video"></i>
                    <span><strong><%= typeof totalLessons !== 'undefined' ? totalLessons : 0 %></strong> Bài học</span>
                </div>
                <div class="stat-pill">
                    <i class="fas fa-users"></i>
                    <span><strong><%= typeof totalStudents !== 'undefined' ? totalStudents : 0 %></strong> Học viên</span>
                </div>
                <div class="stat-pill">
                    <i class="fas fa-eye"></i>
                    <span><strong><%= typeof totalViews !== 'undefined' ? totalViews : 0 %></strong> Lượt xem</span>
                </div>
                <div class="stat-pill">
                    <i class="fas fa-heart"></i>
                    <span><strong><%= typeof totalLikes !== 'undefined' ? totalLikes : 0 %></strong> Lượt thích</span>
                </div>
            </div>

            <button class="hero-cta" onclick="document.getElementById('course-grid-section').scrollIntoView({behavior: 'smooth'})">
                Khám phá lộ trình <i class="fas fa-arrow-down"></i>
            </button>
        </div>
    </div>
</div>

<div class="main-container" id="course-grid-section">
    <!-- LEFT COLUMN: COURSE GRID -->
    <div class="content-col">
        <div class="section-header">
            <h2 class="section-title">Các khóa học trong lộ trình</h2>
            <div class="filter-pills" style="display: none;">
                <button class="filter-pill active">Tất cả</button>
                <button class="filter-pill">Mới nhất</button>
                <button class="filter-pill">Phổ biến</button>
            </div>
        </div>

        <% if(courses && courses.length > 0) { %>
            <div class="course-grid">
                <% courses.forEach(course => { %>
                    <div class="course-card">
                        <a href="<%= buildCoursePath(course) %>" class="card-thumb-link">
                            <img src="<%= course.thumbnail || 'https://i.ibb.co/BVnNtLhp/default-course.png' %>" class="card-thumb" alt="<%= course.title %>">
                            <div class="card-badges">
                                <% if(course.isPro) { %>
                                    <span class="badge pro"><i class="fas fa-crown"></i> PRO</span>
                                <% } %>
                                <% if(!course.isPublished) { %>
                                    <span class="badge draft"><i class="fas fa-lock"></i> Sắp ra mắt</span>
                                <% } %>
                            </div>
                        </a>

                        <div class="card-body">
                            <h3 class="card-title">
                                <a href="<%= buildCoursePath(course) %>"><%= course.title %></a>
                            </h3>
                            
                            <p class="card-desc">
                                <%= course.description || 'Chưa có mô tả ngắn. Khóa học này đang được biên soạn nội dung.' %>
                            </p>

                            <div class="subject-card-stats">
                                <span><i class="fas fa-book-open"></i> <%= course.lessonCount || 0 %> bài</span>
                                <span><i class="fas fa-eye"></i> <%= (course.viewCount || 0).toLocaleString('vi-VN') %></span>
                            </div>

                            <% if (user) { %>
                                <div class="card-progress">
                                    <div class="progress-info">
                                        <span class="progress-text">Tiến độ: <%= course.progressPercent || 0 %>%</span>
                                        <span class="progress-count"><%= course.completedCount || 0 %>/<%= course.lessonCount || 0 %> bài</span>
                                    </div>
                                    <div class="progress-bar-bg">
                                        <div class="progress-bar-fill" style="width: <%= course.progressPercent || 0 %>%"></div>
                                    </div>
                                </div>
                            <% } %>

                            <div class="author-info">
                                <% 
                                    const author = course.createdBy || course.author || {}; 
                                    const avatar = author.avatar || 'https://static.vecteezy.com/system/resources/previews/013/360/247/non_2x/default-avatar-photo-icon-social-media-profile-sign-symbol-vector.jpg';
                                    const name = author.username || 'Ban biên tập';
                                %>
                                <img src="<%= avatar %>" class="author-avatar" alt="<%= name %>">
                                <span class="author-name"><%= name %></span>
                            </div>
                        </div>

                        <div class="card-footer">
                            <button class="subject-card-like-btn <%= course.isLikedByUser ? 'is-liked' : '' %>"
                                    data-course-id="<%= course._id %>"
                                    data-liked="<%= course.isLikedByUser %>"
                                    title="Thích khóa học này">
                                <i class="<%= course.isLikedByUser ? 'fas' : 'far' %> fa-heart"></i>
                                <span class="like-count"><%= course.likeCount || 0 %></span>
                            </button>
                            
                            <a href="<%= buildCoursePath(course) %>" class="card-cta">
                                <%= course.progressPercent > 0 ? 'Học tiếp' : 'Vào học' %> <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="fas fa-box-open"></i>
                </div>
                <h3>Chưa có khóa học nào</h3>
                <p>Nội dung cho lộ trình này đang được các giảng viên xây dựng và sẽ sớm ra mắt.</p>
                <a href="/subjects" class="btn btn-primary mt-3">Khám phá lộ trình khác</a>
            </div>
        <% } %>
    </div>

    <!-- RIGHT COLUMN: STICKY SIDEBAR -->
    <div class="sidebar-col">
        <div class="sticky-sidebar">
            <div class="sidebar-widget">
                <h3 class="widget-title">Tổng quan lộ trình</h3>
                <div class="widget-stats">
                    <div class="w-stat-row">
                        <span class="w-stat-label"><i class="fas fa-book"></i> Khóa học</span>
                        <span class="w-stat-val"><%= courses.length %></span>
                    </div>
                    <div class="w-stat-row">
                        <span class="w-stat-label"><i class="fas fa-file-video"></i> Bài học</span>
                        <span class="w-stat-val"><%= typeof totalLessons !== 'undefined' ? totalLessons : 0 %></span>
                    </div>
                    <div class="w-stat-row">
                        <span class="w-stat-label"><i class="fas fa-eye"></i> Lượt xem</span>
                        <span class="w-stat-val"><%= typeof totalViews !== 'undefined' ? totalViews : 0 %></span>
                    </div>
                    <div class="w-stat-row">
                        <span class="w-stat-label"><i class="fas fa-heart"></i> Yêu thích</span>
                        <span class="w-stat-val"><%= typeof totalLikes !== 'undefined' ? totalLikes : 0 %></span>
                    </div>
                </div>
            </div>

            <% if (user) { %>
                <div class="sidebar-widget">
                    <h3 class="widget-title">Tiến độ của bạn</h3>
                    <% 
                        let totalCompleted = 0;
                        let totalSubjectLessons = typeof totalLessons !== 'undefined' ? totalLessons : 0;
                        if (courses && courses.length > 0) {
                            courses.forEach(c => totalCompleted += (c.completedCount || 0));
                        }
                        let overallProgress = totalSubjectLessons > 0 ? Math.round((totalCompleted / totalSubjectLessons) * 100) : 0;
                    %>
                    <div class="overall-progress-circle">
                        <svg viewBox="0 0 36 36" class="circular-chart <%= overallProgress >= 100 ? 'success' : 'blue' %>">
                            <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                            <path class="circle" stroke-dasharray="<%= overallProgress %>, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                            <text x="18" y="20.35" class="percentage"><%= overallProgress %>%</text>
                        </svg>
                    </div>
                    <p class="text-center text-muted small mt-2">Hoàn thành <%= totalCompleted %>/<%= totalSubjectLessons %> bài học</p>
                </div>
            <% } %>

            <a href="/subjects" class="sidebar-link">
                <i class="fas fa-arrow-left"></i> Xem tất cả môn học
            </a>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // Client-side JS for course like toggle
    const isLoggedIn = <%= !!user %>;
    
    document.querySelectorAll('.subject-card-like-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            e.preventDefault();
            e.stopPropagation();
            
            if (!isLoggedIn) {
                alert('Vui lòng đăng nhập để thích khóa học.');
                window.location.href = '/login';
                return;
            }
            
            const courseId = btn.dataset.courseId;
            try {
                const res = await fetch(`/api/course/${courseId}/like`, { method: 'POST' });
                const data = await res.json();
                
                if (data.error) {
                    alert(data.error);
                    return;
                }
                
                // Update UI
                btn.classList.toggle('is-liked', data.liked);
                btn.dataset.liked = data.liked;
                
                const icon = btn.querySelector('i');
                icon.className = data.liked ? 'fas fa-heart' : 'far fa-heart';
                
                btn.querySelector('.like-count').textContent = data.likeCount;
                
            } catch (err) {
                console.error('Like failed:', err);
                alert('Có lỗi xảy ra khi thả tim.');
            }
        });
    });
});
</script>

<%- include('partials/footer') %>
