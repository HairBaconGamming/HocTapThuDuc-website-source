# MongoDB Configuration
# Get your MongoDB Atlas URI from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGO_URI="mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/studypro?retryWrites=true&w=majority"

# Session & Security
SESSION_SECRET=your_super_secret_session_key_here_change_me
JWT_SECRET=your_super_secret_jwt_key_here_change_me
# You can temporarily reuse the same value for both in production, but using two separate secrets is recommended.

# Server Configuration
PORT=3000
NODE_ENV=development

# Passport/OAuth (Optional - for social login)
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

GOOGLE_ID=your_google_client_id
GOOGLE_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# Optional: load client_id/client_secret from the Google JSON file on local machines
# GOOGLE_OAUTH_CONFIG_PATH=D:/Download/client_secret_xxx.apps.googleusercontent.com.json

# Email Configuration (Optional - for notifications)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password

# Upload Configuration
MAX_FILE_SIZE=5242880  # 5MB in bytes

# Render.com Configuration (if deploying to Render)
# RENDER_EXTERNAL_URL=https://your-app-name.onrender.com

# Lesson TTS
LESSON_TTS_DEFAULT_VOICE=vi-VN-HoaiMyNeural

# App Timezone
APP_TIMEZONE=Asia/Bangkok

# LiveKit Cloud
LIVEKIT_URL=https://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_WEBHOOK_API_KEY=your_livekit_api_key
LIVEKIT_WEBHOOK_SECRET=your_livekit_api_secret

# Live attendance / rewards
LIVE_ATTENDANCE_QUALIFY_MINUTES=10
LIVE_ATTENDANCE_REWARD_POINTS=5

# LiveKit recording to S3-compatible storage (optional)
LIVEKIT_EGRESS_S3_ACCESS_KEY=your_access_key
LIVEKIT_EGRESS_S3_SECRET=your_secret_key
LIVEKIT_EGRESS_S3_SESSION_TOKEN=
LIVEKIT_EGRESS_S3_REGION=ap-southeast-1
LIVEKIT_EGRESS_S3_BUCKET=your-live-replay-bucket
LIVEKIT_EGRESS_S3_ENDPOINT=
LIVEKIT_EGRESS_S3_FORCE_PATH_STYLE=false
LIVEKIT_EGRESS_S3_PREFIX=livestreams
LIVEKIT_EGRESS_S3_TAGGING=
LIVEKIT_EGRESS_S3_CONTENT_DISPOSITION=
LIVEKIT_EGRESS_S3_ASSUME_ROLE_ARN=
LIVEKIT_EGRESS_S3_ASSUME_ROLE_EXTERNAL_ID=

# ========================================
# IMPORTANT - MONGODB ATLAS IP WHITELIST
# ========================================
# If you see "Could not connect to any servers in your MongoDB Atlas cluster":
#
# 1. Go to https://cloud.mongodb.com
# 2. Click on your cluster name
# 3. Go to "Security" -> "Network Access"
# 4. Click "Add IP Address"
# 5. Choose one of these options:
#    - Add your current IP (best for development)
#    - Add 0.0.0.0/0 (allow all - NOT recommended for production)
# 6. Save and wait 1-2 minutes for the change to take effect
#
# If connecting from different networks, you may need to add multiple IPs
# or allow 0.0.0.0/0 temporarily for local testing
